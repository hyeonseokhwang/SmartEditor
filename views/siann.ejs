      3:  { name:'Pure White (미니멀)',    bg:'#FAFAF8', deep:'#F0F0EC', mid:'#E8E8E2', card:'#FFFFFF', accent:'#2C2C2C', accentLt:'#555555', accentDk:'#111111', text:'#1A1A1A', text2:'#444444', gray:'#888888', heroBg:'radial-gradient(ellipse 80% 60% at 50% 35%, #E8E8E0 0%, #FAFAF8 65%)', quotesBg:'linear-gradient(160deg,#F0F0EC 0%,#E4E4DC 50%,#F0F0EC 100%)', footerBg:'#1A1A1A', navBg:'rgba(250,250,248,0.98)', border:'rgba(44,44,44,0.12)' },
      4:  { name:'Earthy Brown (대지)',    bg:'#1C1208', deep:'#241808', mid:'#2E200E', card:'#261A0A', accent:'#D4882A', accentLt:'#EAA845', accentDk:'#956018', text:'#F5EAD4', text2:'#D9C9A8', gray:'#8A7658', heroBg:'radial-gradient(ellipse 80% 60% at 50% 35%, #3A2810 0%, #1C1208 65%)', quotesBg:'linear-gradient(160deg,#241808 0%,#2E2010 50%,#241808 100%)', footerBg:'#0E0905', navBg:'rgba(28,18,8,0.98)', border:'rgba(212,136,42,0.18)' },
      5:  { name:'Dawn Mist (새벽 안개)',  bg:'#F2F4F7', deep:'#E8ECF3', mid:'#DDE3EF', card:'#FFFFFF', accent:'#5B7FA6', accentLt:'#7B9DC4', accentDk:'#3A5F85', text:'#2A3547', text2:'#4A5E7A', gray:'#8A9AB5', heroBg:'radial-gradient(ellipse 80% 60% at 50% 35%, #D8E4F5 0%, #F2F4F7 65%)', quotesBg:'linear-gradient(160deg,#E8ECF3 0%,#DCE4F0 50%,#E8ECF3 100%)', footerBg:'#2A3547', navBg:'rgba(242,244,247,0.98)', border:'rgba(91,127,166,0.18)' },
