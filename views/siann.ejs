      7:  { name:'Bamboo (대나무)',        bg:'#F8F5EC', deep:'#F0EBD8', mid:'#E8E0C8', card:'#FFFDF6', accent:'#5C7A3E', accentLt:'#7A9E56', accentDk:'#3E5A28', text:'#2A3018', text2:'#4A5830', gray:'#7A8A68', heroBg:'radial-gradient(ellipse 80% 60% at 50% 35%, #E0EDD4 0%, #F8F5EC 65%)', quotesBg:'linear-gradient(160deg,#F0EBD8 0%,#E8E2D0 50%,#F0EBD8 100%)', footerBg:'#1A2010', navBg:'rgba(248,245,236,0.98)', border:'rgba(92,122,62,0.18)' },
      8:  { name:'Stone Mountain (산)',   bg:'#141414', deep:'#1C1C1C', mid:'#242424', card:'#1A1A1A', accent:'#A0A8B0', accentLt:'#C0C8D0', accentDk:'#6A7280', text:'#E8EAEC', text2:'#B8BCC4', gray:'#6A7280', heroBg:'radial-gradient(ellipse 80% 60% at 50% 35%, #282828 0%, #141414 65%)', quotesBg:'linear-gradient(160deg,#1C1C1C 0%,#242424 50%,#1C1C1C 100%)', footerBg:'#080808', navBg:'rgba(20,20,20,0.98)', border:'rgba(160,168,176,0.18)' },
      9:  { name:'Deep Teal (청록)',      bg:'#061518', deep:'#091E22', mid:'#0E282E', card:'#0A1E24', accent:'#3DB8C4', accentLt:'#65CED8', accentDk:'#228898', text:'#E0F4F6', text2:'#B8E4E8', gray:'#5A8A90', heroBg:'radial-gradient(ellipse 80% 60% at 50% 35%, #0E3038 0%, #061518 65%)', quotesBg:'linear-gradient(160deg,#091E22 0%,#0E2C34 50%,#091E22 100%)', footerBg:'#030B0D', navBg:'rgba(6,21,24,0.98)', border:'rgba(61,184,196,0.18)' },
      10: { name:'Warm Amber (앰버)',     bg:'#1A0E00', deep:'#221400', mid:'#2C1C00', card:'#221400', accent:'#E8A020', accentLt:'#F0BE50', accentDk:'#A86E00', text:'#FFF0D0', text2:'#E8D4A8', gray:'#907848', heroBg:'radial-gradient(ellipse 80% 60% at 50% 35%, #3A2400 0%, #1A0E00 65%)', quotesBg:'linear-gradient(160deg,#221400 0%,#302000 50%,#221400 100%)', footerBg:'#0D0700', navBg:'rgba(26,14,0,0.98)', border:'rgba(232,160,32,0.18)' },
      11: { name:'Ocean Night (밤바다)',  bg:'#020C1B', deep:'#031628', mid:'#042035', card:'#041828', accent:'#4A9ECC', accentLt:'#72BEE4', accentDk:'#2A6E9C', text:'#E0EEFF', text2:'#B0CCEE', gray:'#4A6A88', heroBg:'radial-gradient(ellipse 80% 60% at 50% 35%, #062040 0%, #020C1B 65%)', quotesBg:'linear-gradient(160deg,#031628 0%,#042234 50%,#031628 100%)', footerBg:'#01060E', navBg:'rgba(2,12,27,0.98)', border:'rgba(74,158,204,0.18)' },
      12: { name:'Warm Sand (모래)',      bg:'#F7F0E4', deep:'#EDE4D4', mid:'#E4D8C4', card:'#FFFDF8', accent:'#8B6840', accentLt:'#A88058', accentDk:'#6A4A28', text:'#2C2018', text2:'#4A3828', gray:'#8A7860', heroBg:'radial-gradient(ellipse 80% 60% at 50% 35%, #EAD8BC 0%, #F7F0E4 65%)', quotesBg:'linear-gradient(160deg,#EDE4D4 0%,#E5D9C8 50%,#EDE4D4 100%)', footerBg:'#1C1408', navBg:'rgba(247,240,228,0.98)', border:'rgba(139,104,64,0.18)' },
      13: { name:'Moss Green (이끼)',     bg:'#0A1208', deep:'#101A0E', mid:'#162014', card:'#0E1A0C', accent:'#8AB84A', accentLt:'#A8D468', accentDk:'#5A8028', text:'#E4F0D8', text2:'#C0D8A8', gray:'#6A8850', heroBg:'radial-gradient(ellipse 80% 60% at 50% 35%, #162814 0%, #0A1208 65%)', quotesBg:'linear-gradient(160deg,#101A0E 0%,#162418 50%,#101A0E 100%)', footerBg:'#050804', navBg:'rgba(10,18,8,0.98)', border:'rgba(138,184,74,0.18)' },
      14: { name:'Midnight Indigo (인디고)', bg:'#070A1F', deep:'#0C1030', mid:'#121840', card:'#0E1438', accent:'#7B8ED4', accentLt:'#9AAAE8', accentDk:'#4A60A8', text:'#E8EAFF', text2:'#C0C8F0', gray:'#5A6898', heroBg:'radial-gradient(ellipse 80% 60% at 50% 35%, #141A48 0%, #070A1F 65%)', quotesBg:'linear-gradient(160deg,#0C1030 0%,#141C44 50%,#0C1030 100%)', footerBg:'#03040F', navBg:'rgba(7,10,31,0.98)', border:'rgba(123,142,212,0.18)' },
      15: { name:'Parchment (양피지)',    bg:'#F4EDD8', deep:'#EDE4C8', mid:'#E4D8B8', card:'#FBF6E8', accent:'#6B4C22', accentLt:'#8B6C3A', accentDk:'#4A3010', text:'#2A1C08', text2:'#4A3420', gray:'#7A6040', heroBg:'radial-gradient(ellipse 80% 60% at 50% 35%, #E8D8B4 0%, #F4EDD8 65%)', quotesBg:'linear-gradient(160deg,#EDE4C8 0%,#E6DBBC 50%,#EDE4C8 100%)', footerBg:'#1A1005', navBg:'rgba(244,237,216,0.98)', border:'rgba(107,76,34,0.18)' },
      16: { name:'Rose Quartz (로즈)',    bg:'#1A0C10', deep:'#240F15', mid:'#2E141C', card:'#1E0E14', accent:'#D4849A', accentLt:'#E8A8BE', accentDk:'#9A5068', text:'#FFE8F0', text2:'#E8C4D4', gray:'#907080', heroBg:'radial-gradient(ellipse 80% 60% at 50% 35%, #3A1820 0%, #1A0C10 65%)', quotesBg:'linear-gradient(160deg,#240F15 0%,#2E1820 50%,#240F15 100%)', footerBg:'#0D0608', navBg:'rgba(26,12,16,0.98)', border:'rgba(212,132,154,0.18)' },
      17: { name:'Obsidian (흑요석)',     bg:'#050505', deep:'#0A0A0A', mid:'#111111', card:'#080808', accent:'#D4A840', accentLt:'#E8C460', accentDk:'#9A7A20', text:'#F0EEE8', text2:'#C8C4B8', gray:'#6A6860', heroBg:'radial-gradient(ellipse 80% 60% at 50% 35%, #181818 0%, #050505 65%)', quotesBg:'linear-gradient(160deg,#0A0A0A 0%,#141414 50%,#0A0A0A 100%)', footerBg:'#020202', navBg:'rgba(5,5,5,0.98)', border:'rgba(212,168,64,0.18)' },
      18: { name:'Celadon (청자)',        bg:'#0A1618', deep:'#0E1E22', mid:'#14282E', card:'#0E1E24', accent:'#78B4AA', accentLt:'#98D0C4', accentDk:'#4A8880', text:'#E4F2F0', text2:'#C0DCDA', gray:'#5A8880', heroBg:'radial-gradient(ellipse 80% 60% at 50% 35%, #142C30 0%, #0A1618 65%)', quotesBg:'linear-gradient(160deg,#0E1E22 0%,#142A30 50%,#0E1E22 100%)', footerBg:'#05080A', navBg:'rgba(10,22,24,0.98)', border:'rgba(120,180,170,0.18)' },
      19: { name:'Winter White (겨울)',   bg:'#F4F6FA', deep:'#EAEEf4', mid:'#E0E6F0', card:'#FFFFFF', accent:'#3A5C8C', accentLt:'#5A80B4', accentDk:'#1A3C6C', text:'#1A2440', text2:'#3A4C6C', gray:'#7A8CAA', heroBg:'radial-gradient(ellipse 80% 60% at 50% 35%, #D8E4F2 0%, #F4F6FA 65%)', quotesBg:'linear-gradient(160deg,#EAEEf4 0%,#E0E8F2 50%,#EAEEf4 100%)', footerBg:'#1A2440', navBg:'rgba(244,246,250,0.98)', border:'rgba(58,92,140,0.15)' },
      20: { name:'Copper Age (고동)',     bg:'#12080A', deep:'#1C0E10', mid:'#281618', card:'#1A0E10', accent:'#C47848', accentLt:'#DC9860', accentDk:'#8A5028', text:'#F5E8DC', text2:'#D8C4B4', gray:'#8A6858', heroBg:'radial-gradient(ellipse 80% 60% at 50% 35%, #2C1810 0%, #12080A 65%)', quotesBg:'linear-gradient(160deg,#1C0E10 0%,#261818 50%,#1C0E10 100%)', footerBg:'#080408', navBg:'rgba(18,8,10,0.98)', border:'rgba(196,120,72,0.18)' },
    };
    const t = themes[themeId] || themes[1];
    const isLight = [3,5,7,12,15,19].includes(themeId);
    %>
    :root {
      --navy:      <%= t.bg %>;
      --deep:      <%= t.deep %>;
      --mid:       <%= t.mid %>;
      --card:      <%= t.card %>;
      --gold:      <%= t.accent %>;
      --gold-lt:   <%= t.accentLt %>;
      --gold-dk:   <%= t.accentDk %>;
      --cream:     <%= t.text %>;
      --cream-2:   <%= t.text2 %>;
      --gray:      <%= t.gray %>;
      --border:    <%= t.border %>;
      --serif:     'Noto Serif KR', 'Malgun Gothic', serif;
      --sans:      'Noto Sans KR', 'Malgun Gothic', sans-serif;
    }

    html { scroll-behavior: smooth; }
    body { font-family: var(--sans); background: var(--navy); color: var(--cream); overflow-x: hidden; }

    /* 시안 배지 */
    .siann-badge {
      position: fixed; top: 0; left: 0; right: 0; z-index: 999;
      background: rgba(0,0,0,0.85); color: #fff; text-align: center;
      padding: 6px 16px; font-size: 12px; letter-spacing: 0.1em;
      border-bottom: 2px solid <%= t.accent %>;
    }
    .siann-badge span { color: <%= t.accent %>; font-weight: 700; }
    .siann-nav { display: flex; justify-content: center; gap: 6px; margin-top: 4px; flex-wrap: wrap; }
    .siann-nav a {
      display: inline-block; width: 24px; height: 24px; line-height: 24px; text-align: center;
      border-radius: 50%; background: rgba(255,255,255,0.1); font-size: 11px; color: #ccc;
      text-decoration: none; transition: background 0.2s;
    }
    .siann-nav a:hover, .siann-nav a.cur { background: <%= t.accent %>; color: #000; font-weight: 700; }

    /* NAV */
    nav {
      position: fixed; top: 58px; left: 0; right: 0; z-index: 200;
      display: flex; align-items: center; justify-content: space-between;
      padding: 18px 64px;
      background: linear-gradient(180deg, <%= t.navBg %> 0%, <%= t.bg %>00 100%);
      transition: background 0.4s, box-shadow 0.4s;
    }
    nav.pinned {
      background: <%= t.navBg %>;
      box-shadow: 0 1px 0 var(--border);
    }
    .nav-logo { font-family: var(--serif); font-size: 20px; font-weight: 600; color: var(--gold); letter-spacing: 0.06em; text-decoration: none; }
    .nav-logo span { color: var(--cream); }
    .nav-menu { display: flex; gap: 36px; list-style: none; }
    .nav-menu a { font-size: 13px; color: var(--cream-2); text-decoration: none; transition: color 0.2s; }
    .nav-menu a:hover { color: var(--gold); }
    .nav-cta { padding: 9px 22px; border: 1px solid var(--gold); border-radius: 2px; font-size: 12px; color: var(--gold); background: transparent; text-decoration: none; transition: all .22s; }
    .nav-cta:hover { background: var(--gold); color: var(--navy); }

    /* HERO */
    .hero {
      position: relative; min-height: 100vh; padding-top: 58px;
      display: flex; align-items: center; justify-content: center;
      overflow: hidden;
      background: <%= t.heroBg %>;
    }
    .stars {
      position: absolute; inset: 0; pointer-events: none;
      background-image:
        radial-gradient(1.5px 1.5px at 8%  18%, rgba(255,255,255,.35) 0%, transparent 100%),
        radial-gradient(1px   1px   at 18% 72%, rgba(255,255,255,.25) 0%, transparent 100%),
        radial-gradient(1px   1px   at 28% 10%, rgba(255,255,255,.30) 0%, transparent 100%),
        radial-gradient(2px   2px   at 42% 58%, <%= t.accent %>44  0%, transparent 100%),
        radial-gradient(1px   1px   at 55% 25%, rgba(255,255,255,.25) 0%, transparent 100%),
        radial-gradient(1.5px 1.5px at 75% 12%, rgba(255,255,255,.40) 0%, transparent 100%),
        radial-gradient(2px   2px   at 90% 68%, <%= t.accent %>33  0%, transparent 100%);
    }
    .mandala { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 900px; height: 900px; pointer-events: none; }
    .mandala svg { width: 100%; height: 100%; animation: mandalaSpin 120s linear infinite; }
    @keyframes mandalaSpin { to { transform: rotate(360deg); } }

    .hero-inner { position: relative; z-index: 2; text-align: center; padding: 0 24px; }
    .eyebrow { display: inline-block; font-size: 11px; font-weight: 500; letter-spacing: 0.45em; text-transform: uppercase; color: var(--gold); margin-bottom: 32px; opacity: 0; animation: fadeUp .9s ease .2s forwards; }
    .hero-title { font-family: var(--serif); font-size: clamp(48px,8vw,96px); font-weight: 600; color: var(--cream); line-height: 1.08; letter-spacing: -0.01em; margin-bottom: 28px; opacity: 0; animation: fadeUp .9s ease .4s forwards; }
    .hero-title em { font-style: normal; color: var(--gold); }
    .hero-sub { font-family: var(--serif); font-size: clamp(15px,2vw,19px); font-weight: 300; color: var(--cream-2); line-height: 1.95; max-width: 560px; margin: 0 auto 52px; opacity: 0; animation: fadeUp .9s ease .6s forwards; }
    .hero-btns { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; opacity: 0; animation: fadeUp .9s ease .8s forwards; }
    .btn-fill { display: inline-block; padding: 15px 40px; background: var(--gold); color: var(--navy); font-family: var(--sans); font-size: 14px; font-weight: 700; letter-spacing: 0.07em; border-radius: 2px; text-decoration: none; transition: all .22s; }
    .btn-fill:hover { background: var(--gold-lt); transform: translateY(-2px); }
    .btn-line { display: inline-block; padding: 15px 40px; border: 1px solid var(--border); color: var(--cream-2); font-family: var(--sans); font-size: 14px; letter-spacing: 0.07em; border-radius: 2px; text-decoration: none; transition: all .22s; }
    .btn-line:hover { border-color: var(--gold); color: var(--gold); }
    .scroll-hint { position: absolute; bottom: 36px; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; gap: 10px; opacity: 0; animation: fadeIn 1s ease 1.4s forwards; }
    .scroll-hint span { font-size: 10px; letter-spacing: 0.38em; color: var(--gray); text-transform: uppercase; }
    .scroll-bar { width: 1px; height: 44px; background: linear-gradient(180deg, var(--gold) 0%, transparent 100%); animation: scrollAnim 2s ease-in-out infinite; }
    @keyframes scrollAnim { 0%,100%{opacity:0;transform:scaleY(0) translateY(-100%)} 40%{opacity:1;transform:scaleY(1) translateY(0)} 80%{opacity:0;transform:scaleY(0) translateY(100%)} }
    @keyframes fadeUp { from{opacity:0;transform:translateY(22px)} to{opacity:1;transform:translateY(0)} }
    @keyframes fadeIn { to{opacity:1} }

    /* SECTIONS */
    section { padding: 120px 64px; }
    .wrap { max-width: 1120px; margin: 0 auto; }
    .s-label { font-size: 10.5px; font-weight: 600; letter-spacing: 0.42em; text-transform: uppercase; color: var(--gold); margin-bottom: 18px; }
    .s-title { font-family: var(--serif); font-size: clamp(26px,3.5vw,44px); font-weight: 500; color: var(--cream); line-height: 1.28; margin-bottom: 20px; }
    .s-bar { width: 44px; height: 2px; background: var(--gold); margin-bottom: 36px; }
    .s-body { font-family: var(--serif); font-size: 17px; font-weight: 300; color: var(--cream-2); line-height: 2.0; max-width: 580px; }

    .about { background: var(--deep); }
    .about-intro { max-width: 680px; margin-bottom: 72px; }
    .about-cards { display: grid; grid-template-columns: repeat(3,1fr); gap: 3px; }
    .about-card { background: var(--card); padding: 48px 36px 44px; position: relative; overflow: hidden; transition: transform .3s; }
    .about-card::after { content:''; position:absolute; bottom:0; left:0; right:0; height:2px; background: var(--gold); transform: scaleX(0); transform-origin: left; transition: transform .4s; }
    .about-card:hover { transform: translateY(-6px); }
    .about-card:hover::after { transform: scaleX(1); }
    .ac-hanja { position: absolute; top: 28px; right: 28px; font-family: var(--serif); font-size: 52px; font-weight: 700; color: <%= t.accent %>14; line-height: 1; pointer-events: none; }
    .ac-num { font-size: 11px; letter-spacing: 0.3em; color: var(--gold-dk); margin-bottom: 24px; }
    .ac-name { font-family: var(--serif); font-size: 24px; font-weight: 500; color: var(--cream); margin-bottom: 10px; }
    .ac-sub { font-size: 12px; letter-spacing: 0.2em; color: var(--gold); margin-bottom: 20px; }
    .ac-desc { font-family: var(--serif); font-size: 15px; font-weight: 300; color: var(--cream-2); line-height: 1.95; }

    .teachings { background: var(--navy); }
    .teach-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 24px; margin-top: 60px; }
    .teach-card { background: var(--card); padding: 44px 36px 40px; border: 1px solid var(--border); border-radius: 2px; transition: border-color .3s, transform .3s; }
    .teach-card:hover { border-color: var(--gold-lt); transform: translateY(-6px); }
    .t-icon { width: 52px; height: 52px; border-radius: 50%; border: 1px solid var(--gold-dk); display: flex; align-items: center; justify-content: center; font-family: var(--serif); font-size: 22px; color: var(--gold); margin-bottom: 24px; }
    .t-name { font-family: var(--serif); font-size: 22px; font-weight: 500; color: var(--cream); margin-bottom: 8px; }
    .t-hanja-sm { font-size: 12px; letter-spacing: 0.22em; color: var(--gold); margin-bottom: 18px; }
    .t-desc { font-family: var(--serif); font-size: 15px; font-weight: 300; color: var(--cream-2); line-height: 1.95; }

    .quotes { background: <%= t.quotesBg %>; position: relative; overflow: hidden; }
    .quotes-bg { position: absolute; right: -20px; top: 50%; transform: translateY(-50%); font-family: var(--serif); font-size: 180px; font-weight: 700; color: <%= t.accent %>09; letter-spacing: -0.04em; pointer-events: none; white-space: nowrap; }
    .quotes-grid { display: grid; grid-template-columns: 1fr; gap: 56px; position: relative; z-index: 1; }
    .quote-item { max-width: 760px; }
    .q-mark { font-family: var(--serif); font-size: 64px; font-weight: 700; color: var(--gold); line-height: 0.6; margin-bottom: 16px; opacity: 0.5; }
    .q-text { font-family: var(--serif); font-size: clamp(18px,2.4vw,26px); font-weight: 400; color: var(--cream); line-height: 1.72; margin-bottom: 20px; }
    .q-attr { font-family: var(--serif); font-size: 13px; font-weight: 300; color: var(--gold); letter-spacing: 0.08em; }
    .q-divider { width: 40px; height: 1px; background: var(--gold-dk); margin: 40px 0; opacity: 0.5; }

    .center { background: var(--deep); }
    .center-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: start; }
    .programs { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 8px; }
    .prog-item { padding: 28px 24px; border: 1px solid var(--border); background: rgba(0,0,0,0.04); border-radius: 2px; transition: border-color .3s; }
    .prog-item:hover { border-color: var(--gold); }
    .prog-item h4 { font-family: var(--serif); font-size: 16px; font-weight: 500; color: var(--cream); margin-bottom: 8px; }
    .prog-item p { font-family: var(--serif); font-size: 13px; font-weight: 300; color: var(--cream-2); line-height: 1.8; }
    .center-symbol { display: flex; align-items: center; justify-content: center; height: 460px; position: sticky; top: 120px; }
    .center-symbol svg { width: 360px; height: 360px; }

    .archive { background: var(--navy); text-align: center; }
    .archive-num { font-family: var(--serif); font-size: clamp(64px,10vw,120px); font-weight: 700; color: var(--gold); line-height: 1; margin-bottom: 8px; opacity: 0.85; }
    .archive-sub { font-size: 12px; letter-spacing: 0.4em; color: var(--gray); text-transform: uppercase; margin-bottom: 40px; }
    .archive-desc { font-family: var(--serif); font-size: 18px; font-weight: 300; color: var(--cream-2); line-height: 1.85; max-width: 520px; margin: 0 auto 52px; }

    .qa-sec { background: radial-gradient(ellipse 70% 80% at 50% 50%, <%= t.mid %> 0%, <%= t.bg %> 70%); text-align: center; position: relative; overflow: hidden; }
    .qa-rings { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); pointer-events: none; }
    .qa-rings span { display: block; position: absolute; border-radius: 50%; border: 1px solid var(--border); transform: translate(-50%,-50%); }
    .qa-inner { position: relative; z-index: 2; }
    .qa-badge { display: inline-block; padding: 6px 16px; border: 1px solid var(--border); border-radius: 20px; font-size: 11px; letter-spacing: 0.28em; color: var(--gold-dk); text-transform: uppercase; margin-bottom: 28px; }
    .qa-title { font-family: var(--serif); font-size: clamp(24px,3.6vw,46px); font-weight: 500; color: var(--cream); line-height: 1.35; margin-bottom: 20px; }
    .qa-body { font-family: var(--serif); font-size: 17px; font-weight: 300; color: var(--cream-2); line-height: 1.85; max-width: 480px; margin: 0 auto 48px; }
    .qa-input-wrap { display: flex; max-width: 560px; margin: 0 auto; border: 1px solid var(--border); border-radius: 2px; overflow: hidden; }
    .qa-input { flex: 1; padding: 16px 20px; background: rgba(0,0,0,0.05); border: none; outline: none; font-family: var(--serif); font-size: 15px; color: var(--cream); }
    .qa-input::placeholder { color: var(--gray); }
    .qa-btn { padding: 16px 28px; background: var(--gold); color: var(--navy); font-family: var(--sans); font-size: 13px; font-weight: 700; border: none; cursor: pointer; }
    .qa-coming { font-size: 12px; color: var(--gray); margin-top: 16px; }

    footer { background: <%= t.footerBg %>; padding: 64px; border-top: 1px solid var(--border); }
    .ft-inner { max-width: 1120px; margin: 0 auto; display: flex; gap: 48px; justify-content: space-between; flex-wrap: wrap; }
    .ft-brand .logo { font-family: var(--serif); font-size: 20px; color: var(--gold); font-weight: 600; margin-bottom: 14px; }
    .ft-brand p { font-size: 13px; color: var(--gray); line-height: 1.8; max-width: 260px; }
    .ft-col h4 { font-size: 10px; letter-spacing: 0.36em; color: var(--gold); text-transform: uppercase; margin-bottom: 18px; }
    .ft-col ul { list-style: none; }
    .ft-col li { margin-bottom: 10px; }
    .ft-col a { font-size: 14px; color: var(--gray); text-decoration: none; transition: color .2s; }
    .ft-col a:hover { color: var(--cream); }
    .ft-copy { max-width: 1120px; margin: 40px auto 0; padding-top: 24px; border-top: 1px solid rgba(255,255,255,.05); display: flex; justify-content: space-between; flex-wrap: wrap; gap: 8px; font-size: 12px; color: var(--gray); }

    @media (max-width: 960px) {
      nav { padding: 16px 24px; top: 58px; }
      .nav-menu { display: none; }
      section { padding: 80px 24px; }
      .about-cards, .teach-grid, .center-grid, .programs { grid-template-columns: 1fr; }
      footer { padding: 40px 24px; }
    }
  </style>
</head>
