<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>여의명상센터 — 한울사상</title>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@200;300;400;600;900&family=Noto+Sans+KR:wght@100;200;300&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Noto Serif KR', serif;
      background: #FAF8F3;
      color: #1A1612;
      overflow-x: hidden;
    }

    /* ─── TOP BAR ───────────────────────────────────── */
    .topbar {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      height: 56px;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 5vw;
      background: rgba(250,248,243,0.96);
      border-bottom: 1px solid rgba(26,22,18,0.06);
    }
    .topbar-left { display: flex; align-items: center; gap: 3rem; }
    .topbar-logo {
      font-size: 0.9rem; font-weight: 400;
      letter-spacing: 0.15em; color: #1A1612;
      text-decoration: none;
    }
    .topbar-links { display: flex; gap: 2rem; }
    .topbar-links a {
      font-family: 'Noto Sans KR', sans-serif;
      font-size: 0.65rem; font-weight: 200;
      letter-spacing: 0.1em; color: #7A7268;
      text-decoration: none;
      transition: color 0.3s;
    }
    .topbar-links a:hover { color: #1A1612; }
    .topbar-right {
      font-family: 'Noto Sans KR', sans-serif;
      font-size: 0.6rem; font-weight: 200;
      letter-spacing: 0.15em; color: #9A8F7A;
    }

    /* ─── MAGAZINE HERO ─────────────────────────────── */
    .magazine-hero {
      margin-top: 56px;
      display: grid;
      grid-template-columns: 58% 42%;
      height: calc(100vh - 56px);
    }
    .mag-hero-main {
      position: relative; overflow: hidden;
      border-right: 1px solid rgba(26,22,18,0.06);
    }
    .mag-hero-main img {
      width: 100%; height: 100%; object-fit: cover;
    }
    .mag-hero-main-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(26,22,18,0.7) 0%, rgba(26,22,18,0.1) 50%, transparent 100%);
    }
    .mag-hero-main-text {
      position: absolute; bottom: 5vh; left: 6vw; right: 3vw;
    }
    .mag-hero-main-category {
      font-family: 'Noto Sans KR', sans-serif;
      font-size: 0.55rem; font-weight: 200;
      letter-spacing: 0.3em;
      color: rgba(240,235,220,0.7);
      margin-bottom: 1rem;
    }
    .mag-hero-main-title {
      font-size: clamp(2rem, 4vw, 3.2rem);
      font-weight: 300;
      color: rgba(250,248,243,0.96);
      line-height: 1.4;
      letter-spacing: 0.04em;
    }

    .mag-hero-side {
      display: flex; flex-direction: column;
    }
    .mag-hero-side-item {
      flex: 1;
      display: grid; grid-template-columns: 120px 1fr;
      border-bottom: 1px solid rgba(26,22,18,0.06);
      overflow: hidden;
    }
    .mag-hero-side-item:last-child { border-bottom: none; }
    .mag-side-img { overflow: hidden; }
    .mag-side-img img { width: 100%; height: 100%; object-fit: cover; }
    .mag-side-text {
      padding: 1.5rem;
      display: flex; flex-direction: column; justify-content: center;
    }
    .mag-side-cat {
      font-family: 'Noto Sans KR', sans-serif;
      font-size: 0.5rem; font-weight: 200;
      letter-spacing: 0.25em; color: #9A8F7A;
      margin-bottom: 0.5rem;
    }
    .mag-side-title {
      font-size: 0.9rem; font-weight: 300;
      line-height: 1.6; letter-spacing: 0.05em;
      color: #1A1612;
    }

    /* ─── DIVIDER BAR ───────────────────────────────── */
    .divider-bar {
      padding: 1.5rem 5vw;
      border-top: 2px solid #1A1612;
      border-bottom: 1px solid rgba(26,22,18,0.1);
      display: flex; align-items: center; gap: 4rem;
    }
    .divider-tag {
      font-family: 'Noto Sans KR', sans-serif;
      font-size: 0.55rem; font-weight: 200;
      letter-spacing: 0.3em; color: #9A8F7A;
    }
    .divider-title {
      font-size: 1.1rem; font-weight: 400;
      letter-spacing: 0.1em; color: #1A1612;
    }

    /* ─── FEATURE GRID ──────────────────────────────── */
    .feature-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      border-top: 1px solid rgba(26,22,18,0.08);
    }
    .feature-card {
      padding: 5vh 4vw;
      border-right: 1px solid rgba(26,22,18,0.08);
    }
    .feature-card:last-child { border-right: none; }
    .feature-img {
      width: 100%; aspect-ratio: 4/3;
      overflow: hidden; margin-bottom: 2rem;
    }
    .feature-img img {
      width: 100%; height: 100%; object-fit: cover;
      transition: transform 0.8s ease;
    }
    .feature-card:hover .feature-img img { transform: scale(1.04); }
    .feature-num {
      font-family: 'Noto Sans KR', sans-serif;
      font-size: 0.55rem; font-weight: 100;
      letter-spacing: 0.25em; color: #C0B090;
      margin-bottom: 0.8rem;
    }
    .feature-title {
      font-size: 1.05rem; font-weight: 300;
      line-height: 1.6; letter-spacing: 0.06em;
      color: #1A1612; margin-bottom: 0.8rem;
    }
    .feature-desc {
      font-family: 'Noto Sans KR', sans-serif;
      font-size: 0.72rem; font-weight: 200;
      line-height: 1.9; color: #7A7268;
    }

    /* ─── QUOTE FULL ─────────────────────────────────── */
    .quote-full {
      padding: 14vh 5vw;
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 8vw;
      border-top: 1px solid rgba(26,22,18,0.08);
      background: #F5F1EA;
    }
    .quote-full-text {
      display: flex; flex-direction: column; justify-content: center;
    }
    .qf-eyebrow {
      font-family: 'Noto Sans KR', sans-serif;
      font-size: 0.55rem; font-weight: 200;
      letter-spacing: 0.3em; color: #9A8F7A;
      margin-bottom: 2rem;
    }
    .qf-quote {
      font-size: clamp(1.1rem, 2.5vw, 1.7rem);
      font-weight: 300; line-height: 2.0;
      letter-spacing: 0.05em; color: #1A1612;
      margin-bottom: 2rem;
    }
    .qf-source {
      font-family: 'Noto Sans KR', sans-serif;
      font-size: 0.6rem; font-weight: 200;
      letter-spacing: 0.15em; color: #9A8F7A;
    }
    .quote-full-img {
      overflow: hidden; border-radius: 2px;
    }
    .quote-full-img img {
      width: 100%; height: 100%; object-fit: cover;
    }

    /* ─── BANNER STRIP ──────────────────────────────── */
    .banner-strip {
      padding: 6vh 5vw;
      background: #1A1612;
      display: flex; align-items: center; justify-content: space-between;
    }
    .banner-text {
      font-size: clamp(1rem, 2vw, 1.4rem);
      font-weight: 200; letter-spacing: 0.12em;
      color: rgba(250,248,243,0.8);
    }
    .banner-link {
      font-family: 'Noto Sans KR', sans-serif;
      font-size: 0.65rem; font-weight: 200;
      letter-spacing: 0.2em; color: rgba(192,176,144,0.9);
      text-decoration: none;
      border: 1px solid rgba(192,176,144,0.3);
      padding: 0.7rem 1.8rem;
      transition: all 0.3s;
    }
    .banner-link:hover { background: rgba(192,176,144,0.1); }

    /* ─── FOOTER ─────────────────────────────────────── */
    .footer {
      padding: 5vh 5vw;
      border-top: 2px solid #1A1612;
      display: grid; grid-template-columns: 1fr 1fr 1fr;
      gap: 3rem;
    }
    .footer-col-title {
      font-family: 'Noto Sans KR', sans-serif;
      font-size: 0.6rem; font-weight: 300;
      letter-spacing: 0.2em; color: #1A1612;
      margin-bottom: 1.5rem;
      border-bottom: 1px solid rgba(26,22,18,0.1);
      padding-bottom: 0.8rem;
    }
    .footer-col-text {
      font-family: 'Noto Sans KR', sans-serif;
      font-size: 0.65rem; font-weight: 200;
      line-height: 2.0; color: #9A8F7A;
    }
  </style>
</head>
