<script>
  /* ─ NAV scroll ─ */
  const nav=document.getElementById('nav');
  const onScroll=()=>nav.classList.toggle('solid',scrollY>80);
  addEventListener('scroll',onScroll,{passive:true});
  onScroll();

  /* ─ Reveal ─ */
  const io=new IntersectionObserver(es=>{
    es.forEach((e,i)=>{
      if(e.isIntersecting){
        setTimeout(()=>e.target.classList.add('v'),i%5*60);
        io.unobserve(e.target);
      }
    });
  },{threshold:.1,rootMargin:'0px 0px -40px 0px'});
  document.querySelectorAll('.r').forEach(el=>io.observe(el));

  /* ─ Hero parallax ─ */
  const hi=document.querySelector('.hero img');
  let tick=false;
  addEventListener('scroll',()=>{
    if(!tick){requestAnimationFrame(()=>{
      if(hi&&scrollY<innerHeight)hi.style.transform=`translateY(${scrollY*.28}px)scale(1.04)`;
      tick=false;
    });tick=true;}
  },{passive:true});
</script>
