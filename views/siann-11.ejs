    %>

    /* ─── RESET ─── */
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{font-family:'Noto Sans KR',sans-serif;background:<%= t.bg %>;color:<%= t.tx %>;overflow-x:hidden;-webkit-font-smoothing:antialiased}
    img{display:block;width:100%;height:100%;object-fit:cover}

    /* ─── BADGE ─── */
    .badge{position:fixed;top:0;left:0;right:0;z-index:9000;background:rgba(0,0,0,.92);text-align:center;padding:4px 16px;font-size:10px;letter-spacing:.06em;color:#aaa;border-bottom:2px solid <%= t.ac %>}
    .badge b{color:<%= t.ac %>}
    .nums{display:flex;justify-content:center;gap:3px;flex-wrap:wrap;margin-top:3px}
    .nums a{display:inline-flex;align-items:center;justify-content:center;width:20px;height:20px;border-radius:50%;background:rgba(255,255,255,.08);font-size:9px;color:#999;text-decoration:none;transition:.2s}
    .nums a:hover,.nums a.on{background:<%= t.ac %>;color:#000;font-weight:700}

    /* ─── NAV ─── */
    nav{position:fixed;top:46px;left:0;right:0;z-index:800;padding:0 72px;height:64px;display:flex;align-items:center;justify-content:space-between;transition:background .4s,box-shadow .4s}
    nav.solid{background:<%= t.nav %>;backdrop-filter:blur(20px);box-shadow:0 1px 0 <%= t.bd %>}
    .logo{font-family:'Noto Serif KR',serif;font-size:16px;font-weight:400;color:#fff;letter-spacing:.04em;text-decoration:none}
    nav.solid .logo{color:<%= t.tx %>}
    .nl{display:flex;gap:36px;list-style:none}
    .nl a{font-size:12px;letter-spacing:.04em;color:rgba(255,255,255,.75);text-decoration:none;transition:color .2s}
    nav.solid .nl a{color:<%= t.t2 %>}
    .nl a:hover{color:<%= t.ac %>}
    .ncta{padding:9px 26px;border:1px solid rgba(255,255,255,.5);color:#fff;font-size:11px;letter-spacing:.08em;border-radius:1px;transition:.25s;text-decoration:none}
    nav.solid .ncta{border-color:<%= t.bd %>;color:<%= t.ac %>}
    .ncta:hover{background:<%= t.ac %>;border-color:<%= t.ac %>;color:#fff}

    /* ─── HERO (100vh fullscreen — no margin/sidebar) ─── */
    .hero{position:relative;width:100vw;height:100vh;overflow:hidden;margin:0;padding:0}
    .hero img{position:absolute;inset:0;transition:transform 14s ease}
    .hero-ov{position:absolute;inset:0;background:linear-gradient(to bottom,rgba(0,0,0,.04) 0%,rgba(0,0,0,.28) 48%,rgba(0,0,0,.75) 100%)}
    .hero-body{position:absolute;bottom:0;left:0;right:0;padding:0 96px 100px;text-align:left}
    .hero-label{font-size:10px;letter-spacing:.32em;color:rgba(255,255,255,.55);text-transform:uppercase;margin-bottom:24px;display:block}
    .hero-h1{font-family:'Noto Serif KR',serif;font-size:clamp(2.8rem,6.5vw,5.6rem);font-weight:200;color:#fff;line-height:1.15;margin-bottom:40px;max-width:760px}
    .hero-h1 em{font-style:normal;font-weight:400;color:<%= t.ac %>}
    .hb1{display:inline-block;padding:16px 52px;background:transparent;border:1px solid rgba(255,255,255,.6);color:#fff;font-size:12px;font-weight:300;letter-spacing:.14em;border-radius:0;text-decoration:none;transition:.3s}
    .hb1:hover{background:rgba(255,255,255,.12);border-color:#fff}
    .sc{position:absolute;bottom:32px;right:96px;display:flex;flex-direction:column;align-items:center;gap:6px;color:rgba(255,255,255,.38);font-size:9px;letter-spacing:.18em}
    .sc-line{width:1px;height:44px;background:linear-gradient(to bottom,rgba(255,255,255,.5),transparent);animation:scrl 2s infinite}
    @keyframes scrl{0%{transform:scaleY(0);transform-origin:top}50%{transform:scaleY(1);transform-origin:top}51%{transform:scaleY(1);transform-origin:bottom}100%{transform:scaleY(0);transform-origin:bottom}}

    /* ─── ABOUT (split: 82% image / 18% text) ─── */
    .about{display:grid;grid-template-columns:82% 1fr;min-height:700px}
    .about-img{position:relative;overflow:hidden}
    .about-img img{transition:transform 8s ease}
    .about-img:hover img{transform:scale(1.04)}
    .about-txt{background:<%= t.bg2 %>;display:flex;flex-direction:column;justify-content:center;padding:80px 72px}
    .sl{display:block;font-size:10px;letter-spacing:.26em;text-transform:uppercase;color:<%= t.ac %>;margin-bottom:18px}
    .st{font-family:'Noto Serif KR',serif;font-size:clamp(1.6rem,2.5vw,2.4rem);font-weight:300;color:<%= t.tx %>;line-height:1.45;margin-bottom:20px}
    .sdiv{width:32px;height:1.5px;background:<%= t.ac %>;margin-bottom:28px}
    .sq{padding-left:20px;border-left:2px solid rgba(<%= t.acR %>,0.5);font-family:'Noto Serif KR',serif;font-size:.95rem;font-weight:300;color:<%= t.t2 %>;line-height:2;font-style:italic}

    /* ─── PHILOSOPHY PANELS (3 fullscreen image sections) ─── */
    .panels{display:flex;flex-direction:column}
    .panel{position:relative;height:660px;overflow:hidden}
    .panel img{position:absolute;inset:0;transition:transform .7s ease}
    .panel:hover img{transform:scale(1.05)}
    .pov{position:absolute;inset:0}
    .panel:nth-child(odd) .pov{background:linear-gradient(to right,rgba(0,0,0,.75) 0%,rgba(0,0,0,.25) 50%,transparent 100%)}
    .panel:nth-child(even) .pov{background:linear-gradient(to left,rgba(0,0,0,.75) 0%,rgba(0,0,0,.25) 50%,transparent 100%)}
    .pb{position:absolute;top:50%;transform:translateY(-50%);max-width:480px;padding:0 80px}
    .panel:nth-child(even) .pb{right:0;left:auto;text-align:right}
    .pn{font-size:10px;letter-spacing:.3em;color:rgba(255,255,255,.45);margin-bottom:14px}
    .pt{font-family:'Noto Serif KR',serif;font-size:clamp(1.8rem,3.2vw,3rem);font-weight:200;color:#fff;line-height:1.25}
    .pt em{font-style:normal;display:block;font-size:.55em;color:rgba(255,255,255,.6);font-weight:300;margin-top:6px;letter-spacing:.04em}

    /* ─── GALLERY (image-only grid) ─── */
    .gallery{background:<%= t.bg2 %>;padding:80px}
    .gl-head{text-align:center;margin-bottom:40px}
    .gl-grid{display:grid;grid-template-columns:repeat(3,1fr);grid-template-rows:auto auto;gap:4px}
    .gl-item{position:relative;overflow:hidden;cursor:pointer}
    .gl-item:first-child{grid-row:1/3}
    .gl-item{aspect-ratio:3/2}
    .gl-item:first-child{aspect-ratio:auto}
    .gl-item img{transition:transform .5s ease}
    .gl-item:hover img{transform:scale(1.08)}
    .gl-cap{position:absolute;inset:0;background:rgba(0,0,0,0);display:flex;align-items:flex-end;padding:16px;transition:background .3s}
    .gl-item:hover .gl-cap{background:rgba(0,0,0,.3)}
    .gl-cap span{font-family:'Noto Serif KR',serif;font-size:12px;color:rgba(255,255,255,0);letter-spacing:.08em;transition:color .3s}
    .gl-item:hover .gl-cap span{color:#fff}

    /* ─── PROGRAMS (image cards, hover reveal) ─── */
    .programs{padding:100px 80px;background:<%= t.bg %>}
    .ph{text-align:center;margin-bottom:56px}
    .pg{display:grid;grid-template-columns:repeat(3,1fr);gap:2px}
    .pc{position:relative;height:560px;overflow:hidden;cursor:pointer}
    .pc img{position:absolute;inset:0;transition:transform .6s ease}
    .pc:hover img{transform:scale(1.07)}
    .pco{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.88) 0%,rgba(0,0,0,.2) 50%,rgba(0,0,0,0) 100%)}
    .pcb{position:absolute;bottom:0;left:0;right:0;padding:32px;transform:translateY(48px);transition:transform .4s ease}
    .pc:hover .pcb{transform:translateY(0)}
    .pcn{font-size:9px;letter-spacing:.28em;color:rgba(255,255,255,.45);margin-bottom:8px}
    .pct{font-family:'Noto Serif KR',serif;font-size:1.3rem;font-weight:300;color:#fff;line-height:1.35;margin-bottom:8px}
    .pcd{font-size:12px;color:rgba(255,255,255,.65);line-height:1.75;opacity:0;transition:opacity .4s .1s}
    .pc:hover .pcd{opacity:1}

    /* ─── FULLSCREEN QUOTE ─── */
    .fq{position:relative;height:640px;overflow:hidden}
    .fq img{position:absolute;inset:0;transition:transform 10s ease}
    .fq:hover img{transform:scale(1.04)}
    .fq-ov{position:absolute;inset:0;background:rgba(0,0,0,.55)}
    .fq-body{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:40px 80px;text-align:center}
    .fq-mark{font-size:7rem;font-family:Georgia,serif;color:rgba(255,255,255,.12);line-height:1;margin-bottom:-20px}
    .fq-q{font-family:'Noto Serif KR',serif;font-size:clamp(1.4rem,2.8vw,2.2rem);font-weight:200;color:#fff;line-height:1.85;max-width:820px;margin-bottom:28px}
    .fq-cite{font-size:11px;letter-spacing:.22em;color:rgba(<%= t.acR %>,.85);text-transform:uppercase}

    /* ─── SCHEDULE ─── */
    .schedule{background:<%= t.bg2 %>;padding:88px 80px}
    .sl-list{margin-top:48px}
    .sl-item{display:grid;grid-template-columns:100px 1fr auto;align-items:center;gap:40px;padding:24px 0;border-bottom:1px solid <%= t.bd %>}
    .sl-item:first-child{border-top:1px solid <%= t.bd %>}
    .sd{text-align:center}
    .sd-day{font-family:'Noto Serif KR',serif;font-size:2rem;font-weight:200;color:<%= t.ac %>;line-height:1}
    .sd-mon{font-size:9px;letter-spacing:.16em;color:<%= t.gr %>}
    .si h4{font-family:'Noto Serif KR',serif;font-size:1rem;font-weight:400;color:<%= t.tx %>;margin-bottom:3px}
    .si p{font-size:12px;color:<%= t.t2 %>}
    .stag{display:inline-block;padding:5px 16px;border:1px solid <%= t.bd %>;font-size:9px;letter-spacing:.12em;color:<%= t.ac %>}

    /* ─── CTA (image background) ─── */
    .cta{position:relative;height:440px;overflow:hidden}
    .cta img{position:absolute;inset:0;transition:transform 8s ease}
    .cta:hover img{transform:scale(1.04)}
    .cta-ov{position:absolute;inset:0;background:rgba(0,0,0,.52)}
    .cta-body{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:40px}
    .cta-h{font-family:'Noto Serif KR',serif;font-size:clamp(1.6rem,3vw,2.4rem);font-weight:200;color:#fff;line-height:1.5;margin-bottom:28px}
    .cta-btn{display:inline-block;padding:14px 52px;background:#fff;color:<%= t.tx %>;font-size:13px;font-weight:500;letter-spacing:.1em;text-decoration:none;border-radius:1px;transition:.25s}
    .cta-btn:hover{background:<%= t.ac %>;color:#fff;transform:translateY(-2px)}

    /* ─── FOOTER ─── */
    footer{background:<%= t.foot %>;padding:60px 80px 44px;color:rgba(255,255,255,.4)}
    .ft{display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:40px;padding-bottom:44px;border-bottom:1px solid rgba(255,255,255,.07)}
    .fb{font-family:'Noto Serif KR',serif;font-size:1.3rem;color:<%= t.ac %>;font-weight:300;margin-bottom:8px}
    .ftg{font-size:12px;line-height:1.9;max-width:240px}
    .ftl{display:flex;flex-direction:column;gap:8px}
    .ftl a{font-size:12px;color:rgba(255,255,255,.35);text-decoration:none;letter-spacing:.04em;transition:color .2s}
    .ftl a:hover{color:<%= t.ac %>}
    .fcopy{padding-top:24px;font-size:11px;text-align:center}

    /* ─── REVEAL ─── */
    .r{opacity:0;transform:translateY(28px);transition:opacity .7s ease,transform .7s ease}
    .r.v{opacity:1;transform:translateY(0)}

    /* ─── RESPONSIVE ─── */
    @media(max-width:1024px){nav{padding:0 40px}.hero-body{padding:0 40px 72px}.fq-body{padding:40px 48px}.gallery{padding:56px 32px}.programs{padding:64px 40px}.schedule{padding:64px 40px}footer{padding:48px 40px}}
    @media(max-width:768px){.nl,.ncta{display:none}.hero{margin:0}.hero-body{padding:0 28px 56px}.about{grid-template-columns:1fr}.about-img{height:360px}.about-txt{padding:48px 32px}.panel{height:360px}.pb{padding:0 28px;max-width:100%}.pg{grid-template-columns:1fr}.gl-grid{grid-template-columns:1fr 1fr}.gl-item:first-child{grid-row:auto}.programs,.schedule,.gallery{padding:48px 24px}.sl-item{grid-template-columns:80px 1fr;gap:24px}.stag{display:none}footer{padding:40px 28px}}
  </style>
</head>
