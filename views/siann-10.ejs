%><!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>L10 대시보드패널 — 시안 <%= themeId %></title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;600;700&family=Noto+Serif+KR:wght@400;600;700&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --bg: <%= t.bg %>;
  --deep: <%= t.deep %>;
  --mid: <%= t.mid %>;
  --card: <%= t.card %>;
  --accent: <%= t.accent %>;
  --accentLt: <%= t.accentLt %>;
  --accentDk: <%= t.accentDk %>;
  --text: <%= t.text %>;
  --text2: <%= t.text2 %>;
  --gray: <%= t.gray %>;
  --footerBg: <%= t.footerBg %>;
  --border: <%= t.border %>;
}
html { font-size: 16px; }
body {
  background: var(--bg);
  color: var(--text);
  font-family: 'Noto Sans KR', sans-serif;
  min-height: 100vh;
  line-height: 1.6;
}

/* ── TOPBAR ─────────────────────────────────── */
.topbar {
  position: sticky;
  top: 0;
  z-index: 200;
  background: var(--deep);
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  gap: 0;
  height: 56px;
}
.topbar-logo {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 0 24px;
  border-right: 1px solid var(--border);
  height: 100%;
  min-width: 220px;
}
.topbar-logo .logo-mark {
  width: 32px; height: 32px;
  background: var(--accent);
  border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  font-weight: 700; font-size: 16px;
  color: var(--deep);
  flex-shrink: 0;
}
.topbar-logo .logo-name {
  font-size: 15px; font-weight: 700;
  color: var(--text);
  letter-spacing: 0.02em;
}
.breadcrumb {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 0 24px;
  flex: 1;
  font-size: 13px;
  color: var(--text2);
}
.breadcrumb span { color: var(--text2); }
.breadcrumb .bc-sep { opacity: 0.4; }
.breadcrumb .bc-cur { color: var(--accent); font-weight: 500; }
.topbar-actions {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 0 20px;
  border-left: 1px solid var(--border);
  height: 100%;
}
.tb-btn {
  padding: 6px 14px;
  border-radius: 6px;
  border: 1px solid var(--border);
  background: transparent;
  color: var(--text2);
  font-size: 13px;
  cursor: pointer;
  transition: all 0.2s;
}
.tb-btn:hover { border-color: var(--accent); color: var(--accent); }
.tb-btn.primary { background: var(--accent); border-color: var(--accent); color: var(--deep); font-weight: 600; }
.tb-btn.primary:hover { opacity: 0.85; }
.avatar {
  width: 32px; height: 32px;
  border-radius: 50%;
  background: var(--accent);
  display: flex; align-items: center; justify-content: center;
  font-size: 13px; font-weight: 700;
  color: var(--deep);
  cursor: pointer;
  flex-shrink: 0;
}

/* ── SIDEBAR ────────────────────────────────── */
.layout-shell {
  display: grid;
  grid-template-columns: 220px 1fr;
  min-height: calc(100vh - 56px);
}
.sidebar {
  background: var(--deep);
  border-right: 1px solid var(--border);
  padding: 20px 0;
  position: sticky;
  top: 56px;
  height: calc(100vh - 56px);
  overflow-y: auto;
}
.sidebar::-webkit-scrollbar { width: 4px; }
.sidebar::-webkit-scrollbar-thumb { background: var(--gray); border-radius: 4px; }

.sb-section { padding: 0 16px 16px; }
.sb-label {
  font-size: 10px; font-weight: 700; letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text2);
  padding: 4px 8px 8px;
  opacity: 0.6;
}
.sb-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px 12px;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 500;
  color: var(--text2);
  cursor: pointer;
  transition: all 0.15s;
  text-decoration: none;
}
.sb-item:hover { background: var(--gray); color: var(--text); }
.sb-item.active { background: var(--accent); color: var(--deep); font-weight: 700; }
.sb-item .sb-icon {
  width: 18px; height: 18px;
  flex-shrink: 0;
  opacity: 0.7;
  display: flex; align-items: center; justify-content: center;
  font-size: 15px;
}
.sb-item.active .sb-icon { opacity: 1; }
.sb-badge {
  margin-left: auto;
  background: var(--accent);
  color: var(--deep);
  font-size: 10px; font-weight: 700;
  padding: 2px 7px;
  border-radius: 20px;
  min-width: 20px;
  text-align: center;
}
.sb-item.active .sb-badge { background: var(--deep); color: var(--accent); }
.sb-divider {
  height: 1px;
  background: var(--border);
  margin: 8px 16px;
}

/* ── MAIN CONTENT ───────────────────────────── */
.main-content {
  padding: 28px;
  background: var(--bg);
  overflow-x: hidden;
}

/* ── PAGE HEADER ────────────────────────────── */
.page-header {
  margin-bottom: 28px;
}
.page-header h1 {
  font-family: 'Noto Serif KR', serif;
  font-size: 26px;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 6px;
}
.page-header .ph-sub {
  font-size: 14px;
  color: var(--text2);
}

/* ── STAT WIDGETS ROW ───────────────────────── */
.stats-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
  margin-bottom: 24px;
}
.stat-widget {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 20px 24px;
  position: relative;
  overflow: hidden;
  transition: transform 0.2s, box-shadow 0.2s;
}
.stat-widget:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(0,0,0,0.3);
}
.stat-widget::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: var(--accent);
}
.stat-widget.w2 { border-top-color: transparent; }
.stat-widget.w2::before { background: var(--accentLt); }
.stat-widget.w3::before { background: #52b788; }
.stat-widget.w4::before { background: #e63946; }
.sw-label {
  font-size: 12px; font-weight: 600; letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--text2);
  margin-bottom: 10px;
}
.sw-value {
  font-size: 32px; font-weight: 700;
  color: var(--text);
  font-variant-numeric: tabular-nums;
  line-height: 1;
  margin-bottom: 8px;
}
.sw-delta {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: 12px; font-weight: 600;
  padding: 3px 8px;
  border-radius: 20px;
}
.sw-delta.up { background: rgba(82,183,136,0.2); color: #52b788; }
.sw-delta.dn { background: rgba(230,57,70,0.2); color: #e63946; }
.sw-delta::before { font-size: 10px; }
.sw-delta.up::before { content: '▲ '; }
.sw-delta.dn::before { content: '▼ '; }
.sw-chart {
  position: absolute;
  bottom: 16px; right: 16px;
  display: flex;
  align-items: flex-end;
  gap: 3px;
  height: 36px;
}
.sw-bar {
  width: 6px;
  background: var(--accent);
  border-radius: 2px 2px 0 0;
  opacity: 0.4;
  transition: opacity 0.2s;
}
.sw-bar.hi { opacity: 0.9; }
.stat-widget:hover .sw-bar { opacity: 0.6; }
.stat-widget:hover .sw-bar.hi { opacity: 1; }

/* ── MAIN DASHBOARD GRID ───────────────────── */
.dash-grid {
  display: grid;
  grid-template-columns: 2fr 1fr;
  grid-template-rows: auto auto;
  gap: 20px;
  margin-bottom: 24px;
}

/* Panel base */
.panel {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 12px;
  overflow: hidden;
}
.panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 20px;
  border-bottom: 1px solid var(--border);
}
.panel-title {
  font-size: 14px; font-weight: 700;
  color: var(--text);
  display: flex; align-items: center; gap: 8px;
}
.panel-title .pt-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: var(--accent);
}
.panel-more {
  font-size: 12px; color: var(--accent);
  cursor: pointer; font-weight: 500;
  text-decoration: none;
}
.panel-more:hover { opacity: 0.7; }
.panel-body { padding: 20px; }

/* ── IMAGE BANNER ────────────────────────────── */
.img-banner {
  grid-column: 1 / -1;
  height: 200px;
  border-radius: 12px;
  overflow: hidden;
  position: relative;
}
.img-banner img {
  width: 100%; height: 100%;
  object-fit: cover;
  display: block;
}
.img-banner-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(90deg, rgba(0,0,0,0.65) 0%, transparent 60%);
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 28px 36px;
}
.img-banner-overlay h2 {
  font-family: 'Noto Serif KR', serif;
  font-size: 22px; font-weight: 700;
  color: #fff;
  margin-bottom: 8px;
}
.img-banner-overlay p {
  font-size: 14px; color: rgba(255,255,255,0.8);
  max-width: 380px;
}

/* ── ACTIVITY PANEL (left tall) ────────────── */
.activity-panel {
  grid-row: 1 / 3;
}
.act-list { display: flex; flex-direction: column; gap: 0; }
.act-item {
  display: grid;
  grid-template-columns: 40px 1fr auto;
  gap: 12px;
  align-items: start;
  padding: 14px 0;
  border-bottom: 1px solid var(--border);
}
.act-item:last-child { border-bottom: none; }
.act-avatar {
  width: 36px; height: 36px;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
}
.act-avatar img { width: 100%; height: 100%; object-fit: cover; }
.act-avatar.fallback {
  background: var(--accent);
  display: flex; align-items: center; justify-content: center;
  font-size: 14px; font-weight: 700;
  color: var(--deep);
}
.act-info {}
.act-name { font-size: 13px; font-weight: 600; color: var(--text); margin-bottom: 2px; }
.act-desc { font-size: 12px; color: var(--text2); line-height: 1.4; }
.act-time { font-size: 11px; color: var(--text2); opacity: 0.7; white-space: nowrap; }
.act-badge {
  display: inline-block;
  font-size: 10px; font-weight: 700;
  padding: 2px 8px;
  border-radius: 20px;
  margin-top: 4px;
}
.act-badge.done { background: rgba(82,183,136,0.2); color: #52b788; }
.act-badge.prog { background: rgba(88,166,255,0.2); color: var(--accentLt); }
.act-badge.wait { background: rgba(200,200,200,0.15); color: var(--text2); }
.act-badge.urg  { background: rgba(230,57,70,0.2); color: #e63946; }

/* ── TASK LIST PANEL ───────────────────────── */
.task-list { display: flex; flex-direction: column; gap: 10px; }
.task-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 10px 12px;
  border-radius: 8px;
  background: var(--mid);
  transition: background 0.15s;
  cursor: pointer;
}
.task-item:hover { background: var(--gray); }
.task-check {
  width: 18px; height: 18px;
  border: 2px solid var(--border);
  border-radius: 4px;
  flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  transition: all 0.15s;
}
.task-item.done .task-check {
  background: var(--accent);
  border-color: var(--accent);
}
.task-item.done .task-check::after {
  content: '✓';
  font-size: 11px; font-weight: 700;
  color: var(--deep);
}
.task-text {
  flex: 1;
  font-size: 13px; color: var(--text);
}
.task-item.done .task-text {
  opacity: 0.5;
  text-decoration: line-through;
}
.task-tag {
  font-size: 10px; font-weight: 700;
  padding: 2px 7px; border-radius: 20px;
}
.task-tag.ui   { background: rgba(88,166,255,0.2); color: var(--accentLt); }
.task-tag.api  { background: rgba(189,147,249,0.2); color: #bd93f9; }
.task-tag.db   { background: rgba(82,183,136,0.2); color: #52b788; }
.task-tag.bug  { background: rgba(230,57,70,0.2); color: #e63946; }
.task-tag.doc  { background: rgba(200,200,200,0.15); color: var(--text2); }

/* ── PROGRESS PANEL ────────────────────────── */
.prog-list { display: flex; flex-direction: column; gap: 14px; }
.prog-item {}
.prog-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6px;
}
.prog-name { font-size: 13px; font-weight: 600; color: var(--text); }
.prog-pct  { font-size: 12px; font-weight: 700; color: var(--accent); }
.prog-bar {
  height: 6px;
  background: var(--gray);
  border-radius: 3px;
  overflow: hidden;
}
.prog-fill {
  height: 100%;
  border-radius: 3px;
  background: var(--accent);
  transition: width 0.5s ease;
}
.prog-fill.g2 { background: var(--accentLt); }
.prog-fill.g3 { background: #52b788; }
.prog-fill.g4 { background: #e63946; }
.prog-fill.g5 { background: #ffd700; }

/* ── SECOND ROW GRID ────────────────────────── */
.dash-grid2 {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 20px;
  margin-bottom: 24px;
}

/* ── NOTICE PANEL ───────────────────────────── */
.notice-list { display: flex; flex-direction: column; gap: 0; }
.notice-item {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 12px 0;
  border-bottom: 1px solid var(--border);
}
.notice-item:last-child { border-bottom: none; }
.ni-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: 5px;
}
.ni-dot.new  { background: var(--accent); }
.ni-dot.read { background: var(--gray); }
.ni-dot.urg  { background: #e63946; }
.ni-info {}
.ni-title { font-size: 13px; color: var(--text); font-weight: 500; margin-bottom: 3px; }
.ni-time  { font-size: 11px; color: var(--text2); opacity: 0.7; }

/* ── SCHEDULE PANEL ─────────────────────────── */
.sched-list { display: flex; flex-direction: column; gap: 10px; }
.sched-item {
  display: grid;
  grid-template-columns: 60px 1fr;
  gap: 12px;
  align-items: start;
}
.sched-time {
  text-align: right;
  font-size: 12px; font-weight: 700;
  color: var(--accent);
  padding-top: 1px;
}
.sched-body {
  border-left: 3px solid var(--accent);
  padding: 4px 0 4px 12px;
}
.sched-body.s2 { border-color: var(--accentLt); }
.sched-body.s3 { border-color: #52b788; }
.sched-body.s4 { border-color: #e63946; }
.sched-title { font-size: 13px; font-weight: 600; color: var(--text); margin-bottom: 2px; }
.sched-loc   { font-size: 11px; color: var(--text2); }

/* ── TEAM PHOTO PANEL ───────────────────────── */
.team-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}
.team-card {
  border-radius: 8px;
  overflow: hidden;
  position: relative;
}
.team-card img {
  width: 100%; height: 100px;
  object-fit: cover;
  display: block;
  transition: transform 0.3s;
}
.team-card:hover img { transform: scale(1.05); }
.team-card-info {
  position: absolute; bottom: 0; left: 0; right: 0;
  background: linear-gradient(transparent, rgba(0,0,0,0.7));
  padding: 6px 10px;
}
.team-card-name {
  font-size: 12px; font-weight: 700; color: #fff;
}
.team-card-role {
  font-size: 10px; color: rgba(255,255,255,0.7);
}

/* ── WIDE BANNER ROW ────────────────────────── */
.wide-banner {
  border-radius: 12px;
  overflow: hidden;
  position: relative;
  height: 180px;
  margin-bottom: 24px;
}
.wide-banner img {
  width: 100%; height: 100%;
  object-fit: cover;
  display: block;
}
.wb-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(135deg, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.1) 100%);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28px 40px;
}
.wb-text h3 {
  font-family: 'Noto Serif KR', serif;
  font-size: 20px; font-weight: 700;
  color: #fff; margin-bottom: 8px;
}
.wb-text p { font-size: 14px; color: rgba(255,255,255,0.8); }
.wb-cta {
  padding: 12px 28px;
  border-radius: 8px;
  background: var(--accent);
  color: var(--deep);
  font-size: 14px; font-weight: 700;
  cursor: pointer;
  border: none;
  white-space: nowrap;
  transition: opacity 0.2s;
}
.wb-cta:hover { opacity: 0.85; }

/* ── METRICS GRID ───────────────────────────── */
.metrics-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
  margin-bottom: 24px;
}
.metric-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 22px;
  display: flex;
  gap: 16px;
  align-items: center;
}
.metric-icon {
  width: 50px; height: 50px;
  border-radius: 12px;
  background: var(--gray);
  display: flex; align-items: center; justify-content: center;
  font-size: 22px;
  flex-shrink: 0;
}
.metric-info {}
.metric-label { font-size: 12px; color: var(--text2); margin-bottom: 4px; font-weight: 500; }
.metric-val   { font-size: 24px; font-weight: 700; color: var(--text); font-variant-numeric: tabular-nums; }
.metric-sub   { font-size: 11px; color: var(--text2); margin-top: 3px; }

/* ── FOOTER ─────────────────────────────────── */
footer {
  background: var(--footerBg);
  border-top: 1px solid var(--border);
  padding: 32px 28px;
  display: grid;
  grid-template-columns: 2fr 1fr 1fr;
  gap: 32px;
  margin-top: 8px;
}
.ft-brand {}
.ft-logo {
  display: flex; align-items: center; gap: 10px;
  margin-bottom: 12px;
}
.ft-logo-mark {
  width: 28px; height: 28px;
  background: var(--accent);
  border-radius: 6px;
  display: flex; align-items: center; justify-content: center;
  font-weight: 700; font-size: 13px;
  color: var(--deep);
}
.ft-logo-name { font-size: 15px; font-weight: 700; color: var(--text); }
.ft-brand p { font-size: 13px; color: var(--text2); line-height: 1.7; max-width: 260px; }
.ft-col h4 { font-size: 13px; font-weight: 700; color: var(--text); margin-bottom: 12px; }
.ft-col ul { list-style: none; }
.ft-col ul li { margin-bottom: 8px; }
.ft-col ul li a {
  font-size: 13px; color: var(--text2);
  text-decoration: none;
  transition: color 0.15s;
}
.ft-col ul li a:hover { color: var(--accent); }
.ft-bottom {
  background: var(--footerBg);
  border-top: 1px solid var(--border);
  padding: 16px 28px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 12px;
  color: var(--text2);
}
.ft-bottom a { color: var(--accent); text-decoration: none; }

/* ── SIANN BADGE ───────────────────────────── */
.siann-badge {
  position: fixed;
  bottom: 24px; right: 24px;
  z-index: 9000;
  background: var(--card);
  border: 2px solid var(--accent);
  border-radius: 14px;
  padding: 10px 14px;
  display: flex; flex-direction: column; align-items: center;
  box-shadow: 0 8px 28px rgba(0,0,0,0.5);
  min-width: 200px;
}
.siann-badge-title {
  font-size: 10px; font-weight: 700; letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 6px;
}
.siann-badge-grid {
  display: flex; flex-wrap: wrap; gap: 4px;
  justify-content: center;
}
.siann-badge-grid a {
  width: 22px; height: 22px;
  border-radius: 5px;
  background: var(--gray);
  display: flex; align-items: center; justify-content: center;
  font-size: 10px; font-weight: 700;
  color: var(--text2);
  text-decoration: none;
  transition: all 0.15s;
}
.siann-badge-grid a:hover { background: var(--accent); color: var(--deep); }
.siann-badge-grid a.cur { background: var(--accent); color: var(--deep); }

/* ── RESPONSIVE ─────────────────────────────── */
@media (max-width: 1100px) {
  .stats-row { grid-template-columns: repeat(2, 1fr); }
  .dash-grid { grid-template-columns: 1fr; }
  .activity-panel { grid-row: auto; }
  .dash-grid2 { grid-template-columns: 1fr 1fr; }
  .metrics-grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 768px) {
  .layout-shell { grid-template-columns: 1fr; }
  .sidebar { display: none; }
  .topbar-logo { min-width: auto; }
  .breadcrumb { display: none; }
  .stats-row { grid-template-columns: 1fr 1fr; }
  .dash-grid2 { grid-template-columns: 1fr; }
  .metrics-grid { grid-template-columns: 1fr; }
  footer { grid-template-columns: 1fr; }
  .wide-banner { height: 140px; }
  .wb-overlay { flex-direction: column; align-items: flex-start; gap: 12px; }
}
</style>
</head>
<body>

<!-- TOP BAR -->
