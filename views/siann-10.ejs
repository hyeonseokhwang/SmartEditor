        <div class="sw-chart">
          <div class="sw-bar" style="height:50%"></div>
          <div class="sw-bar" style="height:65%"></div>
          <div class="sw-bar" style="height:55%"></div>
          <div class="sw-bar" style="height:75%"></div>
          <div class="sw-bar" style="height:70%"></div>
          <div class="sw-bar" style="height:80%"></div>
          <div class="sw-bar hi" style="height:90%"></div>
        </div>
      </div>
      <div class="stat-widget w3">
        <div class="sw-label">공간 가동률</div>
        <div class="sw-value">83%</div>
        <div class="sw-delta up">3.2%</div>
        <div class="sw-chart">
          <div class="sw-bar" style="height:60%"></div>
          <div class="sw-bar" style="height:70%"></div>
          <div class="sw-bar" style="height:80%"></div>
          <div class="sw-bar" style="height:75%"></div>
          <div class="sw-bar" style="height:85%"></div>
          <div class="sw-bar hi" style="height:90%"></div>
