              <div class="act-info">
                <div class="act-name">운영팀</div>
                <div class="act-desc">B홀 정기 점검 완료 · 에어컨 필터 교체</div>
                <span class="act-badge done">완료</span>
              </div>
              <div class="act-time">34분 전</div>
            </div>
            <div class="act-item">
              <div class="act-avatar fallback" style="background:#e63946">이</div>
              <div class="act-info">
                <div class="act-name">이수아 수강생</div>
