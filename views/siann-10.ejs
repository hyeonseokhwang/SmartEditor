        <span class="sb-icon">◼</span> 대시보드
      </a>
      <a class="sb-item" href="#">
        <span class="sb-icon">◈</span> 프로젝트
        <span class="sb-badge">4</span>
      </a>
      <a class="sb-item" href="#">
        <span class="sb-icon">◉</span> 일정
      </a>
      <a class="sb-item" href="#">
        <span class="sb-icon">◷</span> 리포트
        <span class="sb-badge">2</span>
      </a>
    </div>
    <div class="sb-divider"></div>
    <div class="sb-section">
      <div class="sb-label">서비스</div>
      <a class="sb-item" href="#">
        <span class="sb-icon">◈</span> 강좌 관리
      </a>
      <a class="sb-item" href="#">
        <span class="sb-icon">◐</span> 수강생 현황
      </a>
      <a class="sb-item" href="#">
        <span class="sb-icon">◑</span> 공간 예약
