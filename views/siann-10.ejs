          <div class="sw-bar" style="height:30%"></div>
          <div class="sw-bar" style="height:20%"></div>
          <div class="sw-bar" style="height:50%"></div>
          <div class="sw-bar" style="height:35%"></div>
          <div class="sw-bar" style="height:60%"></div>
          <div class="sw-bar" style="height:45%"></div>
          <div class="sw-bar hi" style="height:70%"></div>
        </div>
      </div>
    </div>

    <!-- IMAGE BANNER (uses img 0) -->
    <div class="img-banner" style="margin-bottom:24px;">
      <img src="<%= imgs[0] %>" alt="센터 전경">
      <div class="img-banner-overlay">
        <h2>2026 봄 학기 집중 프로그램</h2>
