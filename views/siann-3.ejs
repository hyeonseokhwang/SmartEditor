<script>
  const right = document.getElementById('splitRight');
  const dots = document.querySelectorAll('.nav-dot');
  const panels = ['panel-hero','panel-about','panel-teachings','panel-quotes','panel-center','panel-archive'];

  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => {
      document.getElementById(panels[i])?.scrollIntoView({ behavior: 'smooth' });
    });
  });

  right.addEventListener('scroll', () => {
    const scrollTop = right.scrollTop;
    let active = 0;
    panels.forEach((id, i) => {
      const el = document.getElementById(id);
      if (el && el.offsetTop - 100 <= scrollTop) active = i;
    });
    dots.forEach((d, i) => d.classList.toggle('active', i === active));
  }, { passive: true });
</script>
