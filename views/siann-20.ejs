%><!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>여의명상센터 — 한울사랑</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@300;400;500&family=Noto+Sans+KR:wght@200;300;400&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg: <%- t.bg %>;
  --txt: <%- t.txt %>;
  --acc: <%- t.acc %>;
  --line: <%- t.line %>;
  --hero-ov: <%- t.hero %>;
  --nav-bg: <%- t.nav %>;
  --txt-faint: color-mix(in srgb, var(--txt) 42%, transparent);
}
html{scroll-behavior:smooth;font-size:16px}
body{background:var(--bg);color:var(--txt);font-family:'Noto Serif KR',serif;line-height:1.8;overflow-x:hidden}

/* ── BADGE ── */
.badge{position:fixed;top:14px;right:18px;z-index:9999;background:var(--acc);color:#fff;font-size:10px;font-family:'Noto Sans KR',sans-serif;font-weight:300;padding:4px 10px;border-radius:20px;letter-spacing:.06em;opacity:.8}

/* ── NAV ── */
nav{position:fixed;top:0;left:0;width:100%;z-index:1000;padding:32px 72px;display:flex;align-items:center;justify-content:space-between;transition:all .5s}
nav.scrolled{background:var(--nav-bg);padding:18px 72px;border-bottom:1px solid var(--line);box-shadow:0 1px 20px rgba(0,0,0,.04)}
.nav-logo{font-size:17px;font-weight:400;letter-spacing:.1em;color:#fff;text-decoration:none;transition:color .4s}
nav.scrolled .nav-logo{color:var(--txt)}
.nav-cta{font-size:11px;font-family:'Noto Sans KR',sans-serif;font-weight:300;color:rgba(255,255,255,.7);letter-spacing:.18em;text-decoration:none;border-bottom:1px solid rgba(255,255,255,.3);padding-bottom:2px;transition:all .4s}
nav.scrolled .nav-cta{color:var(--acc);border-color:var(--acc)}

/* ── HERO ── */
#hero{width:100vw;height:100vh;position:relative;display:flex;align-items:center;justify-content:center;overflow:hidden}
.hero-bg{position:absolute;inset:0;background:url('<%- imgs.hero %>') center/cover no-repeat;transform:scale(1.08);animation:heroZoom 12s ease-out forwards}
@keyframes heroZoom{to{transform:scale(1)}}
.hero-ov{position:absolute;inset:0;background:var(--hero-ov)}
.hero-inner{position:relative;z-index:2;text-align:center;padding:0 24px}
.hero-eng{font-size:11px;font-family:'Noto Sans KR',sans-serif;font-weight:200;color:rgba(255,255,255,.5);letter-spacing:.4em;text-transform:uppercase;margin-bottom:32px;opacity:0;animation:fadeUp .8s 1s forwards}
.hero-ko{font-size:clamp(48px,8vw,90px);font-weight:300;color:#fff;letter-spacing:.1em;line-height:1.1;margin-bottom:24px;opacity:0;animation:fadeUp .9s 1.3s forwards}
.hero-rule{width:1px;height:48px;background:rgba(255,255,255,.35);margin:0 auto 20px;opacity:0;animation:fadeIn .6s 2s forwards}
.hero-tagline{font-size:14px;font-family:'Noto Sans KR',sans-serif;font-weight:200;color:rgba(255,255,255,.55);letter-spacing:.14em;opacity:0;animation:fadeUp .8s 2.3s forwards}
@keyframes fadeUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
.hero-indicator{position:absolute;bottom:36px;left:50%;transform:translateX(-50%);z-index:2;display:flex;flex-direction:column;align-items:center;gap:6px;cursor:pointer}
.hi-text{font-size:10px;font-family:'Noto Sans KR',sans-serif;font-weight:200;color:rgba(255,255,255,.4);letter-spacing:.2em}
.hi-line{width:1px;height:40px;background:linear-gradient(to bottom,rgba(255,255,255,.45),transparent);animation:pulse 2.5s ease-in-out infinite}
@keyframes pulse{0%,100%{opacity:.3}60%{opacity:1}}

/* ── OPENING — 첫 법문 (Dhamma 스타일) ── */
.opening{padding:120px 24px;text-align:center;background:var(--bg)}
.opening-rule{width:56px;height:1px;background:var(--acc);margin:0 auto 56px;opacity:.7}
.opening-ko{font-size:clamp(20px,3vw,30px);font-weight:300;color:var(--txt);letter-spacing:.05em;line-height:2;max-width:600px;margin:0 auto 48px}
.opening-src{font-size:11px;font-family:'Noto Sans KR',sans-serif;font-weight:200;color:var(--txt);opacity:.38;letter-spacing:.2em}

/* ── FULL-WIDTH IMAGE STRIP ── */
.img-strip{width:100%;height:80vh;overflow:hidden;position:relative}
.strip-img{width:100%;height:100%;object-fit:cover;display:block;transform:scale(1.04);transition:transform 8s ease}
.img-strip.in-view .strip-img{transform:scale(1)}
.strip-caption{position:absolute;bottom:0;left:0;right:0;padding:40px 72px;background:linear-gradient(to top,rgba(0,0,0,.45) 0%,transparent 100%)}
.strip-word{font-size:clamp(32px,5vw,56px);font-weight:300;color:#fff;letter-spacing:.1em;display:block;line-height:1}
.strip-sub{font-size:13px;font-family:'Noto Sans KR',sans-serif;font-weight:200;color:rgba(255,255,255,.6);letter-spacing:.08em;margin-top:8px;display:block}

/* ── WISDOM — 이미지+텍스트 교차 (Brahmakumaris 스타일) ── */
.wisdom{padding:0}
.wisdom-row{display:grid;grid-template-columns:1fr 1fr;min-height:560px}
.wisdom-row.flip{direction:rtl}
.wisdom-row.flip > *{direction:ltr}
.wisdom-img{overflow:hidden;position:relative}
.wisdom-img img{width:100%;height:100%;object-fit:cover;display:block;transition:transform 1s ease}
.wisdom-img:hover img{transform:scale(1.04)}
.wisdom-text{display:flex;flex-direction:column;justify-content:center;padding:80px 96px;background:var(--bg)}
.wisdom-num{font-size:10px;font-family:'Noto Sans KR',sans-serif;font-weight:200;color:var(--acc);letter-spacing:.35em;margin-bottom:28px;opacity:.8}
.wisdom-title{font-size:clamp(24px,3vw,36px);font-weight:300;color:var(--txt);letter-spacing:.06em;line-height:1.4;margin-bottom:24px}
.wisdom-rule{width:28px;height:1px;background:var(--acc);margin-bottom:24px;opacity:.6}
.wisdom-body{font-size:14px;font-family:'Noto Sans KR',sans-serif;font-weight:300;color:var(--txt);opacity:.58;line-height:1.95;max-width:320px}

/* ── QUOTE FULL ── */
.quote-full{width:100%;height:100vh;position:relative;display:flex;align-items:center;justify-content:center;overflow:hidden}
.qf-bg{position:absolute;inset:0;background-size:cover;background-position:center;background-attachment:fixed}
.qf-ov{position:absolute;inset:0;background:rgba(6,4,2,.48)}
.qf-inner{position:relative;z-index:2;max-width:720px;padding:0 48px;text-align:center}
.qf-open{display:block;font-size:80px;line-height:.5;color:var(--acc);opacity:.5;margin-bottom:40px;font-family:Georgia,serif}
.qf-text{font-size:clamp(22px,3.2vw,36px);font-weight:300;color:#fff;letter-spacing:.04em;line-height:1.85;margin-bottom:36px}
.qf-rule{width:32px;height:1px;background:rgba(255,255,255,.35);margin:0 auto 24px}
.qf-src{font-size:12px;font-family:'Noto Sans KR',sans-serif;font-weight:200;color:rgba(255,255,255,.4);letter-spacing:.22em}

/* ── GALLERY — 산포 배치 ── */
.gallery-space{padding:96px 56px;background:var(--bg)}
.gallery-header{text-align:center;margin-bottom:72px}
.gh-label{font-size:10px;font-family:'Noto Sans KR',sans-serif;font-weight:200;color:var(--acc);letter-spacing:.3em;text-transform:uppercase;display:block;margin-bottom:16px;opacity:.8}
.gh-title{font-size:clamp(20px,2.5vw,28px);font-weight:300;color:var(--txt);letter-spacing:.08em}
.gallery-mosaic{display:grid;grid-template-columns:3fr 2fr 2fr;grid-template-rows:300px 300px;gap:4px}
.gm-item{overflow:hidden;position:relative}
.gm-item:nth-child(1){grid-row:span 2}
.gm-img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .8s ease,filter .5s}
.gm-item:hover .gm-img{transform:scale(1.05);filter:brightness(.95)}

/* ── PROGRAMS — 텍스트 리스트 (Dhamma 스타일) ── */
.prog-list{padding:100px 72px;background:var(--bg)}
.pl-header{margin-bottom:64px}
.pl-label{font-size:10px;font-family:'Noto Sans KR',sans-serif;font-weight:200;color:var(--acc);letter-spacing:.3em;text-transform:uppercase;display:block;margin-bottom:18px;opacity:.8}
.pl-title{font-size:clamp(26px,3.5vw,42px);font-weight:300;color:var(--txt);letter-spacing:.06em}
.pl-items{list-style:none;display:grid;grid-template-columns:1fr 1fr;gap:0}
.pl-item{padding:32px 0;border-bottom:1px solid var(--line);display:flex;align-items:baseline;justify-content:space-between;gap:24px;transition:background .3s}
.pl-item:hover{padding-left:8px}
.pl-name{font-size:clamp(16px,2vw,22px);font-weight:300;color:var(--txt);letter-spacing:.06em}
.pl-freq{font-size:12px;font-family:'Noto Sans KR',sans-serif;font-weight:200;color:var(--txt);opacity:.38;letter-spacing:.1em;white-space:nowrap}
.pl-item:nth-child(odd){padding-right:48px}
.pl-item:nth-child(even){padding-left:48px}

/* ── CLOSING IMAGE ── */
.closing{width:100%;height:70vh;overflow:hidden;position:relative;display:flex;align-items:center;justify-content:center}
.closing-bg{position:absolute;inset:0;background-size:cover;background-position:center}
.closing-ov{position:absolute;inset:0;background:rgba(4,3,2,.42)}
.closing-text{position:relative;z-index:2;text-align:center;padding:0 48px}
.ct-ko{font-size:clamp(20px,3vw,32px);font-weight:300;color:#fff;letter-spacing:.06em;line-height:1.8;margin-bottom:40px}
.ct-btn{display:inline-block;padding:13px 44px;border:1px solid rgba(255,255,255,.45);color:#fff;text-decoration:none;font-size:12px;font-family:'Noto Sans KR',sans-serif;font-weight:200;letter-spacing:.2em;transition:all .4s}
.ct-btn:hover{background:rgba(255,255,255,.1);border-color:#fff;letter-spacing:.28em}

/* ── FOOTER ── */
footer{background:#0e0c08;padding:72px 72px 40px;color:rgba(255,255,255,.35)}
.ft-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:56px;padding-bottom:48px;border-bottom:1px solid rgba(255,255,255,.06)}
.ft-brand{font-size:20px;font-weight:300;color:rgba(255,255,255,.7);letter-spacing:.1em;display:block;margin-bottom:12px}
.ft-desc{font-size:13px;font-family:'Noto Sans KR',sans-serif;font-weight:200;line-height:1.8;max-width:260px}
.ft-nav{display:flex;gap:56px}
.ft-nav-group{display:flex;flex-direction:column;gap:10px}
.ft-nav-label{font-size:10px;font-family:'Noto Sans KR',sans-serif;font-weight:300;color:rgba(255,255,255,.4);letter-spacing:.22em;text-transform:uppercase;margin-bottom:4px}
.ft-nav-item{font-size:13px;font-family:'Noto Sans KR',sans-serif;font-weight:200;color:rgba(255,255,255,.28)}
.ft-bottom{display:flex;justify-content:space-between;align-items:center}
.ft-copy{font-size:11px;font-family:'Noto Sans KR',sans-serif;font-weight:200;letter-spacing:.04em}
.ft-badge{font-size:10px;font-family:'Noto Sans KR',sans-serif;background:var(--acc);color:#fff;padding:3px 10px;border-radius:20px;opacity:.65;letter-spacing:.05em}

/* ── THEME BAR ── */
.theme-bar{position:fixed;bottom:20px;left:50%;transform:translateX(-50%);z-index:9000;display:flex;gap:7px;background:rgba(10,8,5,.7);padding:10px 16px;border-radius:40px;backdrop-filter:blur(12px)}
.t-dot{width:18px;height:18px;border-radius:50%;cursor:pointer;border:2px solid transparent;transition:transform .2s,border-color .2s;flex-shrink:0;position:relative}
.t-dot:hover{transform:scale(1.3)}
.t-dot.active{border-color:#fff;transform:scale(1.15)}
.t-tip{position:absolute;bottom:calc(100% + 7px);left:50%;transform:translateX(-50%);background:rgba(0,0,0,.85);color:#fff;font-size:10px;white-space:nowrap;padding:3px 7px;border-radius:3px;pointer-events:none;opacity:0;transition:opacity .2s;font-family:'Noto Sans KR',sans-serif}
.t-dot:hover .t-tip{opacity:1}

/* ── REVEAL ── */
.rv{opacity:0;transform:translateY(24px);transition:opacity .9s ease,transform .9s ease}
.rv.vis{opacity:1;transform:none}
.rv-l{opacity:0;transform:translateX(-24px);transition:opacity .9s ease,transform .9s ease}
.rv-l.vis{opacity:1;transform:none}
.rv-r{opacity:0;transform:translateX(24px);transition:opacity .9s ease,transform .9s ease}
.rv-r.vis{opacity:1;transform:none}
.rv-slow{opacity:0;transition:opacity 1.4s ease}
.rv-slow.vis{opacity:1}

/* ── RESPONSIVE ── */
@media(max-width:1024px){
  .wisdom-text{padding:60px 56px}
  .prog-list{padding:80px 40px}
  nav{padding:24px 40px}
  nav.scrolled{padding:14px 40px}
  .ft-top{flex-direction:column;gap:40px}
  .ft-nav{flex-wrap:wrap;gap:32px}
}
@media(max-width:768px){
  .wisdom-row,.wisdom-row.flip{grid-template-columns:1fr;direction:ltr}
  .wisdom-img{height:320px}
  .pl-items{grid-template-columns:1fr}
  .pl-item:nth-child(odd){padding-right:0}
  .pl-item:nth-child(even){padding-left:0}
  .gallery-mosaic{grid-template-columns:1fr 1fr;grid-template-rows:repeat(3,240px)}
  .gm-item:nth-child(1){grid-row:span 1}
  nav{padding:18px 24px}
  .hero-ko{font-size:clamp(36px,12vw,60px)}
  .strip-caption{padding:28px 32px}
}
</style>
</head>
<body>

<div class="badge">B팀 지안 · siann-20</div>

<!-- NAV -->
<nav id="nav">
  <a href="#" class="nav-logo">여의명상센터</a>
  <a href="#closing" class="nav-cta">참여 안내</a>
</nav>

<!-- HERO -->
<section id="hero">
  <div class="hero-bg"></div>
  <div class="hero-ov"></div>
  <div class="hero-inner">
    <span class="hero-eng">Yeouido Meditation Center</span>
    <h1 class="hero-ko">여의명상센터</h1>
    <div class="hero-rule"></div>
    <p class="hero-tagline">한울 사상 · 내면의 빛</p>
  </div>
  <div class="hero-indicator" onclick="document.querySelector('.opening').scrollIntoView({behavior:'smooth'})">
    <span class="hi-text">아래로</span>
    <div class="hi-line"></div>
  </div>
</section>

<!-- OPENING — 법문 -->
<section class="opening rv">
  <div class="opening-rule"></div>
  <p class="opening-ko">하늘의 이치대로 살아가는 것,<br>그것이 한울 사상의 출발입니다</p>
  <span class="opening-src">— 한울사랑 법문</span>
</section>

<!-- FULL-WIDTH STRIP 1 -->
<div class="img-strip" id="strip1">
  <img class="strip-img" src="<%- imgs.w1 %>" alt="수련">
  <div class="strip-caption">
    <span class="strip-word">수련</span>
    <span class="strip-sub">몸과 마음을 함께 닦는 시간</span>
  </div>
</div>

<!-- WISDOM 1 — 이미지 왼쪽 -->
<div class="wisdom">
  <div class="wisdom-row rv-l">
    <div class="wisdom-img">
      <img src="<%- imgs.med1 %>" alt="명상">
    </div>
    <div class="wisdom-text">
      <span class="wisdom-num">01 · 명상</span>
      <h2 class="wisdom-title">고요히 앉아<br>본성을 만나다</h2>
      <div class="wisdom-rule"></div>
      <p class="wisdom-body">여의명상센터에서는 매주 정기 명상 수련을 진행합니다. 한울 사상에 기반한 명상법으로 내면의 깊은 고요를 경험하세요.</p>
    </div>
  </div>

  <!-- WISDOM 2 — 이미지 오른쪽 -->
  <div class="wisdom-row flip rv-r">
    <div class="wisdom-img">
      <img src="<%- imgs.outing1 %>" alt="자연수련">
    </div>
    <div class="wisdom-text">
      <span class="wisdom-num">02 · 자연</span>
      <h2 class="wisdom-title">자연 속에서<br>길을 찾다</h2>
      <div class="wisdom-rule"></div>
      <p class="wisdom-body">전등사, 사찰 순례와 자연 탐방을 통해 한울 사상이 말하는 천지와 하나 되는 경험을 직접 체험합니다.</p>
    </div>
  </div>
</div>

<!-- FULL-WIDTH STRIP 2 -->
<div class="img-strip" id="strip2">
  <img class="strip-img" src="<%- imgs.nature1 %>" alt="자연">
  <div class="strip-caption">
    <span class="strip-word">자연</span>
    <span class="strip-sub">하늘과 땅 사이, 있는 그대로</span>
  </div>
</div>

<!-- WISDOM 3 -->
<div class="wisdom">
  <div class="wisdom-row rv-l">
    <div class="wisdom-img">
      <img src="<%- imgs.retreat %>" alt="집중수련">
    </div>
    <div class="wisdom-text">
      <span class="wisdom-num">03 · 집중수련</span>
      <h2 class="wisdom-title">일상을 멈추고<br>깊이 들어가다</h2>
      <div class="wisdom-rule"></div>
      <p class="wisdom-body">연 2회 진행되는 집중수련은 3박4일 동안 일상을 완전히 내려놓고 수련에만 집중하는 시간입니다.</p>
    </div>
  </div>
</div>

<!-- QUOTE FULLSCREEN -->
<section class="quote-full rv-slow">
  <div class="qf-bg" style="background-image:url('<%- imgs.w2 %>')"></div>
  <div class="qf-ov"></div>
  <div class="qf-inner">
    <span class="qf-open">"</span>
    <p class="qf-text">마음이 고요해질 때<br>비로소 하늘의 소리가 들린다</p>
    <div class="qf-rule"></div>
    <span class="qf-src">한울사상 법문 중</span>
  </div>
</section>

<!-- GALLERY -->
<section class="gallery-space">
  <div class="gallery-header rv">
    <span class="gh-label">Gallery</span>
    <h2 class="gh-title">수련의 기억</h2>
  </div>
  <div class="gallery-mosaic rv">
    <div class="gm-item"><img class="gm-img" src="<%- imgs.med2 %>" alt="명상"></div>
    <div class="gm-item"><img class="gm-img" src="<%- imgs.outing2 %>" alt="소풍"></div>
    <div class="gm-item"><img class="gm-img" src="<%- imgs.collect %>" alt="자연"></div>
    <div class="gm-item"><img class="gm-img" src="<%- imgs.daily %>" alt="일상"></div>
    <div class="gm-item"><img class="gm-img" src="<%- imgs.w1 %>" alt="수련"></div>
  </div>
</section>

<!-- PROGRAMS — 텍스트 리스트 -->
<section class="prog-list">
  <div class="pl-header rv">
    <span class="pl-label">Programs</span>
    <h2 class="pl-title">수련 안내</h2>
  </div>
  <ul class="pl-items rv">
    <li class="pl-item"><span class="pl-name">정기 명상수련</span><span class="pl-freq">매주 토요일</span></li>
    <li class="pl-item"><span class="pl-name">법문 강독</span><span class="pl-freq">월 2회</span></li>
    <li class="pl-item"><span class="pl-name">좌통수련</span><span class="pl-freq">1박2일 · 월 1회</span></li>
    <li class="pl-item"><span class="pl-name">자연 탐방</span><span class="pl-freq">계절별 진행</span></li>
    <li class="pl-item"><span class="pl-name">집중수련</span><span class="pl-freq">연 2회 · 3박4일</span></li>
    <li class="pl-item"><span class="pl-name">공동체 모임</span><span class="pl-freq">수시</span></li>
  </ul>
</section>

<!-- CLOSING IMAGE -->
<section class="closing" id="closing">
  <div class="closing-bg" style="background-image:url('<%- imgs.outing2 %>')"></div>
  <div class="closing-ov"></div>
  <div class="closing-text rv">
    <p class="ct-ko">문은 언제나 열려 있습니다</p>
    <a href="#" class="ct-btn">참여 문의하기</a>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <div class="ft-top">
    <div>
      <span class="ft-brand">여의명상센터</span>
      <p class="ft-desc">한울 사상을 바탕으로 수련과 명상을 통해 내면의 평화를 찾는 곳입니다.</p>
    </div>
    <div class="ft-nav">
      <div class="ft-nav-group">
        <span class="ft-nav-label">수련</span>
        <span class="ft-nav-item">정기 명상</span>
        <span class="ft-nav-item">집중수련</span>
        <span class="ft-nav-item">자연 탐방</span>
      </div>
      <div class="ft-nav-group">
        <span class="ft-nav-label">안내</span>
        <span class="ft-nav-item">센터 소개</span>
        <span class="ft-nav-item">오시는 길</span>
        <span class="ft-nav-item">후원</span>
      </div>
    </div>
  </div>
  <div class="ft-bottom">
    <span class="ft-copy">© 2026 여의명상센터 · 한울사랑</span>
    <span class="ft-badge">B팀 지안 siann-20</span>
  </div>
</footer>

<!-- THEME BAR -->
<div class="theme-bar" id="tbar"></div>

<script>
(function(){
  /* nav scroll */
  const nav = document.getElementById('nav');
  window.addEventListener('scroll', () => nav.classList.toggle('scrolled', scrollY > 60), {passive:true});

  /* strip zoom on enter */
  const strips = document.querySelectorAll('.img-strip');
  const stripObs = new IntersectionObserver(es => es.forEach(e => { if(e.isIntersecting) e.target.classList.add('in-view'); }), {threshold:.1});
  strips.forEach(s => stripObs.observe(s));

  /* reveal */
  const rv = new IntersectionObserver(es => es.forEach(e => { if(e.isIntersecting){e.target.classList.add('vis'); rv.unobserve(e.target);} }), {threshold:.1});
  document.querySelectorAll('.rv,.rv-l,.rv-r,.rv-slow').forEach(el => rv.observe(el));

  /* theme bar */
  const themes = <%- JSON.stringify(themes.map((t,i)=>({name:t.name,acc:t.acc,i}))) %>;
  const bar = document.getElementById('tbar');
  const cur = <%- themeId % themes.length %>;
  themes.forEach(({name,acc,i}) => {
    const d = document.createElement('div');
    d.className='t-dot'+(i===cur?' active':'');
    d.style.background = acc;
    const tip = document.createElement('span');
    tip.className='t-tip'; tip.textContent=name;
    d.appendChild(tip);
    d.onclick = () => { window.location.href='/siann-20/'+i; };
    bar.appendChild(d);
  });
})();
</script>
</body>
</html>
