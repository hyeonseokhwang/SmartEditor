<!-- THEME SWITCHER -->
<div class="theme-bar" id="theme-bar"></div>

<script>
(function(){
  /* ── 히어로 이미지 로드 ── */
  const heroImg = document.getElementById('hero-img');
  const img = new Image();
  img.onload = () => { heroImg.style.backgroundImage = "url('<%- imgs.hero %>')"; heroImg.classList.add('loaded'); };
  img.src = '<%- imgs.hero %>';

  /* ── Nav scroll ── */
  const nav = document.getElementById('main-nav');
  window.addEventListener('scroll', () => {
    nav.classList.toggle('scrolled', window.scrollY > 60);
  }, {passive:true});

  /* ── Reveal on scroll ── */
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => { if(e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } });
  }, {threshold:0.12});
  document.querySelectorAll('.reveal,.reveal-left,.reveal-right').forEach(el => observer.observe(el));

  /* ── Theme switcher ── */
  const themes = <%- JSON.stringify(themes.map((t,i)=>({name:t.name,acc:t.acc,i}))) %>;
  const bar = document.getElementById('theme-bar');
  const cur = <%- themeId % themes.length %>;
  themes.forEach(({name,acc,i}) => {
    const wrap = document.createElement('div');
    wrap.className='theme-dot-wrap';
    const dot = document.createElement('div');
    dot.className='theme-dot'+(i===cur?' active':'');
    dot.style.background=acc;
    dot.title=name;
    dot.onclick=()=>{ window.location.href='/siann-19/'+i; };
    const tip=document.createElement('span');
    tip.className='theme-dot-tip';
    tip.textContent=name;
    wrap.appendChild(dot);wrap.appendChild(tip);bar.appendChild(wrap);
  });
})();
</script>
