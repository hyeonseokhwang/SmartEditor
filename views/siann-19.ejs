%><!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>여의명상센터 — 한울사랑</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@300;400;500;600&family=Noto+Sans+KR:wght@300;400;500&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg: <%- t.bg %>;
  --txt: <%- t.txt %>;
  --acc: <%- t.acc %>;
  --acc2: <%- t.acc2 %>;
  --hero-ov: <%- t.hero %>;
  --nav-bg: <%- t.nav %>;
}
html{scroll-behavior:smooth;font-size:16px}
body{background:var(--bg);color:var(--txt);font-family:'Noto Serif KR',serif;line-height:1.8;overflow-x:hidden}

/* ── BADGE ── */
.badge{position:fixed;top:14px;right:18px;z-index:9999;background:var(--acc);color:#fff;font-size:11px;font-family:'Noto Sans KR',sans-serif;padding:4px 10px;border-radius:20px;letter-spacing:.05em;opacity:.85}

/* ── NAV ── */
nav{position:fixed;top:0;left:0;width:100%;z-index:1000;padding:20px 56px;display:flex;align-items:center;justify-content:space-between;transition:background .4s,padding .3s}
nav.scrolled{background:var(--nav-bg);padding:14px 56px;backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);border-bottom:1px solid rgba(0,0,0,.06);box-shadow:0 1px 12px rgba(0,0,0,.08)}
.nav-logo{font-size:18px;font-weight:500;letter-spacing:.06em;color:#fff;text-decoration:none;transition:color .3s}
nav.scrolled .nav-logo{color:var(--txt)}
.nav-links{display:flex;gap:36px;list-style:none}
.nav-links a{font-size:13px;font-family:'Noto Sans KR',sans-serif;font-weight:300;color:rgba(255,255,255,.85);text-decoration:none;letter-spacing:.04em;transition:color .3s}
nav.scrolled .nav-links a{color:var(--txt)}
.nav-links a:hover{color:var(--acc2) !important}

/* ── HERO ── */
#hero{width:100vw;height:100vh;position:relative;display:flex;align-items:center;justify-content:center;overflow:hidden}
.hero-img{position:absolute;inset:0;background:url('<%- imgs.hero %>') center/cover no-repeat;transform:scale(1.05);transition:transform 8s ease-out}
.hero-img.loaded{transform:scale(1)}
.hero-overlay{position:absolute;inset:0;background:var(--hero-ov)}
.hero-content{position:relative;z-index:2;text-align:center;padding:0 24px}
.hero-en{font-size:13px;font-family:'Noto Sans KR',sans-serif;font-weight:300;color:rgba(255,255,255,.65);letter-spacing:.35em;text-transform:uppercase;margin-bottom:22px}
.hero-title{font-size:clamp(42px,7vw,80px);font-weight:300;color:#fff;letter-spacing:.08em;line-height:1.25;margin-bottom:18px}
.hero-line{width:48px;height:1px;background:rgba(255,255,255,.5);margin:0 auto 22px}
.hero-sub{font-size:clamp(14px,1.6vw,18px);font-weight:300;color:rgba(255,255,255,.78);letter-spacing:.12em}
.hero-scroll{position:absolute;bottom:40px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:8px;z-index:2;cursor:pointer}
.hero-scroll span{font-size:11px;font-family:'Noto Sans KR',sans-serif;color:rgba(255,255,255,.5);letter-spacing:.15em;text-transform:uppercase}
.scroll-dot{width:1px;height:48px;background:linear-gradient(to bottom,rgba(255,255,255,.5),transparent);animation:scrollDot 2s ease-in-out infinite}
@keyframes scrollDot{0%,100%{opacity:.4;transform:scaleY(1)}50%{opacity:1;transform:scaleY(1.2)}}

/* ── MANIFESTO ── */
.manifesto{background:#1a1510;padding:88px 24px;text-align:center}
.manifesto-ko{font-size:clamp(18px,2.8vw,32px);font-weight:300;color:rgba(255,255,255,.92);letter-spacing:.06em;line-height:1.9;margin-bottom:16px}
.manifesto-divider{width:32px;height:1px;background:var(--acc2);margin:0 auto}

/* ── IMAGE PANELS — 4개 풀폭 이미지 패널 ── */
.panels{display:grid;grid-template-columns:1fr 1fr;grid-template-rows:520px 520px}
.panel{position:relative;overflow:hidden;cursor:default}
.panel-img{position:absolute;inset:0;background-size:cover;background-position:center;transition:transform .8s ease}
.panel:hover .panel-img{transform:scale(1.04)}
.panel-dark{position:absolute;inset:0;background:rgba(0,0,0,.32);transition:background .4s}
.panel:hover .panel-dark{background:rgba(0,0,0,.18)}
.panel-label{position:absolute;bottom:40px;left:40px;z-index:2}
.panel-word{font-size:clamp(28px,4vw,52px);font-weight:300;color:#fff;letter-spacing:.08em;display:block;line-height:1}
.panel-desc{font-size:13px;font-family:'Noto Sans KR',sans-serif;font-weight:300;color:rgba(255,255,255,.65);letter-spacing:.06em;margin-top:10px;display:block;max-width:220px;line-height:1.6;opacity:0;transform:translateY(8px);transition:opacity .4s,transform .4s}
.panel:hover .panel-desc{opacity:1;transform:translateY(0)}
.panel-num{position:absolute;top:32px;right:36px;font-size:11px;font-family:'Noto Sans KR',sans-serif;color:rgba(255,255,255,.35);letter-spacing:.15em}

/* ── QUOTE ── */
.quote-section{width:100vw;height:100vh;position:relative;display:flex;align-items:center;justify-content:center;overflow:hidden}
.quote-bg{position:absolute;inset:0;background-size:cover;background-position:center;background-attachment:fixed}
.quote-overlay{position:absolute;inset:0;background:rgba(10,8,5,.52)}
.quote-content{position:relative;z-index:2;max-width:780px;padding:0 48px;text-align:center}
.quote-mark{font-size:72px;line-height:.6;color:var(--acc2);opacity:.6;margin-bottom:28px;font-family:Georgia,serif}
.quote-text{font-size:clamp(20px,3vw,34px);font-weight:300;color:#fff;letter-spacing:.04em;line-height:1.8;margin-bottom:32px}
.quote-attr{font-size:13px;font-family:'Noto Sans KR',sans-serif;font-weight:300;color:rgba(255,255,255,.5);letter-spacing:.2em;text-transform:uppercase}

/* ── ABOUT — 이미지+텍스트 반반 ── */
.about{display:grid;grid-template-columns:1fr 1fr;min-height:600px}
.about-img-wrap{position:relative;overflow:hidden}
.about-img{position:absolute;inset:0;background-size:cover;background-position:center;transition:transform .8s}
.about-img-wrap:hover .about-img{transform:scale(1.04)}
.about-text{display:flex;flex-direction:column;justify-content:center;padding:80px 72px;background:var(--bg)}
.about-label{font-size:11px;font-family:'Noto Sans KR',sans-serif;font-weight:500;color:var(--acc);letter-spacing:.28em;text-transform:uppercase;margin-bottom:28px}
.about-heading{font-size:clamp(26px,3.2vw,40px);font-weight:300;color:var(--txt);letter-spacing:.04em;line-height:1.5;margin-bottom:28px}
.about-line{width:36px;height:1px;background:var(--acc);margin-bottom:28px}
.about-body{font-size:15px;font-family:'Noto Sans KR',sans-serif;font-weight:300;color:var(--txt);opacity:.72;line-height:1.9;max-width:380px}

/* ── PROGRAMS ── */
.programs{padding:96px 56px;background:var(--bg)}
.sec-header{text-align:center;margin-bottom:64px}
.sec-label{font-size:11px;font-family:'Noto Sans KR',sans-serif;font-weight:500;color:var(--acc);letter-spacing:.28em;text-transform:uppercase;margin-bottom:20px}
.sec-title{font-size:clamp(22px,3vw,36px);font-weight:300;color:var(--txt);letter-spacing:.06em}
.prog-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px}
.prog-card{position:relative;height:360px;overflow:hidden;cursor:pointer}
.prog-card-img{position:absolute;inset:0;background-size:cover;background-position:center;transition:transform .7s ease}
.prog-card:hover .prog-card-img{transform:scale(1.06)}
.prog-card-ov{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.72) 0%,rgba(0,0,0,.1) 55%,transparent 100%);transition:background .4s}
.prog-card:hover .prog-card-ov{background:linear-gradient(to top,rgba(0,0,0,.58) 0%,rgba(0,0,0,.08) 55%,transparent 100%)}
.prog-card-body{position:absolute;bottom:0;left:0;right:0;padding:28px 28px 32px;z-index:2}
.prog-icon{font-size:22px;margin-bottom:10px;display:block}
.prog-name{font-size:17px;font-weight:400;color:#fff;letter-spacing:.06em;display:block;margin-bottom:6px}
.prog-detail{font-size:12px;font-family:'Noto Sans KR',sans-serif;font-weight:300;color:rgba(255,255,255,.6);letter-spacing:.04em;opacity:0;transform:translateY(6px);transition:opacity .35s,transform .35s}
.prog-card:hover .prog-detail{opacity:1;transform:translateY(0)}

/* ── GALLERY ── */
.gallery{display:grid;grid-template-columns:2fr 1fr 1fr;grid-template-rows:320px 320px;gap:3px;background:var(--bg);padding:3px}
.gallery-item{overflow:hidden;position:relative;background:#111}
.gallery-item:first-child{grid-row:span 2}
.gallery-img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .7s ease,opacity .3s}
.gallery-item:hover .gallery-img{transform:scale(1.06)}
.gallery-overlay{position:absolute;inset:0;background:rgba(0,0,0,.0);transition:background .3s}
.gallery-item:hover .gallery-overlay{background:rgba(0,0,0,.15)}

/* ── STATS ── */
.stats{padding:72px 56px;background:#1a1510;display:grid;grid-template-columns:repeat(4,1fr);gap:2px}
.stat-item{text-align:center;padding:40px 24px;border-right:1px solid rgba(255,255,255,.06)}
.stat-item:last-child{border-right:none}
.stat-num{font-size:clamp(36px,5vw,60px);font-weight:300;color:#fff;letter-spacing:.04em;display:block;line-height:1}
.stat-unit{font-size:16px;color:var(--acc2);opacity:.8;vertical-align:super;font-weight:300}
.stat-label{font-size:12px;font-family:'Noto Sans KR',sans-serif;font-weight:300;color:rgba(255,255,255,.45);letter-spacing:.15em;margin-top:14px;display:block;text-transform:uppercase}

/* ── CTA ── */
.cta-section{position:relative;height:540px;display:flex;align-items:center;justify-content:center;overflow:hidden}
.cta-bg{position:absolute;inset:0;background-size:cover;background-position:center;background-attachment:fixed}
.cta-overlay{position:absolute;inset:0;background:rgba(8,6,3,.5)}
.cta-content{position:relative;z-index:2;text-align:center;padding:0 24px}
.cta-title{font-size:clamp(28px,4.5vw,52px);font-weight:300;color:#fff;letter-spacing:.06em;margin-bottom:14px}
.cta-sub{font-size:15px;font-family:'Noto Sans KR',sans-serif;font-weight:300;color:rgba(255,255,255,.65);margin-bottom:40px;letter-spacing:.06em}
.cta-btn{display:inline-block;padding:14px 48px;border:1px solid rgba(255,255,255,.55);color:#fff;text-decoration:none;font-size:13px;font-family:'Noto Sans KR',sans-serif;font-weight:300;letter-spacing:.18em;transition:all .35s}
.cta-btn:hover{background:rgba(255,255,255,.12);border-color:#fff}

/* ── FOOTER ── */
footer{background:#120e0a;padding:64px 56px 40px;color:rgba(255,255,255,.4)}
.footer-grid{display:grid;grid-template-columns:2fr 1fr 1fr;gap:48px;margin-bottom:48px}
.footer-brand{font-size:18px;font-weight:400;color:rgba(255,255,255,.75);letter-spacing:.08em;margin-bottom:14px}
.footer-desc{font-size:13px;font-family:'Noto Sans KR',sans-serif;font-weight:300;line-height:1.8;max-width:280px}
.footer-col-title{font-size:11px;font-family:'Noto Sans KR',sans-serif;font-weight:500;color:rgba(255,255,255,.55);letter-spacing:.2em;text-transform:uppercase;margin-bottom:18px}
.footer-col-list{list-style:none;display:flex;flex-direction:column;gap:9px}
.footer-col-list li{font-size:13px;font-family:'Noto Sans KR',sans-serif;font-weight:300}
.footer-bottom{border-top:1px solid rgba(255,255,255,.06);padding-top:24px;display:flex;justify-content:space-between;align-items:center}
.footer-copy{font-size:12px;font-family:'Noto Sans KR',sans-serif;font-weight:300;letter-spacing:.04em}
.footer-tag{font-size:10px;font-family:'Noto Sans KR',sans-serif;background:var(--acc);color:#fff;padding:3px 9px;border-radius:20px;opacity:.7;letter-spacing:.05em}

/* ── THEME SWITCHER ── */
.theme-bar{position:fixed;bottom:20px;left:50%;transform:translateX(-50%);z-index:9000;display:flex;gap:7px;background:rgba(20,16,12,.75);padding:10px 16px;border-radius:40px;backdrop-filter:blur(10px)}
.theme-dot{width:20px;height:20px;border-radius:50%;cursor:pointer;border:2px solid transparent;transition:transform .2s,border-color .2s;flex-shrink:0}
.theme-dot:hover{transform:scale(1.3)}
.theme-dot.active{border-color:#fff;transform:scale(1.15)}
.theme-dot-wrap{position:relative}
.theme-dot-tip{position:absolute;bottom:calc(100% + 8px);left:50%;transform:translateX(-50%);background:rgba(0,0,0,.85);color:#fff;font-size:10px;white-space:nowrap;padding:4px 8px;border-radius:4px;pointer-events:none;opacity:0;transition:opacity .2s}
.theme-dot-wrap:hover .theme-dot-tip{opacity:1}

/* ── REVEAL ── */
.reveal{opacity:0;transform:translateY(28px);transition:opacity .8s ease,transform .8s ease}
.reveal.visible{opacity:1;transform:translateY(0)}
.reveal-left{opacity:0;transform:translateX(-32px);transition:opacity .8s ease,transform .8s ease}
.reveal-left.visible{opacity:1;transform:translateX(0)}
.reveal-right{opacity:0;transform:translateX(32px);transition:opacity .8s ease,transform .8s ease}
.reveal-right.visible{opacity:1;transform:translateX(0)}

/* ── RESPONSIVE ── */
@media(max-width:900px){
  .panels{grid-template-columns:1fr;grid-template-rows:repeat(4,420px)}
  .about{grid-template-columns:1fr}
  .about-img-wrap{height:360px;position:relative}
  .about-img{position:absolute}
