    const IMG5 = '/api/img-proxy?url=https://cafeptthumb-phinf.pstatic.net/MjAyMDA4MjdfMjI4/MDAxNTk4NTA5OTI4NDU2.mh8WzPbnjU9WBrHi-Gq8F2FRitnzLDMpPcC38w4U1Pcg.R6T4a3m4U8yVqFQlYZHpOqT3J0oKW_-2yEIQh_GZ8Pkg.JPEG/1.jpg?type=w1600';
