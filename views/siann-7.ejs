    %>
    :root {
      --bg: <%= t.bg %>;
      --deep: <%= t.deep %>;
      --mid: <%= t.mid %>;
      --card: <%= t.card %>;
      --accent: <%= t.accent %>;
      --accentLt: <%= t.accentLt %>;
      --accentDk: <%= t.accentDk %>;
      --text: <%= t.text %>;
      --text2: <%= t.text2 %>;
      --gray: <%= t.gray %>;
      --footerBg: <%= t.footerBg %>;
      --border: <%= t.border %>;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { width: 100%; min-height: 100vh; background: var(--bg); color: var(--text); font-family: 'Noto Sans KR', sans-serif; overflow-x: hidden; }

    /* ── PORTAL HEADER ── */
    .portal-header {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 48px; height: 68px;
      background: linear-gradient(to bottom, var(--deep) 0%, transparent 100%);
      backdrop-filter: blur(8px);
    }
    .portal-logo { font-family: 'Noto Serif KR', serif; font-size: 1.3rem; font-weight: 600; color: var(--accent); letter-spacing: 0.08em; text-decoration: none; }
    .portal-nav { display: flex; gap: 32px; list-style: none; }
    .portal-nav a { color: var(--text2); text-decoration: none; font-size: 0.88rem; font-weight: 300; letter-spacing: 0.04em; transition: color 0.2s; }
    .portal-nav a:hover { color: var(--accent); }
    .portal-cta { background: var(--accent); color: var(--bg); padding: 8px 22px; border-radius: 100px; font-size: 0.82rem; font-weight: 500; text-decoration: none; transition: background 0.2s, transform 0.2s; }
    .portal-cta:hover { background: var(--accentLt); transform: translateY(-1px); }

    /* ── MANDALA HERO ── */
    .mandala-hero {
      position: relative; min-height: 100vh;
      display: flex; align-items: center; justify-content: center;
      overflow: hidden; background: var(--bg);
    }

    /* concentric rings */
    .rings-wrap { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; pointer-events: none; }
    .ring {
      position: absolute; border-radius: 50%; border-style: solid; border-color: var(--accent);
      animation: ringPulse 6s ease-in-out infinite;
    }
    .ring:nth-child(1)  { width: 130px;  height: 130px;  border-width: 1.5px; opacity: 0.55; animation-delay: 0s; }
    .ring:nth-child(2)  { width: 220px;  height: 220px;  border-width: 1px;   opacity: 0.42; animation-delay: 0.4s; }
    .ring:nth-child(3)  { width: 330px;  height: 330px;  border-width: 1px;   opacity: 0.30; animation-delay: 0.8s; }
    .ring:nth-child(4)  { width: 460px;  height: 460px;  border-width: 0.8px; opacity: 0.22; animation-delay: 1.2s; }
    .ring:nth-child(5)  { width: 610px;  height: 610px;  border-width: 0.6px; opacity: 0.16; animation-delay: 1.6s; }
    .ring:nth-child(6)  { width: 780px;  height: 780px;  border-width: 0.5px; opacity: 0.10; animation-delay: 2.0s; }
    .ring:nth-child(7)  { width: 980px;  height: 980px;  border-width: 0.4px; opacity: 0.07; animation-delay: 2.4s; }
    .ring:nth-child(8)  { width: 1200px; height: 1200px; border-width: 0.3px; opacity: 0.04; animation-delay: 2.8s; }
    @keyframes ringPulse { 0%,100%{transform:scale(1);} 50%{transform:scale(1.03);} }

    /* radial petals (mandala) */
    .petals-wrap { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; pointer-events: none; }
    .petal-ring { position: absolute; width: 260px; height: 260px; }
    .petal {
      position: absolute; top: 50%; left: 50%;
      width: 28px; height: 68px;
      background: linear-gradient(to bottom, var(--accent), transparent);
      border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
      transform-origin: 50% 100%;
      opacity: 0.22;
    }
    .petal:nth-child(1)  { transform: translate(-50%, -100%) rotate(0deg);   }
    .petal:nth-child(2)  { transform: translate(-50%, -100%) rotate(30deg);  }
    .petal:nth-child(3)  { transform: translate(-50%, -100%) rotate(60deg);  }
    .petal:nth-child(4)  { transform: translate(-50%, -100%) rotate(90deg);  }
    .petal:nth-child(5)  { transform: translate(-50%, -100%) rotate(120deg); }
    .petal:nth-child(6)  { transform: translate(-50%, -100%) rotate(150deg); }
    .petal:nth-child(7)  { transform: translate(-50%, -100%) rotate(180deg); }
    .petal:nth-child(8)  { transform: translate(-50%, -100%) rotate(210deg); }
    .petal:nth-child(9)  { transform: translate(-50%, -100%) rotate(240deg); }
    .petal:nth-child(10) { transform: translate(-50%, -100%) rotate(270deg); }
    .petal:nth-child(11) { transform: translate(-50%, -100%) rotate(300deg); }
    .petal:nth-child(12) { transform: translate(-50%, -100%) rotate(330deg); }

    /* inner petal ring */
    .petal-ring-inner { position: absolute; width: 160px; height: 160px; }
    .petal-inner {
      position: absolute; top: 50%; left: 50%;
      width: 16px; height: 44px;
      background: linear-gradient(to bottom, var(--accentLt), transparent);
      border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
      transform-origin: 50% 100%;
      opacity: 0.30;
      animation: petalRotate 20s linear infinite;
    }
    .petal-inner:nth-child(1)  { transform: translate(-50%, -100%) rotate(0deg);   }
    .petal-inner:nth-child(2)  { transform: translate(-50%, -100%) rotate(45deg);  }
    .petal-inner:nth-child(3)  { transform: translate(-50%, -100%) rotate(90deg);  }
    .petal-inner:nth-child(4)  { transform: translate(-50%, -100%) rotate(135deg); }
    .petal-inner:nth-child(5)  { transform: translate(-50%, -100%) rotate(180deg); }
    .petal-inner:nth-child(6)  { transform: translate(-50%, -100%) rotate(225deg); }
    .petal-inner:nth-child(7)  { transform: translate(-50%, -100%) rotate(270deg); }
    .petal-inner:nth-child(8)  { transform: translate(-50%, -100%) rotate(315deg); }
    @keyframes petalRotate { from{transform:translate(-50%,-100%) rotate(var(--r, 0deg));} to{transform:translate(-50%,-100%) rotate(calc(var(--r, 0deg) + 360deg));} }

    /* central dot */
    .mandala-center {
      position: absolute;
      width: 90px; height: 90px;
      border-radius: 50%;
      background: radial-gradient(circle, var(--accentLt) 0%, var(--accent) 50%, transparent 100%);
      opacity: 0.6;
      animation: centerPulse 3s ease-in-out infinite;
    }
    @keyframes centerPulse { 0%,100%{opacity:0.6;transform:scale(1);} 50%{opacity:0.9;transform:scale(1.08);} }

    /* hero content */
    .hero-content {
      position: relative; z-index: 10;
      text-align: center; padding: 140px 20px 80px;
      max-width: 700px; margin: 0 auto;
    }
    .hero-eyebrow { font-size: 0.78rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--accent); font-weight: 400; margin-bottom: 24px; }
    .hero-title { font-family: 'Noto Serif KR', serif; font-size: clamp(2.4rem, 6vw, 4.2rem); font-weight: 300; line-height: 1.3; color: var(--text); margin-bottom: 20px; }
    .hero-title strong { font-weight: 600; color: var(--accent); }
    .hero-subtitle { font-size: 1.05rem; font-weight: 300; color: var(--text2); line-height: 1.8; margin-bottom: 40px; }
    .hero-gates { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
    .gate-btn {
      padding: 13px 28px; border: 1px solid var(--border); border-radius: 100px;
      color: var(--text2); font-size: 0.88rem; font-weight: 400; text-decoration: none;
      transition: all 0.25s; background: var(--card);
    }
    .gate-btn:hover { background: var(--accent); color: var(--bg); border-color: var(--accent); transform: translateY(-2px); }
    .gate-btn.primary { background: var(--accent); color: var(--bg); border-color: var(--accent); }
    .gate-btn.primary:hover { background: var(--accentLt); }

    /* scroll indicator */
    .scroll-indicator {
      position: absolute; bottom: 40px; left: 50%; transform: translateX(-50%);
      display: flex; flex-direction: column; align-items: center; gap: 8px; z-index: 10;
      opacity: 0.5;
    }
    .scroll-indicator span { font-size: 0.72rem; letter-spacing: 0.18em; color: var(--gray); }
    .scroll-line { width: 1px; height: 48px; background: linear-gradient(to bottom, var(--accent), transparent); animation: scrollDrop 1.8s ease-in-out infinite; }
    @keyframes scrollDrop { 0%{transform:scaleY(0);transform-origin:top;} 50%{transform:scaleY(1);transform-origin:top;} 51%{transform:scaleY(1);transform-origin:bottom;} 100%{transform:scaleY(0);transform-origin:bottom;} }

    /* ── CIRCULAR NAV SECTION ── */
    .circle-nav-section {
      padding: 120px 40px;
      background: var(--deep);
      position: relative; overflow: hidden;
    }
    .circle-nav-section::before {
      content: '한울';
      position: absolute; right: -60px; top: 50%; transform: translateY(-50%);
      font-family: 'Noto Serif KR', serif; font-size: 280px; font-weight: 700;
      color: var(--accent); opacity: 0.03; line-height: 1; pointer-events: none;
    }
    .section-label { font-size: 0.72rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--accent); font-weight: 400; margin-bottom: 16px; }
    .section-heading { font-family: 'Noto Serif KR', serif; font-size: clamp(1.6rem, 3.5vw, 2.6rem); font-weight: 400; color: var(--text); margin-bottom: 64px; line-height: 1.4; }

    .circ-nav-grid {
      display: grid;
      grid-template-columns: 360px 1fr;
      gap: 80px;
      align-items: center;
      max-width: 1100px; margin: 0 auto;
    }
    .circ-diagram { position: relative; width: 360px; height: 360px; }
    .circ-outer {
      position: absolute; inset: 0; border-radius: 50%;
      border: 1px solid var(--border);
    }
    .circ-mid {
      position: absolute; inset: 60px; border-radius: 50%;
      border: 1px solid var(--border);
    }
    .circ-inner {
      position: absolute; inset: 120px; border-radius: 50%;
      background: var(--mid); border: 1px solid var(--border);
      display: flex; align-items: center; justify-content: center;
    }
    .circ-inner-text { font-family: 'Noto Serif KR', serif; font-size: 1.2rem; font-weight: 600; color: var(--accent); text-align: center; line-height: 1.5; }

    .circ-node {
      position: absolute; width: 56px; height: 56px;
      border-radius: 50%; background: var(--card); border: 1px solid var(--border);
      display: flex; align-items: center; justify-content: center;
      font-size: 0.72rem; font-weight: 500; color: var(--text2); text-align: center;
      line-height: 1.3; cursor: default;
      transition: all 0.25s;
    }
    .circ-node:hover { background: var(--accent); color: var(--bg); border-color: var(--accent); }
    .circ-node.n1 { top: -28px; left: 50%; transform: translateX(-50%); }
    .circ-node.n2 { top: 50px; right: -28px; }
    .circ-node.n3 { bottom: 50px; right: -28px; }
    .circ-node.n4 { bottom: -28px; left: 50%; transform: translateX(-50%); }
    .circ-node.n5 { bottom: 50px; left: -28px; }
    .circ-node.n6 { top: 50px; left: -28px; }
    .circ-connector { position: absolute; inset: 0; pointer-events: none; }

    .nav-list { list-style: none; display: flex; flex-direction: column; gap: 20px; }
    .nav-list li { position: relative; padding-left: 28px; }
    .nav-list li::before {
      content: '';
      position: absolute; left: 0; top: 50%; transform: translateY(-50%);
      width: 10px; height: 1px; background: var(--accent);
    }
    .nav-list a { color: var(--text2); text-decoration: none; font-size: 1rem; font-weight: 300; letter-spacing: 0.04em; transition: color 0.2s; }
    .nav-list a:hover { color: var(--accent); }
    .nav-list .nav-desc { font-size: 0.8rem; color: var(--gray); margin-top: 4px; line-height: 1.5; }

    /* ── IMAGE GATEWAY SECTION ── */
    .gateway-section {
      padding: 100px 40px;
      background: var(--bg);
    }
    .gateway-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      grid-template-rows: 280px 280px;
      gap: 4px;
      max-width: 1200px; margin: 0 auto 80px;
    }
    .gw-cell {
      position: relative; overflow: hidden;
      background: var(--card);
      cursor: pointer;
    }
    .gw-cell img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s; display: block; }
    .gw-cell:hover img { transform: scale(1.06); }
    .gw-cell-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 50%);
      display: flex; align-items: flex-end; padding: 24px;
      opacity: 0.85; transition: opacity 0.25s;
    }
    .gw-cell:hover .gw-cell-overlay { opacity: 1; }
    .gw-cell-title { font-family: 'Noto Serif KR', serif; font-size: 1rem; font-weight: 500; color: #fff; line-height: 1.4; }
    .gw-cell.wide { grid-column: span 2; }
    .gw-cell.tall { grid-row: span 2; grid-column: 3; grid-row: 1 / 3; }

    /* ── GATEWAY INTRO ── */
    .gw-intro { max-width: 700px; margin: 0 auto 60px; text-align: center; }
    .gw-intro p { font-size: 1.1rem; font-weight: 300; color: var(--text2); line-height: 1.9; }

    /* ── TEACHING PORTALS ── */
    .teaching-section {
      padding: 100px 40px;
      background: var(--mid);
    }
    .teaching-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2px;
      max-width: 1100px; margin: 60px auto 0;
    }
    .teach-portal {
      position: relative; overflow: hidden;
      background: var(--card); padding: 48px 36px;
      transition: background 0.25s;
    }
    .teach-portal:hover { background: var(--deep); }
    .teach-num {
      font-family: 'Noto Serif KR', serif; font-size: 3.5rem; font-weight: 700;
      color: var(--accent); opacity: 0.2; line-height: 1;
      position: absolute; top: 24px; right: 28px;
    }
    .teach-title { font-family: 'Noto Serif KR', serif; font-size: 1.22rem; font-weight: 500; color: var(--text); margin-bottom: 16px; line-height: 1.4; }
    .teach-body { font-size: 0.88rem; font-weight: 300; color: var(--text2); line-height: 1.8; margin-bottom: 24px; }
    .teach-link { font-size: 0.78rem; color: var(--accent); text-decoration: none; letter-spacing: 0.06em; text-transform: uppercase; font-weight: 500; }
    .teach-link::after { content: ' →'; }
    .teach-link:hover { color: var(--accentLt); }
    .teach-bar { position: absolute; bottom: 0; left: 0; height: 2px; background: var(--accent); width: 0; transition: width 0.4s; }
    .teach-portal:hover .teach-bar { width: 100%; }

    /* ── RADIAL QUOTE ── */
    .radial-quote {
      padding: 120px 40px;
      background: var(--deep);
      text-align: center; position: relative; overflow: hidden;
    }
    .radial-quote::before, .radial-quote::after {
      content: '';
      position: absolute;
      border-radius: 50%;
      border: 1px solid var(--border);
      pointer-events: none;
    }
    .radial-quote::before { width: 500px; height: 500px; top: 50%; left: 50%; transform: translate(-50%,-50%); }
    .radial-quote::after  { width: 800px; height: 800px; top: 50%; left: 50%; transform: translate(-50%,-50%); }
    .quote-inner { position: relative; z-index: 2; max-width: 680px; margin: 0 auto; }
    .quote-mark { font-family: 'Noto Serif KR', serif; font-size: 6rem; line-height: 0; color: var(--accent); opacity: 0.3; margin-bottom: 32px; display: block; }
    .quote-text { font-family: 'Noto Serif KR', serif; font-size: clamp(1.3rem, 2.8vw, 1.9rem); font-weight: 300; color: var(--text); line-height: 1.8; margin-bottom: 24px; }
    .quote-source { font-size: 0.82rem; color: var(--gray); letter-spacing: 0.1em; }

    /* ── CONNECT SECTION ── */
    .connect-section {
      padding: 100px 40px;
      background: var(--bg);
    }
    .connect-wrap { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: start; }
    .connect-img-stack { position: relative; height: 480px; }
    .conn-img-back {
      position: absolute; top: 0; left: 30px; right: 0; bottom: 40px;
      background: var(--card); overflow: hidden;
    }
    .conn-img-back img { width: 100%; height: 100%; object-fit: cover; }
    .conn-img-front {
      position: absolute; bottom: 0; left: 0; width: 66%;
      background: var(--deep); overflow: hidden;
      border: 3px solid var(--bg);
    }
    .conn-img-front img { width: 100%; aspect-ratio: 4/3; object-fit: cover; display: block; }
    .conn-badge {
      position: absolute; top: 24px; left: 0;
      background: var(--accent); color: var(--bg);
      padding: 10px 20px; font-size: 0.82rem; font-weight: 600; letter-spacing: 0.06em;
    }

    .connect-text .section-label { margin-bottom: 16px; }
    .connect-text h2 { font-family: 'Noto Serif KR', serif; font-size: clamp(1.6rem, 3vw, 2.4rem); font-weight: 400; color: var(--text); margin-bottom: 28px; line-height: 1.5; }
    .connect-text p { font-size: 0.93rem; font-weight: 300; color: var(--text2); line-height: 1.9; margin-bottom: 24px; }
    .connect-info { display: flex; flex-direction: column; gap: 12px; margin-bottom: 36px; }
    .connect-info-row { display: flex; gap: 16px; align-items: flex-start; }
    .conn-key { font-size: 0.78rem; color: var(--gray); font-weight: 400; min-width: 80px; padding-top: 2px; }
    .conn-val { font-size: 0.88rem; color: var(--text2); font-weight: 300; line-height: 1.6; }

    /* ── ARCHIVE PORTAL ── */
    .archive-section {
      padding: 80px 40px;
      background: var(--card); border-top: 1px solid var(--border);
    }
    .archive-row {
      max-width: 1100px; margin: 0 auto;
      display: grid; grid-template-columns: repeat(4,1fr); gap: 40px;
    }
    .arch-item { text-align: center; padding: 32px 20px; border: 1px solid var(--border); position: relative; overflow: hidden; transition: border-color 0.2s; }
    .arch-item::before {
      content: '';
      position: absolute; bottom: 0; left: 0; height: 2px; width: 0;
      background: var(--accent); transition: width 0.35s;
    }
    .arch-item:hover { border-color: var(--accent); }
    .arch-item:hover::before { width: 100%; }
    .arch-num { font-family: 'Noto Serif KR', serif; font-size: 2.8rem; font-weight: 700; color: var(--accent); line-height: 1; margin-bottom: 8px; }
    .arch-unit { font-size: 0.75rem; color: var(--gray); letter-spacing: 0.08em; display: block; margin-bottom: 12px; }
    .arch-desc { font-size: 0.84rem; color: var(--text2); font-weight: 300; line-height: 1.6; }

    /* ── FOOTER ── */
    .site-footer {
      background: var(--footerBg);
      border-top: 1px solid var(--border);
      padding: 60px 48px 40px;
    }
    .footer-inner { max-width: 1100px; margin: 0 auto; }
    .footer-top { display: grid; grid-template-columns: 1.5fr 1fr 1fr 1fr; gap: 48px; margin-bottom: 48px; }
    .footer-brand .logo { font-family: 'Noto Serif KR', serif; font-size: 1.3rem; font-weight: 600; color: var(--accent); margin-bottom: 16px; display: block; }
    .footer-brand p { font-size: 0.82rem; font-weight: 300; color: var(--gray); line-height: 1.7; }
    .footer-col h4 { font-size: 0.78rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--accent); margin-bottom: 20px; font-weight: 500; }
    .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 12px; }
    .footer-col li a { color: var(--gray); font-size: 0.84rem; font-weight: 300; text-decoration: none; transition: color 0.2s; }
    .footer-col li a:hover { color: var(--text); }
    .footer-bottom { border-top: 1px solid var(--border); padding-top: 24px; display: flex; align-items: center; justify-content: space-between; }
    .footer-copy { font-size: 0.78rem; color: var(--gray); font-weight: 300; }

    /* ── SIANN BADGE ── */
    .siann-badge {
      position: fixed; bottom: 24px; right: 24px; z-index: 9999;
      background: rgba(0,0,0,0.82); backdrop-filter: blur(8px);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 10px; padding: 10px 14px;
      font-size: 0.72rem; color: rgba(255,255,255,0.7);
      font-family: 'Noto Sans KR', sans-serif;
      max-width: 300px; line-height: 1.5;
    }
    .b-row1 { margin-bottom: 6px; }
    .b-row1 span { color: var(--accent); font-weight: 600; }
    .b-row2 { display: flex; flex-wrap: wrap; gap: 3px; }
    .b-row2 a {
      display: inline-block; width: 20px; height: 20px; line-height: 20px;
      text-align: center; border-radius: 4px; text-decoration: none;
      font-size: 0.66rem; color: rgba(255,255,255,0.5);
      background: rgba(255,255,255,0.06); transition: all 0.15s;
    }
    .b-row2 a:hover { background: var(--accent); color: #000; }
    .b-row2 a.cur { background: var(--accent); color: #000; font-weight: 700; }

    /* ── RESPONSIVE ── */
    @media (max-width: 900px) {
      .portal-nav { display: none; }
      .circ-nav-grid { grid-template-columns: 1fr; }
      .circ-diagram { margin: 0 auto; }
      .gateway-grid { grid-template-columns: 1fr 1fr; grid-template-rows: auto; }
      .gw-cell.wide { grid-column: span 2; }
      .gw-cell.tall { grid-column: auto; grid-row: auto; }
      .teaching-grid { grid-template-columns: 1fr; }
      .connect-wrap { grid-template-columns: 1fr; }
      .archive-row { grid-template-columns: repeat(2,1fr); }
      .footer-top { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 600px) {
      .portal-header { padding: 0 20px; }
      .hero-content { padding: 120px 20px 60px; }
      .gateway-grid { grid-template-columns: 1fr; }
      .gw-cell.wide { grid-column: auto; }
      .archive-row { grid-template-columns: 1fr 1fr; }
      .footer-top { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

  <!-- HEADER -->
  <header class="portal-header">
    <a class="portal-logo" href="#">한울사상</a>
    <nav><ul class="portal-nav">
      <li><a href="#">한울이란</a></li>
      <li><a href="#">가르침</a></li>
      <li><a href="#">수련</a></li>
      <li><a href="#">말씀</a></li>
      <li><a href="#">아카이브</a></li>
    </ul></nav>
    <a class="portal-cta" href="#">입문 안내</a>
  </header>

  <!-- MANDALA HERO -->
  <section class="mandala-hero">
    <div class="rings-wrap">
      <div class="ring"></div><div class="ring"></div><div class="ring"></div><div class="ring"></div>
      <div class="ring"></div><div class="ring"></div><div class="ring"></div><div class="ring"></div>
    </div>
    <div class="petals-wrap">
      <div class="petal-ring">
        <div class="petal"></div><div class="petal"></div><div class="petal"></div>
        <div class="petal"></div><div class="petal"></div><div class="petal"></div>
        <div class="petal"></div><div class="petal"></div><div class="petal"></div>
        <div class="petal"></div><div class="petal"></div><div class="petal"></div>
      </div>
      <div class="petal-ring-inner">
        <div class="petal-inner"></div><div class="petal-inner"></div>
        <div class="petal-inner"></div><div class="petal-inner"></div>
        <div class="petal-inner"></div><div class="petal-inner"></div>
        <div class="petal-inner"></div><div class="petal-inner"></div>
      </div>
      <div class="mandala-center"></div>
    </div>

    <div class="hero-content">
      <div class="hero-eyebrow">Portal · Gateway · 한울의 문</div>
      <h1 class="hero-title">하늘과 땅의 원리,<br><strong>한울</strong>의 세계로</h1>
      <p class="hero-subtitle">천지 자연의 이치를 깨닫고 참된 삶의 길을 찾아가는<br>한울사상의 열린 문에 오신 것을 환영합니다.</p>
      <div class="hero-gates">
        <a class="gate-btn primary" href="#">입문하기</a>
        <a class="gate-btn" href="#">한울이란</a>
        <a class="gate-btn" href="#">말씀 보기</a>
      </div>
    </div>

    <div class="scroll-indicator">
      <span>SCROLL</span>
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- CIRCULAR NAV SECTION -->
  <section class="circle-nav-section">
    <div style="max-width:1100px;margin:0 auto;">
      <div class="section-label">Navigation · 탐색</div>
      <h2 class="section-heading">한울사상의 여섯 문</h2>
      <div class="circ-nav-grid">
        <div class="circ-diagram">
          <div class="circ-outer"></div>
          <div class="circ-mid"></div>
          <div class="circ-inner"><div class="circ-inner-text">한울<br>사상</div></div>
          <div class="circ-node n1">한울<br>이란</div>
          <div class="circ-node n2">가르<br>침</div>
          <div class="circ-node n3">말씀</div>
          <div class="circ-node n4">수련</div>
          <div class="circ-node n5">공동<br>체</div>
          <div class="circ-node n6">아카<br>이브</div>
        </div>
        <ul class="nav-list">
          <li>
            <a href="#">한울이란</a>
            <div class="nav-desc">천지 자연의 섭리와 한울의 근본 의미를 탐구합니다. 우주 만물의 연결과 순환 원리를 이해하는 첫걸음입니다.</div>
          </li>
          <li>
            <a href="#">가르침</a>
            <div class="nav-desc">한울사상의 핵심 교리와 삶의 지혜를 담은 가르침을 전합니다. 일상 속에서 실천할 수 있는 원칙들을 안내합니다.</div>
          </li>
          <li>
            <a href="#">말씀</a>
            <div class="nav-desc">선생님의 말씀과 경전 구절을 통해 한울의 뜻을 깊이 새깁니다. 성찰과 명상의 글들이 모여 있습니다.</div>
          </li>
          <li>
            <a href="#">수련원</a>
            <div class="nav-desc">마음과 몸을 가다듬는 수련 과정을 안내합니다. 초급부터 심화까지 단계적인 수련 프로그램을 제공합니다.</div>
          </li>
          <li>
            <a href="#">공동체</a>
            <div class="nav-desc">한울사상을 함께 나누는 사람들의 모임과 활동 소식을 전합니다. 서로를 격려하는 따뜻한 커뮤니티입니다.</div>
          </li>
          <li>
            <a href="#">아카이브</a>
            <div class="nav-desc">오랜 세월 쌓아온 자료와 기록들을 디지털로 보존합니다. 연구와 학습을 위한 풍부한 자료실입니다.</div>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- GATEWAY IMAGE SECTION -->
  <section class="gateway-section">
    <div style="max-width:700px;margin:0 auto 60px;text-align:center;">
      <div class="section-label">Gallery · 사진으로 만나는 한울</div>
      <h2 style="font-family:'Noto Serif KR',serif;font-size:clamp(1.6rem,3vw,2.4rem);font-weight:400;color:var(--text);margin-bottom:20px;line-height:1.5;">자연 속에서 피어나는<br>한울의 숨결</h2>
      <p style="font-size:0.95rem;font-weight:300;color:var(--text2);line-height:1.9;">산과 들, 하늘과 땅의 경계에서 한울의 이치는 조용히 흐릅니다.<br>사진 한 장 한 장에 그 숨결이 담겨 있습니다.</p>
    </div>
    <div class="gateway-grid">
      <div class="gw-cell wide">
        <img src="<%= IMG1 %>" alt="한울의 자연" />
        <div class="gw-cell-overlay">
          <div class="gw-cell-title">하늘과 땅이 하나 되는 순간<br><span style="font-size:0.8rem;opacity:0.8;font-weight:300;">천지자연의 원리</span></div>
        </div>
      </div>
      <div class="gw-cell tall">
        <img src="<%= IMG4 %>" alt="천지연폭포" />
        <div class="gw-cell-overlay">
          <div class="gw-cell-title">천지연의 힘<br><span style="font-size:0.8rem;opacity:0.8;font-weight:300;">생명의 근원</span></div>
        </div>
      </div>
      <div class="gw-cell">
        <img src="<%= IMG2 %>" alt="표와 포" />
        <div class="gw-cell-overlay">
          <div class="gw-cell-title">표와 포<br><span style="font-size:0.8rem;opacity:0.8;font-weight:300;">상징의 의미</span></div>
        </div>
      </div>
      <div class="gw-cell">
        <img src="<%= IMG3 %>" alt="의로움" />
        <div class="gw-cell-overlay">
          <div class="gw-cell-title">의로움의 길<br><span style="font-size:0.8rem;opacity:0.8;font-weight:300;">바른 삶의 실천</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- TEACHING PORTALS -->
  <section class="teaching-section">
    <div style="max-width:1100px;margin:0 auto;">
      <div class="section-label">Teaching · 핵심 가르침</div>
      <h2 class="section-heading">세 가지 근본 가르침</h2>
      <div class="teaching-grid">
        <div class="teach-portal">
          <div class="teach-num">一</div>
          <h3 class="teach-title">천지 자연의 이치</h3>
          <p class="teach-body">하늘과 땅의 원리를 바르게 이해하는 것이 한울사상의 출발점입니다. 자연의 섭리 속에 모든 존재가 서로 연결되어 있음을 깨닫습니다. 봄이 오면 꽃이 피듯, 이치에 따라 삶도 순환합니다.</p>
          <a class="teach-link" href="#">자세히 보기</a>
          <div class="teach-bar"></div>
        </div>
        <div class="teach-portal">
          <div class="teach-num">二</div>
          <h3 class="teach-title">참된 마음의 수련</h3>
          <p class="teach-body">마음을 닦아 맑게 하는 것이 한울사상의 핵심 수련입니다. 욕심과 집착을 내려놓고 본래의 맑고 순수한 마음 상태를 회복합니다. 일상 속 작은 실천들이 쌓여 큰 변화를 이룹니다.</p>
          <a class="teach-link" href="#">자세히 보기</a>
          <div class="teach-bar"></div>
        </div>
        <div class="teach-portal">
          <div class="teach-num">三</div>
          <h3 class="teach-title">더불어 사는 삶</h3>
          <p class="teach-body">혼자가 아닌 함께 살아가는 공동체의 가치를 중시합니다. 이웃을 내 몸처럼 여기고, 자연을 가족처럼 돌보는 마음이 한울사상의 실천입니다. 나눔과 섬김이 참된 행복의 길입니다.</p>
          <a class="teach-link" href="#">자세히 보기</a>
          <div class="teach-bar"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- RADIAL QUOTE -->
  <section class="radial-quote">
    <div class="quote-inner">
      <span class="quote-mark">"</span>
      <p class="quote-text">하늘은 스스로 돕는 자를 돕는다고 하지 않았는가.<br>한울의 뜻은 바로 그대 안에 있으니, 고요히 앉아 귀 기울이라.</p>
      <div class="quote-source">한울사상 경전 · 제3장 마음의 문</div>
    </div>
  </section>

  <!-- CONNECT SECTION -->
  <section class="connect-section">
    <div class="connect-wrap">
      <div class="connect-img-stack">
        <div class="conn-img-back"><img src="<%= IMG5 %>" alt="한울 모임" /></div>
        <div class="conn-img-front"><img src="<%= IMG6 %>" alt="한울 공동체" /></div>
        <div class="conn-badge">한울사상 수련원</div>
      </div>
      <div class="connect-text">
        <div class="section-label">Contact · 찾아오시는 길</div>
        <h2>한울의 문은<br>항상 열려 있습니다</h2>
        <p>처음 접하시는 분도, 오래 공부하신 분도 모두 환영합니다. 한울사상에 대해 궁금한 점이 있으시면 언제든지 연락 주시기 바랍니다.</p>
