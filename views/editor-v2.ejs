<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>법문 에디터 — 한울사상</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@200;300;400;500&family=Noto+Sans+KR:wght@300;400&family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&display=swap" rel="stylesheet">
  <style>
    *{margin:0;padding:0;box-sizing:border-box}
    :root{
      --bg:#FAFAF7;--bg2:#F4F0E8;--bg3:#E8E0CE;
      --ac:#7A5230;--tx:#1A1410;--t2:#4A3828;--gr:#8A7868;
      --bd:rgba(122,82,48,0.15);--nav-bg:rgba(26,16,8,0.97)
    }
    html{scroll-behavior:smooth}
    body{font-family:'Noto Sans KR',sans-serif;font-weight:300;background:var(--bg);color:var(--tx);-webkit-font-smoothing:antialiased}

    /* ── NAV ── */
    .site-nav{
      position:fixed;top:0;left:0;right:0;z-index:900;
      height:68px;display:flex;align-items:center;gap:0;
      background:var(--nav-bg);backdrop-filter:blur(20px);
      padding:0 clamp(16px,4vw,80px);
      box-shadow:0 1px 0 rgba(122,82,48,0.2)
    }
    .site-nav .logo{
      font-family:'Noto Serif KR',serif;font-size:15px;font-weight:400;
      color:rgba(255,255,255,.9);letter-spacing:.06em;text-decoration:none;
      margin-right:20px;padding-right:20px;
      border-right:1px solid rgba(255,255,255,.12)
    }
    .site-nav .logo:hover{color:var(--ac)}
    .nav-links{display:flex;gap:0;list-style:none}
    .nav-links a{
      font-size:11px;letter-spacing:.09em;color:rgba(255,255,255,.5);
      text-decoration:none;padding:0 14px;height:68px;display:flex;align-items:center;
      transition:color .2s;border-bottom:2px solid transparent
    }
    .nav-links a:hover{color:rgba(255,255,255,.85)}
    .nav-links a.active{color:var(--ac);border-bottom-color:var(--ac)}

    /* ── PAGE ── */
    .page{margin-top:68px;max-width:100%;margin-left:auto;margin-right:auto;padding:16px 24px 24px}

    /* ── TOOLBAR ── */
    .toolbar-row{display:flex;align-items:center;gap:8px;margin-bottom:10px;flex-wrap:wrap}
    .toolbar-row input[type=text]{
      padding:9px 13px;border:1px solid var(--bd);border-radius:0;
      font-size:13px;font-family:'Noto Sans KR',sans-serif;font-weight:300;
      background:#fff;flex:1;min-width:180px;color:var(--tx);
      outline:none;transition:border-color .2s
    }
    .toolbar-row input[type=text]:focus{border-color:var(--ac)}
    .toolbar-row input[type=text]::placeholder{color:var(--gr)}

    /* ── BUTTONS ── */
    .btn{
      padding:9px 20px;border:none;border-radius:0;cursor:pointer;
      font-size:11px;font-family:'Noto Sans KR',sans-serif;font-weight:400;
      letter-spacing:.1em;transition:.2s;white-space:nowrap
    }
    .btn-primary{background:var(--ac);color:#fff;border:1px solid var(--ac)}
    .btn-primary:hover{background:transparent;color:var(--ac)}
    .btn-secondary{background:var(--bg2);color:var(--t2);border:1px solid var(--bd)}
    .btn-secondary:hover{background:var(--bg3)}

    /* ── STATUS ── */
    .status-msg{font-size:12px;color:var(--gr);letter-spacing:.04em;padding:4px 0}
    .status-msg.ok{color:#4A7A2A}
    .status-msg.err{color:#A03030}

    /* ── PROGRESS BAR ── */
    #save-progress-wrap{display:none;margin-top:8px}
    #save-progress-label{font-size:12px;color:var(--t2);margin-bottom:4px;letter-spacing:.04em}
    #save-progress-bar-outer{height:10px;background:#e0e0e0;border-radius:5px;overflow:hidden;width:100%}
    #save-progress-bar-inner{height:100%;width:0%;background:var(--ac);border-radius:5px;transition:width .2s}
    #save-progress-detail{font-size:11px;color:var(--gr);margin-top:3px}

    /* ── EDITOR FRAME ── */
    .se-frame-wrap{
      background:#fff;border:1px solid var(--bd);
      overflow:hidden;width:100%;margin-bottom:24px
    }
    #se-iframe{width:100%;height:calc(100vh - 160px);border:none;display:block}

    @media(max-width:768px){
      .page{padding:12px 12px 24px}
    }
  </style>
</head>
<body>
<nav class="site-nav">
  <a href="javascript:void(0)" class="logo">한울사상</a>
  <ul class="nav-links">
    <li><a href="javascript:void(0)">홈</a></li>
    <li><a href="javascript:void(0)">아카이브</a></li>
    <li><a href="javascript:void(0)">AI 챗봇</a></li>
    <li><a href="javascript:void(0)" class="active">에디터</a></li>
  </ul>
</nav>

<div class="page">
  <!-- 게시글 선택 + 저장 -->
  <div class="toolbar-row">
    <input type="text" id="post-id-input" placeholder="게시글 ID 입력 후 불러오기…">
    <button class="btn btn-secondary" onclick="loadPost()">불러오기</button>
    <button class="btn btn-primary" id="save-btn" onclick="savePost()">저장</button>
    <span class="status-msg" id="status"></span>
  </div>
  <!-- 이미지 업로드 진행 상태바 -->
  <div id="save-progress-wrap">
    <div id="save-progress-label">이미지 업로드 준비 중…</div>
    <div id="save-progress-bar-outer"><div id="save-progress-bar-inner"></div></div>
    <div id="save-progress-detail"></div>
  </div>

  <!-- SmartEditor2 iframe -->
  <div class="se-frame-wrap">
    <iframe id="se-iframe" src="/public/se-wrapper.html" title="SmartEditor2 법문 에디터"></iframe>
  </div>
</div>

<!-- se-init-v2.js: paste/drop 이미지 업로드 핸들러 (순차 업로드 + 프로그레스 바) -->
<script src="/public/js/se-init-v2.js"></script>

<script>
let currentPostId = null;

function getSeEditor() {
  try {
    const cw = document.getElementById('se-iframe').contentWindow;
    return cw && cw.oEditors && cw.oEditors.getById && cw.oEditors.getById['ir1'];
  } catch { return null; }
}

function getSeHTML() {
  const ed = getSeEditor();
  if (!ed) return '';
  try { ed.exec('UPDATE_CONTENTS_FIELD', []); } catch {}
  try {
    const cw = document.getElementById('se-iframe').contentWindow;
    return cw.document.getElementById('ir1').value || '';
  } catch { return ''; }
}

function setSeHTML(html) {
  const ed = getSeEditor();
  if (!ed) { setTimeout(() => setSeHTML(html), 300); return; }
  try {
    ed.exec('SET_IR_VALUE', [html || '']);
  } catch {
    try {
      const cw = document.getElementById('se-iframe').contentWindow;
      const ta = cw.document.getElementById('ir1');
      if (ta) ta.value = html || '';
    } catch {}
  }
}

async function loadPost() {
  const pid = document.getElementById('post-id-input').value.trim();
  if (!pid) return;
  setStatus('불러오는 중…');
  try {
    const d = await fetch('/api/posts/' + encodeURIComponent(pid)).then(r => r.json());
    if (d.error) { setStatus('오류: ' + d.error, true); return; }
    currentPostId = d.post_id;
    const html = d.content_html || `<p>${(d.content || '').replace(/\n/g, '<br>')}</p>`;
    setSeHTML(html);
    setStatus(`"${d.title}" 불러옴`, false, true);
  } catch (e) { setStatus('오류: ' + e.message, true); }
}

// blob: URL → dataUrl 변환 (서버는 blob URL 처리 불가 — 클라이언트에서 변환 필수)
async function blobUrlToDataUrl(blobUrl) {
  const res = await fetch(blobUrl);
  const blob = await res.blob();
  return new Promise((resolve, reject) => {
    const reader = new FileReader();
    reader.onload = () => resolve(reader.result);
    reader.onerror = reject;
    reader.readAsDataURL(blob);
  });
}

// img src 분류: uploaded(http/https) / pending(data:/blob:/file:) / broken(src없음)
function auditImgSrcs(html) {
  const details = [];
  const re = /<img\b([^>]*)>/gi;
  let m;
  while ((m = re.exec(html)) !== null) {
    const srcM = /\bsrc\s*=\s*["']([^"']*)["']/i.exec(m[1]);
    const src = srcM ? srcM[1] : '';
    let status;
    if (!src) status = 'broken';
    else if (/^https?:\/\//i.test(src)) status = 'uploaded';
    else status = 'pending';
    details.push({ src, status });
  }
  return details;
}

function showProgress(visible) {
  document.getElementById('save-progress-wrap').style.display = visible ? 'block' : 'none';
  document.getElementById('save-btn').disabled = visible;
}

function updateProgress(current, total, successCount, failCount) {
  const pct = total > 0 ? Math.round((current / total) * 100) : 0;
  document.getElementById('save-progress-bar-inner').style.width = pct + '%';
  document.getElementById('save-progress-label').textContent =
    `이미지 업로드 중… ${current} / ${total}개 (${pct}%)`;
  const f = typeof failCount === 'number' ? failCount : 0;
  document.getElementById('save-progress-detail').textContent =
    `성공 ${successCount}건${f > 0 ? ' / 실패 ' + f + '건' : ''}`;
}

async function savePost() {
  if (!currentPostId) { setStatus('먼저 게시글을 불러오세요', true); return; }
  setStatus('이미지 감사 중…');
  try {
    let html = getSeHTML();

    // ── 1. 이미지 감사 ──────────────────────────────────────────
    const details = auditImgSrcs(html);
    const total = details.length;
    const pendingList = details.filter(d => d.status === 'pending');
    if (total > 0) setStatus(`이미지 총 ${total}개 — 미업로드 ${pendingList.length}개`);

    // ── 2. 이미지 상태바 표시 (pending 유무 관계없이 이미지 있으면 항상 표시) ──
    if (total > 0) {
      showProgress(true);
      if (pendingList.length === 0) {
        // 붙여넣기 시 이미 업로드 완료된 경우 → 즉시 100% 표시
        document.getElementById('save-progress-label').textContent =
          `이미지 ${total}개 전체 업로드 확인 완료 (${total}/${total})`;
        document.getElementById('save-progress-bar-inner').style.width = '100%';
        document.getElementById('save-progress-detail').textContent =
          `업로드 완료 ${total}건`;
        await new Promise(function(r){ setTimeout(r, 900); });
        showProgress(false);
      }
    }

    if (pendingList.length > 0) {
      showProgress(true);
      document.getElementById('save-progress-label').textContent =
        `이미지 업로드 시작… 0 / ${pendingList.length}개 (0%)`;
      document.getElementById('save-progress-bar-inner').style.width = '0%';

      const uploadFn  = window.SE2_uploadQueue;
      const replaceFn = window.SE2_replaceDataUrls;

      // blob URL 포함 tasks 빌드 (blob: → dataUrl 변환 후 서버 전송)
      const tasks = [];
      for (const d of pendingList) {
        let dataUrl = d.src;
        if (d.src.startsWith('blob:')) {
          try { dataUrl = await blobUrlToDataUrl(d.src); } catch { dataUrl = null; }
        }
        tasks.push({ kind: 'dataUrl', dataUrl, key: d.src });
      }

      if (uploadFn && replaceFn) {
        const urls = await uploadFn(tasks, 1, updateProgress);
        const map = new Map();
        tasks.forEach((t, i) => { if (urls[i]) map.set(t.key, urls[i]); });
        html = replaceFn(html, map);  // split/join 방식 (se-init-v2.js 수정됨)
      } else {
        // fallback: 기본 순차 업로드 (split/join으로 안정적 교체)
        let suc = 0; let fail = 0;
        for (let i = 0; i < tasks.length; i++) {
          updateProgress(i, tasks.length, suc, fail);
          const t = tasks[i];
          if (!t.dataUrl) { fail++; continue; }
          let uploaded = null;
          for (let attempt = 0; attempt < 3; attempt++) {
            try {
              const r = await fetch('/api/upload', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ dataUrl: t.dataUrl }),
              });
              const j = await r.json();
              if (j && j.url) { uploaded = j.url; break; }
            } catch { if (attempt === 2) break; }
          }
          if (uploaded) { html = html.split(t.key).join(uploaded); suc++; } else fail++;
        }
        updateProgress(tasks.length, tasks.length, suc, fail);
      }
      showProgress(false);
    }

    // ── 3. 저장 전 최종 검증 — 미업로드 이미지 있으면 차단 ──────
    const preCheck = auditImgSrcs(html);
    const stillPending = preCheck.filter(d => d.status === 'pending');
    if (stillPending.length > 0) {
      setStatus(`⛔ 이미지 ${stillPending.length}개 업로드 실패 — 저장 중단. 재시도하거나 이미지를 확인하세요.`, true);
      return;
    }

    // ── 4. PUT 저장 ─────────────────────────────────────────────
    setStatus('저장 중…');
    const r = await fetch('/api/posts/' + encodeURIComponent(currentPostId), {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ content_html: html }),
    }).then(r => r.json());
    if (!r.ok) { setStatus('오류: ' + r.error, true); return; }

    // ── 5. 저장 후 검증 ─────────────────────────────────────────
    const saved = auditImgSrcs(html);
    const failedCount = saved.filter(d => d.status === 'pending').length;
    const okCount     = saved.filter(d => d.status === 'uploaded').length;
    if (failedCount > 0) {
      setStatus(`⚠️ 이미지 ${failedCount}개 미업로드 상태로 저장됨`, true);
    } else {
      setStatus(total > 0
        ? `저장 완료 — 이미지 ${okCount} / ${total}개 전체 업로드 확인`
        : '저장 완료', false, true);
    }
  } catch (e) {
    showProgress(false);
    setStatus('오류: ' + e.message, true);
  }
}

function setStatus(msg, isErr = false, isOk = false) {
  const el = document.getElementById('status');
  el.textContent = msg;
  el.className = 'status-msg' + (isErr ? ' err' : isOk ? ' ok' : '');
}

function escHtml(s) { return String(s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;'); }
</script>
</body>
</html>
