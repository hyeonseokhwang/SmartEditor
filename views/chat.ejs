<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>한울사상 AI 상담 · 여의명상센터</title>
  <meta name="description" content="한울사상 AI 상담 챗봇. 한울사상, 여의수행, 유○론적 각성에 관한 질문에 RAG 기반으로 답변합니다."/>
  <meta property="og:title" content="한울사상 AI 상담"/>
  <meta property="og:description" content="한울사상 여의명상센터 AI 챗봇 — 한울 · 여의수행 · 유○론적 각성 Q&A"/>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@300;400;500&family=Noto+Sans+KR:wght@300;400&display=swap" rel="stylesheet">
  <style>
    *{margin:0;padding:0;box-sizing:border-box}
    body{font-family:'Noto Sans KR',sans-serif;background:#F8F6F0;color:#2A1E10;height:100vh;display:flex;flex-direction:column}

    /* NAV */
    .site-nav{position:fixed;top:0;left:0;right:0;height:44px;background:rgba(42,30,16,0.96);display:flex;align-items:center;gap:0;z-index:9999;padding:0 24px}
    .site-nav a{color:#E8DCC8;text-decoration:none;font-size:13px;padding:0 14px;height:44px;display:flex;align-items:center;font-family:'Noto Sans KR',sans-serif;letter-spacing:.5px;transition:color .2s}
    .site-nav a:hover,.site-nav a.active{color:#D4A840}
    .site-nav .logo{font-family:'Noto Serif KR',serif;font-size:15px;font-weight:500;color:#E8DCC8;margin-right:8px;border-right:1px solid rgba(255,255,255,.2);padding-right:18px}

    /* LAYOUT */
    .chat-wrap{margin-top:44px;flex:1;display:flex;flex-direction:column;max-width:760px;width:100%;margin-left:auto;margin-right:auto;padding:20px 20px 16px}

    /* OPERATOR HEADER */
    .chat-header{display:flex;align-items:center;gap:14px;padding:16px 20px;background:#fff;border:1px solid #DDD8C8;border-radius:10px 10px 0 0;border-bottom:1px solid #EDE8D8}
    .op-avatar{width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,#7A5230,#C8A030);display:flex;align-items:center;justify-content:center;font-family:'Noto Serif KR',serif;font-size:18px;color:#fff;flex-shrink:0}
    .op-info{flex:1}
    .op-name{font-family:'Noto Serif KR',serif;font-size:15px;font-weight:400;color:#2A1E10}
    .op-sub{font-size:11px;color:#9A8870;margin-top:2px;letter-spacing:.04em}
    .op-status{display:flex;align-items:center;gap:6px;font-size:11px;letter-spacing:.06em}
    .status-dot{width:8px;height:8px;border-radius:50%;background:#5A9A5A;animation:pulse-dot 2s infinite}
    @keyframes pulse-dot{0%,100%{opacity:1;box-shadow:0 0 0 0 rgba(90,154,90,.4)}50%{box-shadow:0 0 0 4px rgba(90,154,90,0)}}
    .status-txt{color:#5A9A5A}

    /* MESSAGES */
    .messages{flex:1;overflow-y:auto;background:#fff;border:1px solid #DDD8C8;border-top:none;border-bottom:none;padding:20px;display:flex;flex-direction:column;gap:16px;min-height:200px;max-height:calc(100vh - 320px)}
    .messages::-webkit-scrollbar{width:4px}
    .messages::-webkit-scrollbar-thumb{background:#DDD8C8;border-radius:2px}
    .msg{display:flex;gap:12px;align-items:flex-start}
    .msg.user{flex-direction:row-reverse}
    .avatar{width:34px;height:34px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0;font-family:'Noto Serif KR',serif}
    .msg.user .avatar{background:#2A1E10;color:#E8DCC8}
    .msg.bot  .avatar{background:linear-gradient(135deg,#7A5230,#C8A030);color:#fff}
    .bubble{max-width:80%;padding:12px 16px;font-size:14px;line-height:1.85;word-break:break-word}
    .msg.user .bubble{background:#2A1E10;color:#E8DCC8;border-radius:10px 2px 10px 10px}
    .msg.bot  .bubble{background:#F8F2E4;color:#2A1E10;border-radius:2px 10px 10px 10px;border-left:2px solid #D4A840}
    .msg-time{font-size:10px;color:#C0B8A8;margin-top:4px;letter-spacing:.04em}
    .msg.user .msg-time{text-align:right}

    /* TYPING */
    .typing-wrap{display:flex;align-items:center;gap:5px;padding:12px 16px;background:#F8F2E4;border-radius:2px 10px 10px 10px;border-left:2px solid #D4A840}
    .typing-txt{font-size:12px;color:#9A8870;letter-spacing:.04em}
    .dot{width:5px;height:5px;background:#D4A840;border-radius:50%;animation:bounce .8s infinite alternate}
    .dot:nth-child(2){animation-delay:.2s}
    .dot:nth-child(3){animation-delay:.4s}
    @keyframes bounce{from{transform:translateY(0)}to{transform:translateY(-5px)}}

    /* NOTICE */
    .notice-bar{background:#F0E8D4;border:1px solid #DDD0B0;border-top:none;border-bottom:none;padding:8px 20px;font-size:11px;color:#7A6048;display:flex;align-items:center;gap:8px;letter-spacing:.04em}

    /* SUGGESTIONS */
    .sugg-area{background:#fff;border:1px solid #DDD8C8;border-top:none;border-bottom:none;padding:10px 20px}
    .sugg-label{font-size:10px;letter-spacing:.14em;color:#9A8870;margin-bottom:7px;text-transform:uppercase}
    .suggestions{display:flex;flex-wrap:wrap;gap:7px}
    .sugg{padding:5px 13px;background:#F0E8D4;color:#5A3E18;border:1px solid #DDD0B0;border-radius:20px;font-size:12px;cursor:pointer;transition:background .15s}
    .sugg:hover{background:#E8D8B8}

    /* INPUT */
    .input-area{display:flex;background:#fff;border:1px solid #DDD8C8;border-top:1px solid #EDE8D8;border-radius:0 0 10px 10px;overflow:hidden}
    .input-area input{flex:1;padding:14px 18px;border:none;font-size:14px;background:transparent;font-family:'Noto Sans KR',sans-serif;outline:none;color:#2A1E10}
    .input-area input::placeholder{color:#BDB5A5}
    .input-area button{padding:14px 24px;background:#2A1E10;color:#E8DCC8;border:none;cursor:pointer;font-size:13px;font-family:'Noto Serif KR',serif;white-space:nowrap;transition:background .2s;letter-spacing:.04em;min-height:44px;touch-action:manipulation}
    .input-area button:hover{background:#3A2E20}
    .input-area button:active:not(:disabled){background:#3A2E20}
    .input-area button:disabled{opacity:.45;cursor:not-allowed}

    /* SOURCES */
    .src-bar{font-size:10px;color:#B0A890;margin-top:6px;letter-spacing:.04em}
    .src-tag{display:inline-block;padding:2px 8px;background:#F0E8D4;border-radius:10px;margin:2px;font-size:10px;color:#7A6048}

    /* MARKDOWN rendered in bubble */
    .bubble h3,.bubble h4{font-family:'Noto Serif KR',serif;margin:.8em 0 .3em;font-size:1em}
    .bubble strong{color:#7A5230;font-weight:700}
    .bubble ul,.bubble ol{padding-left:1.4em;margin:.5em 0}
    .bubble li{margin:.25em 0}
    .bubble blockquote{border-left:2px solid #D4A840;padding-left:.8em;color:#5A4030;margin:.5em 0;font-style:italic}
    .bubble hr{border:none;border-top:1px solid #DDD8C8;margin:.8em 0}

    /* QUICK QUESTIONS (2줄) */
    .quick-grid{display:grid;grid-template-columns:1fr 1fr;gap:6px}
    .quick-btn{padding:8px 12px;background:#F4EFE4;color:#5A3E18;border:1px solid #DDD0B0;border-radius:8px;font-size:12px;cursor:pointer;text-align:left;transition:background .15s;font-family:'Noto Sans KR',sans-serif;line-height:1.4;min-height:44px;touch-action:manipulation}
    .quick-btn:hover{background:#EDE0C8}
    .quick-btn:active{background:#E0D0B0}

    /* MOBILE */
    @media(max-width:640px){
      .chat-wrap{padding:12px 0 0;max-width:100%}
      .chat-header{border-radius:0;border-left:0;border-right:0}
      .messages{max-height:calc(100vh - 290px)}
      .bubble{max-width:92%;font-size:13px}
      .sugg-area{padding:8px 12px}
      .quick-grid{grid-template-columns:1fr}
      .input-area{border-radius:0;border-left:0;border-right:0;border-bottom:0}
      .input-area input{padding:12px 12px;font-size:14px}
      .input-area button{padding:12px 18px;font-size:13px}
      .site-nav{overflow-x:auto;white-space:nowrap;scrollbar-width:none}
      .site-nav::-webkit-scrollbar{display:none}
      .site-nav a{flex-shrink:0;font-size:12px;padding:0 10px}
      .site-nav .logo{font-size:13px}
      .notice-bar{padding:6px 12px;font-size:10px}
    }
    @media(max-width:480px){
      .chat-wrap{padding:6px 0 0}
      .chat-header{padding:12px 14px;gap:10px}
      .op-avatar{width:36px;height:36px;font-size:15px}
      .op-name{font-size:13px}
      .op-sub{font-size:10px}
      .messages{max-height:calc(100vh - 280px);padding:12px}
      .bubble{padding:10px 12px;font-size:13px}
      .quick-btn{font-size:11px;padding:7px 10px}
      .sugg-area{padding:6px 10px}
      .sugg-label{font-size:9px}
      .input-area input{font-size:14px;padding:10px;min-height:44px}
      .input-area button{padding:10px 14px;font-size:12px;min-height:44px}
    }
  </style>
</head>
<body>
<nav class="site-nav">
  <a href="/" class="logo">한울사상</a>
  <a href="/">홈 (A팀)</a>
  <a href="/v2">홈 (B팀)</a>
  <a href="/archive">아카이브</a>
  <a href="/chat" class="active">담당관 채팅</a>
  <a href="/editor">에디터</a>
</nav>

<div class="chat-wrap">

  <div class="chat-header">
    <div class="op-avatar">한</div>
    <div class="op-info">
      <div class="op-name">한울사상 AI 상담관</div>
      <div class="op-sub">여의선원 경전 996건 · 카페 게시글 9,400건+ 기반 · GPT-4o 구동</div>
    </div>
    <div class="op-status">
      <div class="status-dot"></div>
      <div class="status-txt">응대 중</div>
    </div>
  </div>

  <div class="messages" id="messages">
    <div class="msg bot">
      <div class="avatar">한</div>
      <div>
        <div class="bubble">안녕하세요. 여의선원 한울사상 AI 상담관입니다.<br><br>
        <strong>생명장 · 수도 · 제도(濟度) · 성멸오통 · 각성 · 집중수도</strong> 등<br>
        한울사상 전반에 대해 여의선원 경전 및 큰스승님 법문 게시글 기반으로 답변드립니다.<br><br>
        아래 질문을 선택하시거나 직접 입력해 주세요.</div>
        <div class="msg-time">방금</div>
      </div>
    </div>
  </div>

  <div class="notice-bar">
    <span>☯</span>
    <span>한울사상 경전 원문 및 큰스승님 말씀을 기반으로 답변드립니다</span>
  </div>

  <div class="sugg-area">
    <div class="sugg-label">빠른 질문</div>
    <div class="quick-grid">
      <button class="quick-btn" onclick="ask(this.textContent)">생명장이란 무엇인가요?</button>
      <button class="quick-btn" onclick="ask(this.textContent)">성멸오통이란 무엇인가요?</button>
      <button class="quick-btn" onclick="ask(this.textContent)">우주영제도는 무엇인가요?</button>
      <button class="quick-btn" onclick="ask(this.textContent)">집중수도는 어떻게 하나요?</button>
      <button class="quick-btn" onclick="ask(this.textContent)">수도자 1인은 세상자 만인의 의미는?</button>
      <button class="quick-btn" onclick="ask(this.textContent)">한울사상의 핵심은 무엇인가요?</button>
    </div>
  </div>

  <div class="input-area">
    <input type="text" id="q" placeholder="담당관에게 질문하세요…" onkeydown="if(event.key==='Enter'&&!event.shiftKey)sendMsg()">
    <button id="send-btn" onclick="sendMsg()">전송</button>
  </div>

</div>

<script>
let busy = false;

function ask(text) {
  document.getElementById('q').value = text;
  sendMsg();
}

function nowTime() {
  return new Date().toLocaleTimeString('ko-KR', {hour:'2-digit', minute:'2-digit'});
}

async function sendMsg() {
  if (busy) return;
  const q = document.getElementById('q').value.trim();
  if (!q) return;
  busy = true;
  document.getElementById('send-btn').disabled = true;
  document.getElementById('q').value = '';

  const msgs = document.getElementById('messages');

  msgs.innerHTML += `
    <div class="msg user">
      <div class="avatar">나</div>
      <div>
        <div class="bubble">${escHtml(q)}</div>
        <div class="msg-time">${nowTime()}</div>
      </div>
    </div>`;

  const typingId = 'typing-' + Date.now();
  msgs.innerHTML += `
    <div class="msg bot" id="${typingId}">
      <div class="avatar">한</div>
      <div>
        <div class="typing-wrap">
          <span class="dot"></span><span class="dot"></span><span class="dot"></span>
          <span class="typing-txt">담당관이 답변을 작성 중입니다…</span>
        </div>
      </div>
    </div>`;
  msgs.scrollTop = msgs.scrollHeight;

  try {
    const res = await fetch('/api/chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ question: q }),
    });
    if (!res.ok) throw new Error(`HTTP ${res.status}`);

    // typing indicator → 스트리밍 버블로 교체
    const el = document.getElementById(typingId);
    let bubbleEl = null;
    let sources = null;
    if (el) {
      el.outerHTML = `
        <div class="msg bot" id="${typingId}-resp">
          <div class="avatar">한</div>
          <div>
            <div class="bubble" id="${typingId}-bubble"></div>
            <div class="msg-time" id="${typingId}-time"></div>
          </div>
        </div>`;
      bubbleEl = document.getElementById(`${typingId}-bubble`);
    }

    const reader = res.body.getReader();
    const decoder = new TextDecoder();
    let buffer = '';
    let fullText = '';

    while (true) {
      const { done, value } = await reader.read();
      if (done) break;
      buffer += decoder.decode(value, { stream: true });
      const lines = buffer.split('\n');
      buffer = lines.pop();
      for (const line of lines) {
        if (!line.startsWith('data: ')) continue;
        try {
          const data = JSON.parse(line.slice(6));
          if (data.type === 'sources') {
            sources = data.sources;
          } else if (data.type === 'token') {
            fullText += data.text;
            if (bubbleEl) { bubbleEl.innerHTML = renderMd(fullText); msgs.scrollTop = msgs.scrollHeight; }
          } else if (data.type === 'done') {
            const timeEl = document.getElementById(`${typingId}-time`);
            if (timeEl) timeEl.innerHTML = `${nowTime()} · 한울사상 AI${sources && sources.length ? ' · <span class="src-bar">' + sources.slice(0,3).map(s=>`<span class="src-tag">${escHtml(s.book)}</span>`).join('') + '</span>' : ''}`;
          } else if (data.type === 'error') {
            throw new Error(data.message);
          }
        } catch(parseErr) { if (parseErr.message && !parseErr.message.startsWith('JSON')) throw parseErr; }
      }
    }
  } catch(e) {
    const el = document.getElementById(typingId) || document.getElementById(`${typingId}-resp`);
    if (el) el.outerHTML = `
      <div class="msg bot">
        <div class="avatar">한</div>
        <div>
          <div class="bubble">잠시 후 다시 시도해 주세요. 불편을 드려 죄송합니다.</div>
          <div class="msg-time">${nowTime()} · 한울 담당관</div>
        </div>
      </div>`;
  }

  msgs.scrollTop = msgs.scrollHeight;
  busy = false;
  document.getElementById('send-btn').disabled = false;
  document.getElementById('q').focus();
}

function escHtml(s){ return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

function renderMd(s) {
  return escHtml(s)
    // headers
    .replace(/^### (.+)$/gm, '<h4>$1</h4>')
    .replace(/^## (.+)$/gm, '<h3>$1</h3>')
    // bold
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    // blockquote
    .replace(/^&gt; (.+)$/gm, '<blockquote>$1</blockquote>')
    // hr
    .replace(/^---$/gm, '<hr>')
    // unordered list
    .replace(/^[*\-] (.+)$/gm, '<li>$1</li>')
    .replace(/(<li>.*<\/li>\n?)+/g, m => `<ul>${m}</ul>`)
    // ordered list
    .replace(/^\d+\. (.+)$/gm, '<li>$1</li>')
    // newlines
    .replace(/\n{2,}/g, '<br><br>')
    .replace(/\n/g, '<br>');
}
</script>
</body>
</html>
