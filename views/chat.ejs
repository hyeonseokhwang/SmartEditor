<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>한울사상 AI 챗봇</title>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@300;400;500&family=Noto+Sans+KR:wght@300;400&display=swap" rel="stylesheet">
  <style>
    *{margin:0;padding:0;box-sizing:border-box}
    body{font-family:'Noto Sans KR',sans-serif;background:#F8F6F0;color:#2A1E10;height:100vh;display:flex;flex-direction:column}
    .site-nav{position:fixed;top:0;left:0;right:0;height:44px;background:rgba(42,30,16,0.96);display:flex;align-items:center;gap:0;z-index:9999;padding:0 24px}
    .site-nav a{color:#E8DCC8;text-decoration:none;font-size:13px;padding:0 14px;height:44px;display:flex;align-items:center;font-family:'Noto Sans KR',sans-serif;letter-spacing:.5px;transition:color .2s}
    .site-nav a:hover,.site-nav a.active{color:#D4A840}
    .site-nav .logo{font-family:'Noto Serif KR',serif;font-size:15px;font-weight:500;color:#E8DCC8;margin-right:8px;border-right:1px solid rgba(255,255,255,.2);padding-right:18px}
    .chat-wrap{margin-top:44px;flex:1;display:flex;flex-direction:column;max-width:760px;width:100%;margin-left:auto;margin-right:auto;padding:20px}
    h1{font-family:'Noto Serif KR',serif;font-size:20px;font-weight:400;margin-bottom:4px}
    .desc{font-size:13px;color:#7A6048;margin-bottom:20px}
    .messages{flex:1;overflow-y:auto;background:#fff;border:1px solid #DDD8C8;border-radius:10px;padding:20px;display:flex;flex-direction:column;gap:16px;min-height:300px;max-height:calc(100vh - 260px)}
    .msg{display:flex;gap:12px;align-items:flex-start}
    .msg.user{flex-direction:row-reverse}
    .avatar{width:34px;height:34px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0}
    .msg.user .avatar{background:#2A1E10;color:#E8DCC8}
    .msg.bot  .avatar{background:#D4A840;color:#fff}
    .bubble{max-width:80%;padding:12px 16px;border-radius:10px;font-size:14px;line-height:1.8}
    .msg.user .bubble{background:#2A1E10;color:#E8DCC8;border-radius:10px 2px 10px 10px}
    .msg.bot  .bubble{background:#F8F2E4;color:#2A1E10;border-radius:2px 10px 10px 10px}
    .sources{margin-top:8px;font-size:11px;color:#9A8870}
    .typing{display:flex;align-items:center;gap:6px;color:#9A8870;font-size:13px}
    .dot{width:6px;height:6px;background:#D4A840;border-radius:50%;animation:bounce .8s infinite alternate}
    .dot:nth-child(2){animation-delay:.2s}.dot:nth-child(3){animation-delay:.4s}
    @keyframes bounce{from{transform:translateY(0)}to{transform:translateY(-6px)}}
    .input-area{display:flex;gap:8px;margin-top:12px}
    .input-area input{flex:1;padding:11px 16px;border:1px solid #DDD8C8;border-radius:8px;font-size:14px;background:#fff;font-family:'Noto Sans KR',sans-serif;outline:none}
    .input-area input:focus{border-color:#D4A840}
    .input-area button{padding:11px 22px;background:#2A1E10;color:#E8DCC8;border:none;border-radius:8px;cursor:pointer;font-size:13px;font-family:'Noto Serif KR',serif;white-space:nowrap}
    .input-area button:disabled{opacity:.5;cursor:not-allowed}
    .suggestions{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:12px}
    .sugg{padding:6px 14px;background:#F0E8D4;color:#5A3E18;border:1px solid #DDD0B0;border-radius:20px;font-size:12px;cursor:pointer;transition:background .15s}
    .sugg:hover{background:#E8D8B8}
  </style>
</head>
<body>
<nav class="site-nav">
  <a href="/" class="logo">한울사상</a>
  <a href="/">홈 (A팀)</a>
  <a href="/v2">홈 (B팀)</a>
  <a href="/archive">아카이브</a>
  <a href="/chat" class="active">AI 챗봇</a>
  <a href="/editor">에디터</a>
</nav>

<div class="chat-wrap">
  <h1>한울사상 AI 안내자</h1>
  <p class="desc">여의선원 경전 871 청크 기반 · 질문하시면 관련 구절을 찾아 답변드립니다</p>

  <div class="suggestions">
    <span class="sugg" onclick="ask(this.textContent)">한울이란 무엇인가요?</span>
    <span class="sugg" onclick="ask(this.textContent)">수행의 목적은 무엇인가요?</span>
    <span class="sugg" onclick="ask(this.textContent)">여의명상의 핵심 가르침은?</span>
    <span class="sugg" onclick="ask(this.textContent)">마음을 다스리는 방법</span>
  </div>

  <div class="messages" id="messages">
    <div class="msg bot">
      <div class="avatar">☯</div>
      <div class="bubble">안녕하세요. 저는 한울사상 AI 안내자입니다.<br>여의선원의 가르침과 관련된 질문을 자유롭게 해주세요.</div>
    </div>
  </div>

  <div class="input-area">
    <input type="text" id="q" placeholder="질문을 입력하세요…" onkeydown="if(event.key==='Enter'&&!event.shiftKey)sendMsg()">
    <button id="send-btn" onclick="sendMsg()">전송</button>
  </div>
</div>

<script>
let busy = false;

function ask(text) {
  document.getElementById('q').value = text;
  sendMsg();
}

async function sendMsg() {
  if (busy) return;
  const q = document.getElementById('q').value.trim();
  if (!q) return;
  busy = true;
  document.getElementById('send-btn').disabled = true;
  document.getElementById('q').value = '';

  const msgs = document.getElementById('messages');
  msgs.innerHTML += `<div class="msg user"><div class="avatar">나</div><div class="bubble">${escHtml(q)}</div></div>`;

  const typingId = 'typing-' + Date.now();
  msgs.innerHTML += `<div class="msg bot" id="${typingId}"><div class="avatar">☯</div><div class="bubble typing"><span class="dot"></span><span class="dot"></span><span class="dot"></span> 찾는 중…</div></div>`;
  msgs.scrollTop = msgs.scrollHeight;

  try {
    const r = await fetch('/api/chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ question: q }),
    }).then(r => r.json());

    const el = document.getElementById(typingId);
    const srcHtml = r.sources?.length
      ? `<div class="sources">출처: ${r.sources.map(s=>`${escHtml(s.book)} (${(s.similarity*100).toFixed(1)}%)`).join(' · ')}</div>`
      : '';
    if (el) el.outerHTML = `<div class="msg bot"><div class="avatar">☯</div><div class="bubble">${escHtml(r.answer||r.error||'오류')}${srcHtml}</div></div>`;
  } catch(e) {
    const el = document.getElementById(typingId);
    if (el) el.outerHTML = `<div class="msg bot"><div class="avatar">☯</div><div class="bubble" style="color:#c00">오류: ${escHtml(e.message)}</div></div>`;
  }

  msgs.scrollTop = msgs.scrollHeight;
  busy = false;
  document.getElementById('send-btn').disabled = false;
  document.getElementById('q').focus();
}

function escHtml(s){ return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\n/g,'<br>'); }
</script>
</body>
</html>
