<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>여의선원 아카이브 — 한울사상</title>
  <meta name="description" content="여의선원 아카이브. 10,000건 이상의 한울사상 게시물, 법문, 수행 기록을 검색하고 열람할 수 있습니다."/>
  <meta property="og:title" content="여의선원 아카이브"/>
  <meta property="og:description" content="한울사상 여의선원 게시물 아카이브 — 법문, 수행 기록, 교류"/>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@300;400;500&family=Noto+Sans+KR:wght@300;400&display=swap" rel="stylesheet">
  <style>
    *{margin:0;padding:0;box-sizing:border-box}
    body{font-family:'Noto Sans KR',sans-serif;background:#F8F6F0;color:#2A1E10}
    .site-nav{position:fixed;top:0;left:0;right:0;height:44px;background:rgba(42,30,16,0.96);display:flex;align-items:center;gap:0;z-index:9999;padding:0 24px}
    .site-nav a{color:#E8DCC8;text-decoration:none;font-size:13px;padding:0 14px;height:44px;display:flex;align-items:center;font-family:'Noto Sans KR',sans-serif;letter-spacing:.5px;transition:color .2s}
    .site-nav a:hover,.site-nav a.active{color:#D4A840}
    .site-nav .logo{font-family:'Noto Serif KR',serif;font-size:15px;font-weight:500;color:#E8DCC8;margin-right:8px;border-right:1px solid rgba(255,255,255,.2);padding-right:18px}
    .page{margin-top:44px;max-width:100%;padding:30px 28px}
    h1{font-family:'Noto Serif KR',serif;font-size:22px;font-weight:400;margin-bottom:6px}
    .subtitle{font-size:13px;color:#7A6048;margin-bottom:24px}
    .layout{display:flex;gap:20px}
    .sidebar{width:200px;flex-shrink:0}
    .sidebar h3{font-size:13px;padding:8px 12px;background:#2A1E10;color:#E8DCC8;border-radius:6px 6px 0 0}
    .board-list{background:#fff;border:1px solid #DDD8C8;border-top:0;border-radius:0 0 6px 6px}
    .board-item{padding:8px 12px;font-size:13px;cursor:pointer;display:flex;justify-content:space-between;border-bottom:1px solid #F0EAD8;transition:background .15s}
    .board-item:hover{background:#F8F2E4}
    .board-item.active{background:#F0E8D4;font-weight:500;color:#7A5020}
    .board-item .cnt{color:#9A8870;font-size:11px}
    .main{flex:1;min-width:0}
    .search-bar{display:flex;gap:8px;margin-bottom:16px}
    .search-bar input{flex:1;padding:8px 12px;border:1px solid #DDD8C8;border-radius:6px;font-size:14px;background:#fff;font-family:'Noto Sans KR',sans-serif}
    .search-bar button{padding:8px 18px;background:#2A1E10;color:#E8DCC8;border:none;border-radius:6px;cursor:pointer;font-size:13px;font-family:'Noto Sans KR',sans-serif;touch-action:manipulation}
    .search-bar button:active{background:#3A2E20}
    .stats-bar{background:#fff;border:1px solid #DDD8C8;border-radius:6px;padding:10px 16px;margin-bottom:16px;display:flex;gap:24px;font-size:12px;color:#7A6048}
    .stats-bar b{color:#2A1E10}
    .post-table{width:100%;background:#fff;border:1px solid #DDD8C8;border-radius:6px;overflow:hidden}
    .post-table th{background:#F0EAD8;padding:9px 12px;text-align:left;font-size:12px;border-bottom:1px solid #DDD8C8;color:#5A4028;font-weight:500}
    .post-table td{padding:8px 12px;font-size:13px;border-bottom:1px solid #F0EAD8;vertical-align:middle}
    .post-table tr:hover td{background:#FBF7EE;cursor:pointer}
    .post-title{color:#2A1E10;text-decoration:none}
    .post-title:hover{color:#7A5020;text-decoration:underline}
    .badge-board{font-size:11px;background:#F0E8D4;color:#7A5020;padding:2px 7px;border-radius:10px}
    .pagination{display:flex;justify-content:center;gap:6px;margin-top:20px;flex-wrap:wrap}
    .pagination button{padding:5px 11px;border:1px solid #DDD8C8;background:#fff;border-radius:4px;cursor:pointer;font-size:12px;touch-action:manipulation}
    .pagination button.active{background:#2A1E10;color:#fff;border-color:#2A1E10}
    .pagination button:hover:not(.active){background:#F0EAD8}
    /* Modal */
    .modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:10000;overflow-y:auto;padding:60px 20px}
    .modal-bg.open{display:flex;align-items:flex-start;justify-content:center}
    .modal{background:#fff;width:100%;max-width:820px;border-radius:10px;overflow:hidden}
    .modal-header{padding:18px 24px;background:#2A1E10;color:#E8DCC8;display:flex;justify-content:space-between;align-items:center}
    .modal-header h2{font-family:'Noto Serif KR',serif;font-size:17px;font-weight:400}
    .modal-close{background:none;border:none;color:#E8DCC8;font-size:22px;cursor:pointer;line-height:1;min-width:44px;min-height:44px;display:flex;align-items:center;justify-content:center}
    .modal-meta{padding:12px 24px;background:#F8F6F0;font-size:12px;color:#7A6048;display:flex;gap:16px;border-bottom:1px solid #DDD8C8;flex-wrap:wrap}
    .modal-body{padding:24px;font-size:14px;line-height:1.9;max-height:60vh;overflow-y:auto}
    .modal-body img{max-width:100%;height:auto;border-radius:4px;margin:8px 0}
    .comments{padding:16px 24px;border-top:1px solid #DDD8C8}
    .comments h4{font-size:13px;font-weight:500;margin-bottom:10px;color:#5A4028}
    .comment{padding:8px 12px;background:#F8F6F0;border-radius:4px;margin-bottom:6px;font-size:12px}
    .comment .cmeta{color:#9A8870;font-size:11px;margin-bottom:3px}
    /* Mobile toggle */
    .sidebar-toggle{display:none;width:100%;padding:11px 16px;background:#2A1E10;color:#E8DCC8;border:none;border-radius:6px;font-size:13px;cursor:pointer;text-align:left;min-height:44px;font-family:'Noto Sans KR',sans-serif;margin-bottom:8px;touch-action:manipulation}
    .sidebar-toggle:active{background:#3A2E20}
    /* Post card (mobile) */
    .post-card{display:none;background:#fff;border:1px solid #DDD8C8;border-radius:8px;padding:14px 16px;margin-bottom:8px;cursor:pointer;transition:background .15s}
    .post-card:hover,.post-card:active{background:#FBF7EE}
    .post-card-title{font-size:14px;color:#2A1E10;line-height:1.5;margin-bottom:6px}
    .post-card-meta{font-size:11px;color:#9A8870;display:flex;gap:10px;flex-wrap:wrap;align-items:center}
    .post-card-meta .badge-board{font-size:11px;background:#F0E8D4;color:#7A5020;padding:2px 7px;border-radius:10px}
    /* Responsive */
    @media(max-width:768px){
      .layout{flex-direction:column;gap:12px}
      .sidebar{width:100%}
      .sidebar-toggle{display:flex;align-items:center;justify-content:space-between}
      .board-list{display:none}
      .board-list.open{display:block}
      .board-item{min-height:44px;display:flex;align-items:center;justify-content:space-between}
      .search-bar input{font-size:16px}
      .search-bar button{min-height:44px;padding:0 20px}
      .stats-bar{flex-wrap:wrap;gap:8px}
    }
    @media(max-width:640px){
      .page{padding:16px 12px}
      h1{font-size:18px}
      .post-table{display:none}
      .post-card{display:block}
      .pagination button{min-width:44px;min-height:44px;padding:0 8px}
      .modal-bg{padding:0}
      .modal{border-radius:0;min-height:100dvh}
      .modal-body{max-height:calc(100dvh - 140px)}
      .site-nav{overflow-x:auto;white-space:nowrap;padding:0 12px;scrollbar-width:none}
      .site-nav::-webkit-scrollbar{display:none}
      .site-nav a{padding:0 10px;font-size:12px;flex-shrink:0}
      .search-bar{flex-direction:column;gap:6px}
      .search-bar input,.search-bar button{width:100%;box-sizing:border-box}
      .stats-bar{display:none}
    }
    @media(max-width:480px){
      .page{padding:12px 10px}
      h1{font-size:16px}
      .subtitle{font-size:12px;margin-bottom:14px}
      .site-nav{padding:0 8px}
      .site-nav .logo{font-size:13px;padding-right:10px}
      .site-nav a:not(.logo){font-size:11px;padding:0 8px}
      .post-card-title{font-size:13px}
      .post-card{padding:12px 14px}
      .sidebar-toggle{font-size:12px;padding:9px 12px}
      .search-bar input{font-size:14px;padding:10px}
      .search-bar button{padding:10px 16px}
      .modal-header{padding:14px 16px}
      .modal-header h2{font-size:15px}
      .modal-body{padding:16px;font-size:13px}
      .comments{padding:12px 16px}
      .pagination{margin-top:14px}
      .pagination button{font-size:11px}
    }
  </style>
</head>
<body>
<nav class="site-nav">
  <a href="/" class="logo">한울사상</a>
  <a href="/">홈 (A팀)</a>
  <a href="/v2">홈 (B팀)</a>
  <a href="/archive" class="active">아카이브</a>
  <a href="/chat">AI 챗봇</a>
  <a href="/editor">에디터</a>
</nav>

<div class="page">
  <h1>여의선원 아카이브</h1>
  <p class="subtitle">한울사상 디지털 도서관 · 크롤링 수집 게시글</p>

  <div id="stats-bar" class="stats-bar">불러오는 중…</div>

  <div class="layout">
    <div class="sidebar">
      <button class="sidebar-toggle" id="sidebar-toggle" onclick="toggleSidebar()">
        <span>📋 게시판 선택</span><span id="sidebar-arrow">▼</span>
      </button>
      <h3 style="display:none" id="sidebar-heading">게시판</h3>
      <div class="board-list" id="board-list">
        <div class="board-item active" data-board="">전체 <span class="cnt"></span></div>
      </div>
    </div>
    <div class="main">
      <div class="search-bar">
        <input type="text" id="search-input" placeholder="제목·내용·작성자 검색…" onkeydown="if(event.key==='Enter')doSearch()" oninput="debounceSearch()">
        <button onclick="doSearch()">검색</button>
      </div>
      <div id="board-title" class="board-title" style="font-size:14px;font-weight:500;margin-bottom:10px;color:#5A4028"></div>
      <table class="post-table" id="post-table">
        <thead>
          <tr><th style="width:50px">번호</th><th>제목</th><th style="width:90px">게시판</th><th style="width:80px">작성자</th><th style="width:100px">날짜</th><th style="width:50px">댓글</th></tr>
        </thead>
        <tbody id="post-tbody"></tbody>
      </table>
      <div id="post-cards"></div>
      <div class="pagination" id="pagination"></div>
    </div>
  </div>
</div>

<!-- Modal -->
<div class="modal-bg" id="modal-bg" onclick="if(event.target===this)closeModal()">
  <div class="modal">
    <div class="modal-header">
      <h2 id="modal-title"></h2>
      <button class="modal-close" onclick="closeModal()">×</button>
    </div>
    <div class="modal-meta" id="modal-meta"></div>
    <div class="modal-body" id="modal-body"></div>
    <div class="comments" id="modal-comments"></div>
  </div>
</div>

<script>
let state = { board: '', page: 1, search: '' };

async function loadStats() {
  const r = await fetch('/api/stats').then(r=>r.json());
  document.getElementById('stats-bar').innerHTML =
    `총 <b>${r.totalPosts?.toLocaleString()}</b>건 게시글 &nbsp;·&nbsp; 댓글 <b>${r.totalComments?.toLocaleString()}</b>건 &nbsp;·&nbsp; 최신: <b>${r.newestPost ? new Date(r.newestPost).toLocaleDateString('ko') : '-'}</b>`;
}

async function loadBoards() {
  const boards = await fetch('/api/boards').then(r=>r.json());
  const el = document.getElementById('board-list');
  const items = boards.map(b=>`<div class="board-item" data-board="${escHtml(b.board)}">${escHtml(b.board)}<span class="cnt">${b.count}</span></div>`).join('');
  el.innerHTML = `<div class="board-item active" data-board="">전체</div>` + items;
  el.querySelectorAll('.board-item').forEach(item=>{
    item.onclick = () => {
      state.board = item.dataset.board;
      state.page = 1;
      loadPosts();
      highlightBoard();
      // 모바일: 게시판 선택 후 board-list 자동 닫기
      const bl = document.getElementById('board-list');
      const arrow = document.getElementById('sidebar-arrow');
      if (bl.classList.contains('open')) {
        bl.classList.remove('open');
        if (arrow) arrow.textContent = '▼';
      }
      // 게시판명 표시 + 게시글 목록으로 스크롤
      const titleEl = document.getElementById('board-title');
      if (titleEl) titleEl.textContent = item.dataset.board ? `📋 ${item.dataset.board}` : '';
      document.getElementById('post-table')?.scrollIntoView({behavior:'smooth', block:'start'});
    };
  });
}

function highlightBoard() {
  document.querySelectorAll('.board-item').forEach(el=>{
    el.classList.toggle('active', el.dataset.board === state.board);
  });
}

async function loadPosts() {
  const params = new URLSearchParams({ page: state.page, limit: 30 });
  if (state.board)  params.set('board', state.board);
  if (state.search) params.set('search', state.search);
  const data = await fetch('/api/posts?' + params).then(r=>r.json());
  const tbody = document.getElementById('post-tbody');
  if (!data.posts?.length) { tbody.innerHTML='<tr><td colspan="6" style="text-align:center;padding:30px;color:#9A8870">게시글이 없습니다</td></tr>'; renderPaging(0,1); return; }
  tbody.innerHTML = data.posts.map((p,i)=>`
    <tr onclick="openPost('${p.post_id}')">
      <td style="color:#9A8870;font-size:11px">${(state.page-1)*30+i+1}</td>
      <td><span class="post-title">${escHtml(p.title||'(제목없음)')}</span></td>
      <td><span class="badge-board">${escHtml(p.board||'')}</span></td>
      <td style="color:#7A6048;font-size:12px">${escHtml(p.author||'')}</td>
      <td style="color:#9A8870;font-size:11px">${p.created_at?new Date(p.created_at).toLocaleDateString('ko'):''}</td>
      <td style="color:#7A6048;font-size:12px;text-align:center">${p.comment_count||0}</td>
    </tr>`).join('');
  renderCards(data.posts);
  renderPaging(data.totalPages, data.page);
}

function renderPaging(total, cur) {
  const el = document.getElementById('pagination');
  if (total <= 1) { el.innerHTML=''; return; }
  let html = '';
  const start = Math.max(1, cur-4), end = Math.min(total, cur+4);
  if (cur > 1) html += `<button onclick="goPage(${cur-1})">‹</button>`;
  for (let i=start;i<=end;i++) html += `<button class="${i===cur?'active':''}" onclick="goPage(${i})">${i}</button>`;
  if (cur < total) html += `<button onclick="goPage(${cur+1})">›</button>`;
  el.innerHTML = html;
}

function goPage(n) { state.page = n; loadPosts(); window.scrollTo(0,0); }
function doSearch() { state.search = document.getElementById('search-input').value.trim(); state.page = 1; loadPosts(); }

let _searchTimer = null;
function debounceSearch() {
  clearTimeout(_searchTimer);
  _searchTimer = setTimeout(() => {
    const v = document.getElementById('search-input').value.trim();
    if (v.length >= 2 || v.length === 0) { state.search = v; state.page = 1; loadPosts(); }
  }, 500);
}

async function openPost(postId) {
  const data = await fetch('/api/posts/' + postId).then(r=>r.json());
  document.getElementById('modal-title').textContent = data.title || '(제목없음)';
  document.getElementById('modal-meta').innerHTML =
    `<span>게시판: <b>${escHtml(data.board||'')}</b></span><span>작성자: ${escHtml(data.author||'')}</span><span>날짜: ${data.created_at?new Date(data.created_at).toLocaleDateString('ko'):''}</span>`;

  const body = document.getElementById('modal-body');
  if (data.content_html) {
    body.innerHTML = data.content_html.replace(
      /https?:\/\/[^\s"'<>]*(pstatic\.net)[^\s"'<>]*/g,
      m => `/api/img-proxy?url=${encodeURIComponent(m)}`
    );
  } else {
    body.innerHTML = `<pre style="white-space:pre-wrap;font-size:13px">${escHtml(data.content||'(내용 없음)')}</pre>`;
  }

  const cmts = data.comments||[];
  document.getElementById('modal-comments').innerHTML = cmts.length
    ? `<h4>댓글 ${cmts.length}건</h4>` + cmts.map(c=>`<div class="comment"><div class="cmeta">${escHtml(c.author||'')} · ${c.created_at?new Date(c.created_at).toLocaleDateString('ko'):''}</div>${escHtml(c.content||'')}</div>`).join('')
    : '';

  document.getElementById('modal-bg').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeModal() { document.getElementById('modal-bg').classList.remove('open'); document.body.style.overflow=''; }
function escHtml(s){ return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

function toggleSidebar() {
  const bl = document.getElementById('board-list');
  const arrow = document.getElementById('sidebar-arrow');
  const open = bl.classList.toggle('open');
  arrow.textContent = open ? '▲' : '▼';
}

// Re-render cards for mobile
function renderCards(posts) {
  const el = document.getElementById('post-cards');
  if (!posts?.length) { el.innerHTML=''; return; }
  el.innerHTML = posts.map((p,i) => `
    <div class="post-card" onclick="openPost('${p.post_id}')">
      <div class="post-card-title">${escHtml(p.title||'(제목없음)')}</div>
      <div class="post-card-meta">
        <span class="badge-board">${escHtml(p.board||'')}</span>
        <span>${escHtml(p.author||'')}</span>
        <span>${p.created_at?new Date(p.created_at).toLocaleDateString('ko'):''}</span>
        ${p.comment_count ? `<span>💬 ${p.comment_count}</span>` : ''}
      </div>
    </div>`).join('');
}


// URL 파라미터에서 board 자동 선택
const _urlBoard = new URLSearchParams(location.search).get('board');
if (_urlBoard) state.board = _urlBoard;

loadStats();
loadBoards().then(() => {
  if (_urlBoard) highlightBoard();
});
loadPosts();
</script>
</body>
</html>
