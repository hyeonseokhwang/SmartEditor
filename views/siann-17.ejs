  <script>
    // NAV scroll
    const nav = document.getElementById('nav');
    window.addEventListener('scroll', () => {
      nav.classList.toggle('solid', window.scrollY > 60);
    }, { passive: true });

    // Language Toggle
    function toggleLang(){
      const isEn = document.body.classList.toggle('lang-en');
      const btn = document.getElementById('lang-toggle');
      btn.textContent = isEn ? 'KO' : 'EN';
      btn.classList.toggle('active', isEn);
      document.documentElement.lang = isEn ? 'en' : 'ko';
      try { localStorage.setItem('hanul-lang', isEn ? 'en' : 'ko'); } catch(e) {}
    }
    try { if(localStorage.getItem('hanul-lang') === 'en') toggleLang(); } catch(e) {}
  </script>
