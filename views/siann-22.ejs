<!-- PROGRAMS -->
<section class="programs" id="programs">
  <div class="sec-head r">
    <span class="sec-label" data-ko>수행 프로그램</span>
    <span class="sec-label" data-en>Practice Programs</span>
    <h2 class="sec-title" data-ko style="text-align:center;margin:12px auto 0">당신의 수행을 시작하세요</h2>
    <h2 class="sec-title" data-en style="text-align:center;margin:12px auto 0">Begin Your Practice</h2>
  </div>
  <div class="prog-grid">
    <div class="prog r">
      <div class="prog-bg"></div>
      <div class="prog-glyph" aria-hidden="true">入</div>
      <div class="prog-fade"></div>
      <div class="prog-body">
        <div class="prog-n">PROGRAM 01</div>
        <div class="prog-title" data-ko>생명장 수련</div>
        <div class="prog-title" data-en>Life Field Training</div>
        <div class="prog-desc" data-ko>생명장 점검·조정 수련<br>여의명상센터 정기 수련 과정</div>
        <div class="prog-desc" data-en>Life Field inspection & adjustment<br>Regular sessions at Yeoui Center</div>
      </div>
    </div>
