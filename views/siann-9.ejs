    const t = themes[themeId] || themes[1];
    const isLight = [3,5,7,12,15,19].includes(themeId);
    const IMG1 = '/api/img-proxy?url=https://cafeptthumb-phinf.pstatic.net/MjAyMDA4MjNfMjMy/MDAxNTk4MTgwNTg5MDYy.uA1NHCj3WWGQ4N4X2lBJBLv9kXIyDFNXXBP5QO0SoNIg.FBHqHZmPTrNcD7HpCaqvJX1gUV5ZllRAuMxL9h5Y3wcg.JPEG/KakaoTalk_20200823_195242797.jpg?type=w1600';
    const IMG2 = '/api/img-proxy?url=https://cafeptthumb-phinf.pstatic.net/MjAyMDA4MjRfMTA0/MDAxNTk4MjM4Mjc1ODE3.0k2BaE4ogtlYVBvHyVmHRkQb8dIvqD8i2ULhVKcVEDIg.mH8dOqWbFVT3yJPPHgtnIU8KSzP_vf2YbhLe27F7PfMg.JPEG/%ED%91%9C%EC%99%80_%ED%8F%AC.jpg?type=w1600';
    const IMG3 = '/api/img-proxy?url=https://cafeptthumb-phinf.pstatic.net/MjAyMDA4MjRfMTMx/MDAxNTk4MjQwMjI3NjQ2.hLSA_5kfuWxPRUPy2d3l9Xu6G1t7QFJNw9kXb2mS8AMg.5eZKYCnLCfuPcwJX3HQoEh3k3WHGDsMfI4V0VPK5rZEg.JPEG/%EC%9D%98%EB%A1%9C%EC%9B%80.jpg?type=w1600';
    const IMG4 = '/api/img-proxy?url=https://cafeptthumb-phinf.pstatic.net/MjAyMDA4MjVfMjY0/MDAxNTk4MzE3NjgyMTQ4.j8kFmmQFLoFT5PLxTPmYW6T0Tx9BjvDX_pPtY8XvzLYg.7b8L0Uj3lBf6Dh2lGj8LxMHwFlKbdOsT4AaYQ6aHPGYg.JPEG/%EC%B2%9C%EC%A7%80%EC%97%B0%ED%8F%AD%ED%8F%AC.jpeg?type=w1600';
    const IMG5 = '/api/img-proxy?url=https://cafeptthumb-phinf.pstatic.net/MjAyMDA4MjdfMjI4/MDAxNTk4NTA5OTI4NDU2.mh8WzPbnjU9WBrHi-Gq8F2FRitnzLDMpPcC38w4U1Pcg.R6T4a3m4U8yVqFQlYZHpOqT3J0oKW_-2yEIQh_GZ8Pkg.JPEG/1.jpg?type=w1600';
    const IMG6 = '/api/img-proxy?url=https://cafeptthumb-phinf.pstatic.net/MjAyMDA4MjdfMTE2/MDAxNTk4NTEwMDE1OTU3.hVOK14ZImOyDTiH_nrJCTlKN3U7JgQDrVsw_jCjQ5H8g.tKV1w5uifEyRuvNIf1k_6CDzRHBQw7VPxEJAy2hA0osg.JPEG/2.jpg?type=w1600';
    %>
    :root{--bg:<%= t.bg %>;--deep:<%= t.deep %>;--mid:<%= t.mid %>;--card:<%= t.card %>;--accent:<%= t.accent %>;--accentLt:<%= t.accentLt %>;--text:<%= t.text %>;--text2:<%= t.text2 %>;--gray:<%= t.gray %>;--footerBg:<%= t.footerBg %>;--border:<%= t.border %>;}
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
    html,body{width:100%;min-height:100vh;background:var(--bg);color:var(--text);font-family:'Noto Sans KR',sans-serif;overflow-x:hidden;}
    .gh{position:fixed;top:0;left:0;right:0;z-index:100;height:64px;display:flex;align-items:center;justify-content:space-between;padding:0 40px;background:var(--bg);border-bottom:1px solid var(--border);}
    .gh-logo{font-family:'Noto Serif KR',serif;font-size:1.2rem;font-weight:600;color:var(--accent);text-decoration:none;}
    .gh-nav{display:flex;gap:8px;}
    .gnb{padding:6px 18px;border:1px solid var(--border);border-radius:100px;color:var(--text2);font-size:.8rem;font-weight:300;background:transparent;cursor:pointer;transition:all .2s;}
    .gnb:hover,.gnb.on{background:var(--accent);color:var(--bg);border-color:var(--accent);}
    .gh-cta{background:var(--accent);color:var(--bg);padding:9px 22px;border-radius:100px;font-size:.82rem;font-weight:500;text-decoration:none;}
    .hstrip{margin-top:64px;display:grid;grid-template-columns:2fr 1fr 1fr;grid-template-rows:480px;gap:3px;}
    .hs-m,.hs-i{position:relative;overflow:hidden;}
    .hs-c{display:grid;grid-template-rows:1fr 1fr;gap:3px;}
    .hs-m img,.hs-i img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .6s;}
    .hs-m:hover img,.hs-i:hover img{transform:scale(1.05);}
    .ov-lg{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.75) 0%,rgba(0,0,0,.1) 50%,transparent 100%);display:flex;flex-direction:column;justify-content:flex-end;padding:32px;}
    .ov-sm{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.7) 0%,transparent 60%);display:flex;flex-direction:column;justify-content:flex-end;padding:20px;}
    .ov-tag{display:inline-block;background:var(--accent);color:var(--bg);padding:4px 12px;font-size:.7rem;font-weight:600;letter-spacing:.06em;margin-bottom:12px;border-radius:2px;}
    .ov-h{font-family:'Noto Serif KR',serif;font-size:1.6rem;font-weight:500;color:#fff;line-height:1.35;margin-bottom:8px;}
    .ov-p{font-size:.84rem;color:rgba(255,255,255,.8);font-weight:300;line-height:1.6;}
    .ov-hs{font-family:'Noto Serif KR',serif;font-size:.95rem;font-weight:500;color:#fff;line-height:1.4;}
    .ov-ss{font-size:.76rem;color:rgba(255,255,255,.7);font-weight:300;margin-top:4px;}
    .gal-sec{padding:80px 40px;}
    .gal-hdr{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:48px;}
    .glbl{font-size:.72rem;letter-spacing:.22em;text-transform:uppercase;color:var(--accent);margin-bottom:12px;}
    .gal-h{font-family:'Noto Serif KR',serif;font-size:clamp(1.5rem,3vw,2.2rem);font-weight:400;color:var(--text);line-height:1.4;}
    .gal-meta{font-size:.84rem;color:var(--gray);font-weight:300;text-align:right;}
    .mgrid{display:grid;grid-template-columns:repeat(3,1fr);grid-auto-rows:260px;gap:4px;}
    .mgi{position:relative;overflow:hidden;}
    .mgi.tall{grid-row:span 2;}
    .mgi.wide{grid-column:span 2;}
    .mgi img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .5s;}
    .mgi:hover img{transform:scale(1.07);}
    .mgi-ov{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.72) 0%,transparent 55%);opacity:0;transition:opacity .3s;display:flex;flex-direction:column;justify-content:flex-end;padding:24px;}
    .mgi:hover .mgi-ov{opacity:1;}
    .mgi-h{font-family:'Noto Serif KR',serif;font-size:1rem;font-weight:500;color:#fff;margin-bottom:6px;}
    .mgi-p{font-size:.78rem;color:rgba(255,255,255,.8);font-weight:300;line-height:1.5;}
    .feat{position:relative;height:560px;overflow:hidden;margin:0 0 4px;}
    .feat img{width:100%;height:100%;object-fit:cover;display:block;}
    .feat-ov{position:absolute;inset:0;background:linear-gradient(135deg,rgba(0,0,0,.65) 0%,transparent 60%);display:flex;align-items:center;padding:80px;}
    .feat-t{max-width:540px;}
    .feat-lbl{font-size:.72rem;letter-spacing:.22em;text-transform:uppercase;color:var(--accent);margin-bottom:16px;}
    .feat-h{font-family:'Noto Serif KR',serif;font-size:clamp(1.8rem,4vw,3rem);font-weight:300;color:#fff;line-height:1.35;margin-bottom:20px;}
    .feat-p{font-size:.95rem;font-weight:300;color:rgba(255,255,255,.85);line-height:1.8;margin-bottom:28px;}
    .feat-btn{display:inline-block;padding:12px 28px;border:1px solid rgba(255,255,255,.5);color:#fff;font-size:.84rem;font-weight:300;text-decoration:none;border-radius:100px;transition:all .2s;}
    .feat-btn:hover{background:var(--accent);border-color:var(--accent);}
    .r2g{display:grid;grid-template-columns:repeat(4,1fr);gap:4px;height:320px;}
    .r2i{position:relative;overflow:hidden;}
    .r2i img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .5s;}
    .r2i:hover img{transform:scale(1.06);}
    .r2-ov{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.7) 0%,transparent 60%);display:flex;flex-direction:column;justify-content:flex-end;padding:20px;}
    .r2-t{font-family:'Noto Serif KR',serif;font-size:.9rem;font-weight:500;color:#fff;line-height:1.4;}
    .r2-m{font-size:.72rem;color:rgba(255,255,255,.65);margin-top:4px;}
    .qband{padding:80px 40px;background:var(--deep);text-align:center;}
    .qmark{font-family:'Noto Serif KR',serif;font-size:5rem;line-height:.8;color:var(--accent);opacity:.25;display:block;margin-bottom:24px;}
    .qtext{font-family:'Noto Serif KR',serif;font-size:clamp(1.2rem,2.5vw,1.8rem);font-weight:300;color:var(--text);line-height:1.8;max-width:680px;margin:0 auto 20px;}
    .qsrc{font-size:.8rem;color:var(--gray);letter-spacing:.1em;}
    .csec{padding:80px 40px;background:var(--mid);}
    .cs-in{max-width:1000px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center;}
    .cs-lbl{font-size:.72rem;letter-spacing:.22em;text-transform:uppercase;color:var(--accent);margin-bottom:12px;}
    .cs-h{font-family:'Noto Serif KR',serif;font-size:clamp(1.5rem,2.8vw,2.2rem);font-weight:400;color:var(--text);margin:16px 0 24px;line-height:1.5;}
    .cs-p{font-size:.92rem;font-weight:300;color:var(--text2);line-height:1.9;margin-bottom:32px;}
    .cs-row{display:flex;gap:12px;flex-wrap:wrap;}
    .bp{background:var(--accent);color:var(--bg);padding:13px 32px;border-radius:100px;font-size:.88rem;font-weight:500;text-decoration:none;transition:all .2s;}
    .bp:hover{background:var(--accentLt);transform:translateY(-1px);}
    .bs{border:1px solid var(--border);color:var(--text2);padding:13px 32px;border-radius:100px;font-size:.88rem;font-weight:300;text-decoration:none;background:var(--card);transition:all .2s;}
    .bs:hover{border-color:var(--accent);color:var(--accent);}
    .cs-img img{width:100%;aspect-ratio:4/3;object-fit:cover;display:block;}
    footer{background:var(--footerBg);border-top:1px solid var(--border);padding:60px 48px 40px;}
    .fi{max-width:1100px;margin:0 auto;}
    .ft{display:grid;grid-template-columns:1.5fr 1fr 1fr 1fr;gap:48px;margin-bottom:48px;}
    .fb .flogo{font-family:'Noto Serif KR',serif;font-size:1.2rem;font-weight:600;color:var(--accent);margin-bottom:14px;display:block;}
    .fb p{font-size:.82rem;font-weight:300;color:var(--gray);line-height:1.7;}
    .fcol h4{font-size:.75rem;letter-spacing:.14em;text-transform:uppercase;color:var(--accent);margin-bottom:18px;font-weight:500;}
    .fcol ul{list-style:none;display:flex;flex-direction:column;gap:10px;}
    .fcol li a{color:var(--gray);font-size:.83rem;font-weight:300;text-decoration:none;transition:color .2s;}
    .fcol li a:hover{color:var(--text);}
    .fb2{border-top:1px solid var(--border);padding-top:24px;display:flex;align-items:center;justify-content:space-between;}
    .fcopy{font-size:.78rem;color:var(--gray);font-weight:300;}
    .siann-badge{position:fixed;bottom:24px;right:24px;z-index:9999;background:rgba(0,0,0,.82);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,.12);border-radius:10px;padding:10px 14px;font-size:.72rem;color:rgba(255,255,255,.7);font-family:'Noto Sans KR',sans-serif;max-width:300px;line-height:1.5;}
    .b-row1{margin-bottom:6px;}
    .b-row1 span{color:var(--accent);font-weight:600;}
    .b-row2{display:flex;flex-wrap:wrap;gap:3px;}
    .b-row2 a{display:inline-block;width:20px;height:20px;line-height:20px;text-align:center;border-radius:4px;text-decoration:none;font-size:.66rem;color:rgba(255,255,255,.5);background:rgba(255,255,255,.06);transition:all .15s;}
    .b-row2 a:hover{background:var(--accent);color:#000;}
    .b-row2 a.cur{background:var(--accent);color:#000;font-weight:700;}
    @media(max-width:900px){.gh-nav{display:none;}.hstrip{grid-template-columns:1fr 1fr;grid-template-rows:320px 200px;}.hs-m{grid-column:span 2;}.mgrid{grid-template-columns:1fr 1fr;grid-auto-rows:220px;}.mgi.wide{grid-column:span 2;}.r2g{grid-template-columns:1fr 1fr;height:auto;}.r2i img{height:220px;}.cs-in{grid-template-columns:1fr;}.ft{grid-template-columns:1fr 1fr;}}
    @media(max-width:600px){.hstrip{grid-template-columns:1fr;height:auto;}.hs-m{grid-column:auto;height:300px;}.hs-i{height:200px;}.mgrid{grid-template-columns:1fr;}.mgi.tall,.mgi.wide{grid-row:auto;grid-column:auto;}.r2g{grid-template-columns:1fr;}.feat-ov{padding:40px 24px;}.ft{grid-template-columns:1fr;}}
  </style>
</head>
<body>

<header class="gh">
  <a class="gh-logo" href="#">한울사상</a>
  <nav class="gh-nav">
    <button class="gnb on" type="button">전체</button>
    <button class="gnb" type="button">자연</button>
    <button class="gnb" type="button">공동체</button>
    <button class="gnb" type="button">수련</button>
    <button class="gnb" type="button">행사</button>
  </nav>
  <a class="gh-cta" href="#">입문 안내</a>
</header>

<div class="hstrip">
  <div class="hs-m">
    <img src="<%= IMG4 %>" alt="천지연폭포" />
    <div class="ov-lg">
      <span class="ov-tag">자연</span>
      <h2 class="ov-h">천지연의 품에서<br>한울의 소리를 듣다</h2>
      <p class="ov-p">하늘과 땅이 만나는 곳에서 우리는 한울의 이치를 깨닫습니다.</p>
    </div>
  </div>
  <div class="hs-c">
    <div class="hs-i"><img src="<%= IMG1 %>" alt="한울 공동체" /><div class="ov-sm"><div class="ov-hs">한울 공동체의 만남</div><div class="ov-ss">2020 · 공동체</div></div></div>
