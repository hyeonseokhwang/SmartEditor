      19: { name:'Morning Fog',     bg:'#F4F4F2', deep:'#EAEAE6', mid:'#E0E0DA', card:'#FFFFFF', accent:'#5C7868', accentLt:'#7C9888', accentDk:'#3C5848', text:'#161814', text2:'#343830', gray:'#8C9890', footerBg:'#D0D4CE', border:'rgba(92,120,104,0.18)' },
