  <% for(let i=1;i<=20;i++){ %>
    <a href="/siann-12/<%= i %>" class="<%= themeId==i?'active':'' %>">T<%= i %></a>
  <% } %>
</nav>

<!-- NAVBAR -->
<nav class="navbar">
  <div class="navbar-brand">한울사상</div>
  <div class="navbar-links">
    <a href="#">한울이란</a>
    <a href="#">가르침</a>
    <a href="#">수련 프로그램</a>
    <a href="#">법문 아카이브</a>
    <a href="#">여의명상센터</a>
