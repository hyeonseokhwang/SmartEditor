      8:  { name:'Stone Mountain',  bg:'#141414', deep:'#1C1C1C', mid:'#242424', card:'#1A1A1A', accent:'#A0A8B0', accentLt:'#C0C8D0', accentDk:'#6A7280', text:'#E8EAEC', text2:'#B8BCC4', gray:'#6A7280', footerBg:'#080808', border:'rgba(160,168,176,0.18)' },
      9:  { name:'Deep Teal',       bg:'#061518', deep:'#091E22', mid:'#0E282E', card:'#0A1E24', accent:'#3DB8C4', accentLt:'#65CED8', accentDk:'#228898', text:'#E0F4F6', text2:'#B8E4E8', gray:'#5A8A90', footerBg:'#030B0D', border:'rgba(61,184,196,0.18)' },
      10: { name:'Warm Amber',      bg:'#1A0E00', deep:'#221400', mid:'#2C1C00', card:'#221400', accent:'#E8A020', accentLt:'#F0BE50', accentDk:'#A86E00', text:'#FFF0D0', text2:'#E8D4A8', gray:'#907848', footerBg:'#0D0700', border:'rgba(232,160,32,0.18)' },
      11: { name:'Ocean Night',     bg:'#020C1B', deep:'#031628', mid:'#042035', card:'#041828', accent:'#4A9ECC', accentLt:'#72BEE4', accentDk:'#2A6E9C', text:'#E0EEFF', text2:'#B0CCEE', gray:'#4A6A88', footerBg:'#01060E', border:'rgba(74,158,204,0.18)' },
      12: { name:'Warm Sand',       bg:'#F7F0E4', deep:'#EDE4D4', mid:'#E4D8C4', card:'#FFFDF8', accent:'#8B6840', accentLt:'#A88058', accentDk:'#6A4A28', text:'#2C2018', text2:'#4A3828', gray:'#8A7860', footerBg:'#1C1408', border:'rgba(139,104,64,0.18)' },
      13: { name:'Moss Green',      bg:'#0A1208', deep:'#101A0E', mid:'#162014', card:'#0E1A0C', accent:'#8AB84A', accentLt:'#A8D468', accentDk:'#5A8028', text:'#E4F0D8', text2:'#C0D8A8', gray:'#6A8850', footerBg:'#050804', border:'rgba(138,184,74,0.18)' },
      14: { name:'Midnight Indigo', bg:'#070A1F', deep:'#0C1030', mid:'#121840', card:'#0E1438', accent:'#7B8ED4', accentLt:'#9AAAE8', accentDk:'#4A60A8', text:'#E8EAFF', text2:'#C0C8F0', gray:'#5A6898', footerBg:'#03040F', border:'rgba(123,142,212,0.18)' },
      15: { name:'Parchment',       bg:'#F4EDD8', deep:'#EDE4C8', mid:'#E4D8B8', card:'#FBF6E8', accent:'#6B4C22', accentLt:'#8B6C3A', accentDk:'#4A3010', text:'#2A1C08', text2:'#4A3420', gray:'#7A6040', footerBg:'#1A1005', border:'rgba(107,76,34,0.18)' },
      16: { name:'Rose Quartz',     bg:'#1A0C10', deep:'#240F15', mid:'#2E141C', card:'#1E0E14', accent:'#D4849A', accentLt:'#E8A8BE', accentDk:'#9A5068', text:'#FFE8F0', text2:'#E8C4D4', gray:'#907080', footerBg:'#0D0608', border:'rgba(212,132,154,0.18)' },
      17: { name:'Obsidian',        bg:'#050505', deep:'#0A0A0A', mid:'#111111', card:'#080808', accent:'#D4A840', accentLt:'#E8C460', accentDk:'#9A7A20', text:'#F0EEE8', text2:'#C8C4B8', gray:'#6A6860', footerBg:'#020202', border:'rgba(212,168,64,0.18)' },
      18: { name:'Celadon',         bg:'#0A1618', deep:'#0E1E22', mid:'#14282E', card:'#0E1E24', accent:'#78B4AA', accentLt:'#98D0C4', accentDk:'#4A8880', text:'#E4F2F0', text2:'#C0DCDA', gray:'#5A8880', footerBg:'#05080A', border:'rgba(120,180,170,0.18)' },
      19: { name:'Winter White',    bg:'#F4F6FA', deep:'#EAEEf4', mid:'#E0E6F0', card:'#FFFFFF', accent:'#3A5C8C', accentLt:'#5A80B4', accentDk:'#1A3C6C', text:'#1A2440', text2:'#3A4C6C', gray:'#7A8CAA', footerBg:'#1A2440', border:'rgba(58,92,140,0.15)' },
      20: { name:'Copper Age',      bg:'#12080A', deep:'#1C0E10', mid:'#281618', card:'#1A0E10', accent:'#C47848', accentLt:'#DC9860', accentDk:'#8A5028', text:'#F5E8DC', text2:'#D8C4B4', gray:'#8A6858', footerBg:'#080408', border:'rgba(196,120,72,0.18)' },
    };
    const t = themes[themeId] || themes[1];
    const isLight = [3,5,7,12,15,19].includes(themeId);
    %>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: <%= t.bg %>; --deep: <%= t.deep %>; --mid: <%= t.mid %>; --card: <%= t.card %>;
      --accent: <%= t.accent %>; --accentLt: <%= t.accentLt %>; --accentDk: <%= t.accentDk %>;
      --text: <%= t.text %>; --text2: <%= t.text2 %>; --gray: <%= t.gray %>;
      --border: <%= t.border %>; --footerBg: <%= t.footerBg %>;
    }
    html { scroll-behavior: smooth; }
    body { font-family: 'Noto Sans KR', sans-serif; background: var(--bg); color: var(--text); }

    /* 시안 배지 */
    .siann-badge { position: fixed; top: 12px; right: 12px; z-index: 9999; display: flex; flex-wrap: wrap; gap: 4px; max-width: 420px; justify-content: flex-end; }
    .siann-badge a { display: inline-block; padding: 3px 7px; font-size: 10px; border-radius: 3px; background: var(--card); color: var(--accent); border: 1px solid var(--border); text-decoration: none; transition: all 0.2s; }
    .siann-badge a:hover, .siann-badge a.active { background: var(--accent); color: var(--bg); }

    /* ── SAAS NAVBAR ── */
    .navbar {
      position: sticky; top: 0; z-index: 100;
      background: var(--deep);
      border-bottom: 1px solid var(--border);
      padding: 0 60px;
      display: flex; align-items: center; justify-content: space-between;
      height: 64px;
    }
    .navbar-brand { font-family: 'Noto Serif KR', serif; font-size: 1.3rem; color: var(--accent); font-weight: 700; }
    .navbar-links { display: flex; gap: 32px; }
    .navbar-links a { font-size: 0.88rem; color: var(--text2); text-decoration: none; transition: color 0.2s; }
    .navbar-links a:hover { color: var(--accent); }
    .navbar-cta { background: var(--accent); color: var(--bg); padding: 8px 20px; border-radius: 6px; font-size: 0.88rem; font-weight: 600; text-decoration: none; }

    /* ── HERO ── */
    .hero { padding: 100px 60px 80px; display: flex; align-items: center; gap: 80px; max-width: 1200px; margin: 0 auto; }
    .hero-text { flex: 1; }
    .hero-badge { display: inline-block; background: var(--mid); border: 1px solid var(--border); color: var(--accentLt); font-size: 0.78rem; padding: 4px 12px; border-radius: 20px; margin-bottom: 24px; letter-spacing: 1px; }
    .hero h1 { font-family: 'Noto Serif KR', serif; font-size: clamp(2.5rem,5vw,4rem); font-weight: 700; line-height: 1.2; color: var(--text); margin-bottom: 20px; }
    .hero h1 em { color: var(--accent); font-style: normal; }
    .hero p { font-size: 1.1rem; color: var(--text2); line-height: 1.8; margin-bottom: 36px; max-width: 520px; }
    .hero-actions { display: flex; gap: 16px; flex-wrap: wrap; }
    .btn-primary { background: var(--accent); color: var(--bg); padding: 14px 32px; border-radius: 8px; font-size: 1rem; font-weight: 600; text-decoration: none; border: none; cursor: pointer; }
    .btn-outline { background: transparent; color: var(--accent); padding: 14px 32px; border-radius: 8px; font-size: 1rem; font-weight: 600; text-decoration: none; border: 2px solid var(--accent); }
    .hero-visual { flex: 1; max-width: 500px; }
    .hero-visual img { width: 100%; border-radius: 12px; box-shadow: 0 40px 80px rgba(0,0,0,0.4); }

    /* ── STATS BAR ── */
    .stats-bar { background: var(--mid); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); padding: 32px 60px; }
    .stats-row { display: flex; justify-content: space-around; max-width: 1000px; margin: 0 auto; }
    .stat-item { text-align: center; }
    .stat-item .n { font-size: 2rem; font-weight: 700; color: var(--accent); }
    .stat-item .l { font-size: 0.82rem; color: var(--text2); margin-top: 4px; }

    /* ── FEATURE ROWS ── */
    .features { max-width: 1200px; margin: 0 auto; padding: 80px 60px; }
    .feature-row { display: flex; align-items: center; gap: 80px; margin-bottom: 100px; }
    .feature-row.reverse { flex-direction: row-reverse; }
    .feature-content { flex: 1; }
    .feature-tag { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 3px; color: var(--accentLt); margin-bottom: 12px; }
    .feature-content h2 { font-family: 'Noto Serif KR', serif; font-size: clamp(1.8rem,3vw,2.5rem); color: var(--text); margin-bottom: 16px; line-height: 1.3; }
    .feature-content p { font-size: 1rem; color: var(--text2); line-height: 1.9; margin-bottom: 24px; }
    .feature-list { list-style: none; }
    .feature-list li { padding: 8px 0; color: var(--text2); font-size: 0.92rem; display: flex; align-items: flex-start; gap: 10px; }
    .feature-list li::before { content: '✦'; color: var(--accent); flex-shrink: 0; margin-top: 2px; }
    .feature-img { flex: 1; max-width: 480px; }
    .feature-img img { width: 100%; border-radius: 8px; }
    .feature-img-box { background: var(--card); border-radius: 8px; padding: 40px; border: 1px solid var(--border); display: flex; flex-direction: column; gap: 16px; }
    .teaching-card { background: var(--deep); border-radius: 6px; padding: 20px; border-left: 3px solid var(--accent); }
    .teaching-card h4 { font-family: 'Noto Serif KR', serif; color: var(--accent); font-size: 1rem; margin-bottom: 6px; }
    .teaching-card p { font-size: 0.85rem; color: var(--text2); line-height: 1.6; }

    /* ── TESTIMONIAL / QUOTE SECTION ── */
    .quote-section { background: var(--deep); padding: 80px 60px; text-align: center; }
    .quote-section .eyebrow { font-size: 0.78rem; text-transform: uppercase; letter-spacing: 3px; color: var(--gray); margin-bottom: 40px; }
    .quotes-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; max-width: 1100px; margin: 0 auto; }
    .quote-card { background: var(--card); border-radius: 8px; padding: 32px; text-align: left; border-top: 3px solid var(--accent); }
    .quote-card blockquote { font-family: 'Noto Serif KR', serif; font-size: 1rem; color: var(--text); line-height: 1.8; margin-bottom: 20px; }
    .quote-card cite { font-size: 0.82rem; color: var(--gray); }

    /* ── PROGRAM CTA SECTION ── */
    .programs-section { padding: 80px 60px; max-width: 1200px; margin: 0 auto; }
    .section-header { text-align: center; margin-bottom: 60px; }
    .section-header .eyebrow { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 3px; color: var(--accentLt); margin-bottom: 12px; }
    .section-header h2 { font-family: 'Noto Serif KR', serif; font-size: clamp(1.8rem,3vw,2.5rem); color: var(--text); }
    .programs-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
    .prog-card { background: var(--card); border-radius: 8px; overflow: hidden; border: 1px solid var(--border); transition: transform 0.2s, box-shadow 0.2s; }
    .prog-card:hover { transform: translateY(-4px); box-shadow: 0 20px 40px rgba(0,0,0,0.3); }
    .prog-card-head { background: var(--deep); padding: 24px; }
    .prog-icon { width: 48px; height: 48px; background: var(--mid); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.4rem; margin-bottom: 12px; }
    .prog-card-head h3 { font-family: 'Noto Serif KR', serif; font-size: 1.1rem; color: var(--accent); }
    .prog-card-body { padding: 20px 24px 24px; }
    .prog-card-body p { font-size: 0.88rem; color: var(--text2); line-height: 1.7; margin-bottom: 16px; }
    .prog-badge { display: inline-block; background: var(--mid); color: var(--accentLt); font-size: 0.72rem; padding: 3px 10px; border-radius: 20px; }

    /* ── FINAL CTA ── */
    .final-cta { background: linear-gradient(135deg, var(--deep), var(--mid)); padding: 100px 60px; text-align: center; }
    .final-cta h2 { font-family: 'Noto Serif KR', serif; font-size: clamp(2rem,4vw,3rem); color: var(--text); margin-bottom: 20px; }
    .final-cta p { font-size: 1.05rem; color: var(--text2); margin-bottom: 40px; max-width: 600px; margin-left: auto; margin-right: auto; }
    .final-cta-actions { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }

    /* 푸터 */
    footer { background: var(--footerBg); padding: 60px; border-top: 1px solid var(--border); }
    .footer-inner { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 60px; }
    .footer-brand h3 { font-family: 'Noto Serif KR', serif; font-size: 1.3rem; color: var(--accent); margin-bottom: 12px; }
    .footer-brand p { font-size: 0.85rem; color: var(--gray); line-height: 1.7; }
    .footer-col h4 { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 2px; color: var(--accentLt); margin-bottom: 16px; }
    .footer-col a { display: block; font-size: 0.85rem; color: var(--text2); text-decoration: none; margin-bottom: 8px; }
    .footer-col a:hover { color: var(--accent); }
    .footer-bottom { max-width: 1200px; margin: 40px auto 0; padding-top: 24px; border-top: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; font-size: 0.78rem; color: var(--gray); }
  </style>
</head>
<body>

