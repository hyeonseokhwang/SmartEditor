<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>한울사상 — 하늘의 뜻으로 사는 삶</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@300;400;500;600;700&family=Noto+Sans+KR:wght@300;400;500;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --navy:      #080D1A;
      --deep:      #0C1828;
      --mid:       #122035;
      --card:      #0F1D30;
      --gold:      #C9A84C;
      --gold-lt:   #E3C76B;
      --gold-dk:   #8A6E2E;
      --cream:     #F5EFE0;
      --cream-2:   #D6CEBB;
      --gray:      #7A8FAA;
      --border:    rgba(201,168,76,0.18);
      --serif:     'Noto Serif KR', 'Malgun Gothic', serif;
      --sans:      'Noto Sans KR', 'Malgun Gothic', sans-serif;
    }

    html { scroll-behavior: smooth; }
    body { font-family: var(--sans); background: var(--navy); color: var(--cream); overflow-x: hidden; }

    /* ── NAV ───────────────────────────────── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 200;
      display: flex; align-items: center; justify-content: space-between;
      padding: 18px 64px;
      background: linear-gradient(180deg, rgba(8,13,26,0.98) 0%, rgba(8,13,26,0.0) 100%);
      transition: background 0.4s, box-shadow 0.4s;
    }
    nav.pinned {
      background: rgba(8,13,26,0.97);
      box-shadow: 0 1px 0 var(--border);
    }
    .nav-logo {
      font-family: var(--serif); font-size: 20px; font-weight: 600;
      color: var(--gold); letter-spacing: 0.06em; text-decoration: none;
    }
    .nav-logo span { color: var(--cream); }
    .nav-menu { display: flex; gap: 36px; list-style: none; }
    .nav-menu a {
      font-size: 13px; font-weight: 400; letter-spacing: 0.07em;
      color: var(--cream-2); text-decoration: none; transition: color 0.2s;
    }
    .nav-menu a:hover { color: var(--gold); }
    .nav-cta {
      padding: 9px 22px; border: 1px solid var(--gold); border-radius: 2px;
      font-size: 12px; font-weight: 500; letter-spacing: 0.09em;
      color: var(--gold); background: transparent; text-decoration: none;
      transition: all 0.22s;
    }
    .nav-cta:hover { background: var(--gold); color: var(--navy); }

    /* ── HERO ──────────────────────────────── */
    .hero {
      position: relative; min-height: 100vh;
      display: flex; align-items: center; justify-content: center;
      overflow: hidden;
      background: radial-gradient(ellipse 80% 60% at 50% 35%, #152444 0%, #080D1A 65%);
    }
    .stars {
      position: absolute; inset: 0; pointer-events: none;
      background-image:
        radial-gradient(1.5px 1.5px at 8%  18%, rgba(255,255,255,.55) 0%, transparent 100%),
        radial-gradient(1px   1px   at 18% 72%, rgba(255,255,255,.35) 0%, transparent 100%),
        radial-gradient(1px   1px   at 28% 10%, rgba(255,255,255,.50) 0%, transparent 100%),
        radial-gradient(2px   2px   at 42% 58%, rgba(201,168,76,.30)  0%, transparent 100%),
        radial-gradient(1px   1px   at 55% 25%, rgba(255,255,255,.45) 0%, transparent 100%),
        radial-gradient(1px   1px   at 63% 80%, rgba(255,255,255,.30) 0%, transparent 100%),
        radial-gradient(1.5px 1.5px at 75% 12%, rgba(255,255,255,.60) 0%, transparent 100%),
        radial-gradient(1px   1px   at 82% 45%, rgba(255,255,255,.40) 0%, transparent 100%),
        radial-gradient(2px   2px   at 90% 68%, rgba(201,168,76,.25)  0%, transparent 100%),
        radial-gradient(1px   1px   at 95% 30%, rgba(255,255,255,.35) 0%, transparent 100%);
    }
    .mandala {
      position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
      width: 900px; height: 900px; pointer-events: none;
    }
    .mandala svg { width: 100%; height: 100%; animation: mandalaSpin 120s linear infinite; }
    @keyframes mandalaSpin { to { transform: rotate(360deg); } }

    .hero-inner { position: relative; z-index: 2; text-align: center; padding: 0 24px; }
    .eyebrow {
      display: inline-block;
      font-size: 11px; font-weight: 500; letter-spacing: 0.45em; text-transform: uppercase;
      color: var(--gold); margin-bottom: 32px;
      opacity: 0; animation: fadeUp .9s ease .2s forwards;
    }
    .hero-title {
      font-family: var(--serif);
      font-size: clamp(48px, 8vw, 96px); font-weight: 600;
      color: var(--cream); line-height: 1.08; letter-spacing: -0.01em;
      margin-bottom: 28px;
      opacity: 0; animation: fadeUp .9s ease .4s forwards;
    }
    .hero-title em { font-style: normal; color: var(--gold); }
    .hero-sub {
      font-family: var(--serif);
      font-size: clamp(15px, 2vw, 19px); font-weight: 300;
      color: var(--cream-2); line-height: 1.95; max-width: 560px; margin: 0 auto 52px;
      opacity: 0; animation: fadeUp .9s ease .6s forwards;
    }
    .hero-btns {
      display: flex; gap: 14px; justify-content: center; flex-wrap: wrap;
      opacity: 0; animation: fadeUp .9s ease .8s forwards;
    }
    .btn-fill {
      display: inline-block; padding: 15px 40px;
      background: var(--gold); color: var(--navy);
      font-family: var(--sans); font-size: 14px; font-weight: 700; letter-spacing: 0.07em;
      border-radius: 2px; text-decoration: none; transition: all .22s;
    }
    .btn-fill:hover { background: var(--gold-lt); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(201,168,76,.3); }
    .btn-line {
      display: inline-block; padding: 15px 40px;
      border: 1px solid rgba(201,168,76,.45); color: var(--cream-2);
      font-family: var(--sans); font-size: 14px; font-weight: 400; letter-spacing: 0.07em;
      border-radius: 2px; text-decoration: none; transition: all .22s;
    }
    .btn-line:hover { border-color: var(--gold); color: var(--gold); }

    .scroll-hint {
      position: absolute; bottom: 36px; left: 50%; transform: translateX(-50%);
      display: flex; flex-direction: column; align-items: center; gap: 10px;
      opacity: 0; animation: fadeIn 1s ease 1.4s forwards;
    }
    .scroll-hint span { font-size: 10px; letter-spacing: 0.38em; color: var(--gray); text-transform: uppercase; }
    .scroll-bar { width: 1px; height: 44px; background: linear-gradient(180deg, var(--gold) 0%, transparent 100%); animation: scrollAnim 2s ease-in-out infinite; }
    @keyframes scrollAnim { 0%,100%{opacity:0;transform:scaleY(0) translateY(-100%)} 40%{opacity:1;transform:scaleY(1) translateY(0)} 80%{opacity:0;transform:scaleY(0) translateY(100%)} }
    @keyframes fadeUp { from{opacity:0;transform:translateY(22px)} to{opacity:1;transform:translateY(0)} }
    @keyframes fadeIn { to{opacity:1} }

    /* ── SECTION BASE ──────────────────────── */
    section { padding: 120px 64px; }
    .wrap { max-width: 1120px; margin: 0 auto; }
    .s-label {
      font-size: 10.5px; font-weight: 600; letter-spacing: 0.42em; text-transform: uppercase;
      color: var(--gold); margin-bottom: 18px;
    }
    .s-title {
      font-family: var(--serif);
      font-size: clamp(26px, 3.5vw, 44px); font-weight: 500;
      color: var(--cream); line-height: 1.28; margin-bottom: 20px;
    }
    .s-bar { width: 44px; height: 2px; background: var(--gold); margin-bottom: 36px; }
    .s-body {
      font-family: var(--serif); font-size: 17px; font-weight: 300;
      color: var(--cream-2); line-height: 2.0; max-width: 580px;
    }

    /* ── ABOUT (한울이란) ─────────────────── */
    .about { background: var(--deep); }
    .about-intro { max-width: 680px; margin-bottom: 72px; }
    .about-cards { display: grid; grid-template-columns: repeat(3,1fr); gap: 3px; }
    .about-card {
      background: var(--card); padding: 48px 36px 44px;
      position: relative; overflow: hidden;
      transition: transform .3s;
    }
    .about-card::after {
      content:''; position:absolute; bottom:0; left:0; right:0; height:2px;
      background: var(--gold); transform: scaleX(0); transform-origin: left; transition: transform .4s;
    }
    .about-card:hover { transform: translateY(-6px); }
    .about-card:hover::after { transform: scaleX(1); }
    .ac-hanja {
      position: absolute; top: 28px; right: 28px;
      font-family: var(--serif); font-size: 52px; font-weight: 700;
      color: rgba(201,168,76,.08); line-height: 1; pointer-events: none;
    }
    .ac-num { font-size: 11px; letter-spacing: 0.3em; color: var(--gold-dk); margin-bottom: 24px; }
    .ac-name {
      font-family: var(--serif); font-size: 24px; font-weight: 500;
      color: var(--cream); margin-bottom: 10px;
    }
    .ac-sub { font-size: 12px; letter-spacing: 0.2em; color: var(--gold); margin-bottom: 20px; }
    .ac-desc {
      font-family: var(--serif); font-size: 15px; font-weight: 300;
      color: var(--cream-2); line-height: 1.95;
    }

    /* ── TEACHINGS (핵심 가르침) ─────────── */
    .teachings { background: var(--navy); }
    .teach-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 24px; margin-top: 60px; }
    .teach-card {
      background: var(--card); padding: 44px 36px 40px;
      border: 1px solid var(--border); border-radius: 2px;
      transition: border-color .3s, transform .3s;
    }
    .teach-card:hover { border-color: rgba(201,168,76,.45); transform: translateY(-6px); }
    .t-icon {
      width: 52px; height: 52px; border-radius: 50%;
      border: 1px solid var(--gold-dk);
      display: flex; align-items: center; justify-content: center;
      font-family: var(--serif); font-size: 22px; color: var(--gold);
      margin-bottom: 24px;
    }
    .t-name {
      font-family: var(--serif); font-size: 22px; font-weight: 500;
      color: var(--cream); margin-bottom: 8px;
    }
    .t-hanja-sm { font-size: 12px; letter-spacing: 0.22em; color: var(--gold); margin-bottom: 18px; }
    .t-desc {
      font-family: var(--serif); font-size: 15px; font-weight: 300;
      color: var(--cream-2); line-height: 1.95;
    }

    /* ── QUOTES (법문 발췌) ──────────────── */
    .quotes {
      background: linear-gradient(160deg, #0C1828 0%, #142238 50%, #0C1828 100%);
      position: relative; overflow: hidden;
    }
    .quotes-bg {
      position: absolute; right: -20px; top: 50%; transform: translateY(-50%);
      font-family: var(--serif); font-size: 180px; font-weight: 700;
      color: rgba(201,168,76,.035); letter-spacing: -0.04em; pointer-events: none; white-space: nowrap;
    }
    .quotes-grid { display: grid; grid-template-columns: 1fr; gap: 56px; position: relative; z-index: 1; }
    .quote-item { max-width: 760px; }
    .q-mark {
      font-family: var(--serif); font-size: 64px; font-weight: 700;
      color: var(--gold); line-height: 0.6; margin-bottom: 16px; opacity: 0.5;
    }
    .q-text {
      font-family: var(--serif);
      font-size: clamp(18px, 2.4vw, 26px); font-weight: 400;
      color: var(--cream); line-height: 1.72; margin-bottom: 20px;
    }
    .q-attr {
      font-family: var(--serif); font-size: 13px; font-weight: 300;
      color: var(--gold); letter-spacing: 0.08em;
    }
    .q-divider { width: 40px; height: 1px; background: var(--gold-dk); margin: 40px 0; opacity: 0.5; }

    /* ── CENTER (여의명상센터) ──────────── */
    .center { background: var(--deep); }
    .center-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: start; }
    .programs { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 8px; }
    .prog-item {
      padding: 28px 24px;
      border: 1px solid var(--border);
      background: rgba(201,168,76,.025); border-radius: 2px;
      transition: border-color .3s, background .3s;
    }
    .prog-item:hover { border-color: rgba(201,168,76,.4); background: rgba(201,168,76,.05); }
    .prog-item h4 {
      font-family: var(--serif); font-size: 16px; font-weight: 500;
      color: var(--cream); margin-bottom: 8px;
    }
    .prog-item p {
      font-family: var(--serif); font-size: 13px; font-weight: 300;
      color: var(--cream-2); line-height: 1.8;
    }
    .center-symbol {
      display: flex; align-items: center; justify-content: center;
      height: 460px; position: sticky; top: 120px;
    }
    .center-symbol svg { width: 360px; height: 360px; }

    /* ── ARCHIVE (법문 아카이브) ─────────── */
    .archive { background: var(--navy); text-align: center; }
    .archive-num {
      font-family: var(--serif);
      font-size: clamp(64px, 10vw, 120px); font-weight: 700;
      color: var(--gold); line-height: 1; margin-bottom: 8px;
      opacity: 0.85;
    }
    .archive-sub {
      font-size: 12px; letter-spacing: 0.4em; color: var(--gray); text-transform: uppercase;
      margin-bottom: 40px;
    }
    .archive-desc {
      font-family: var(--serif); font-size: 18px; font-weight: 300;
      color: var(--cream-2); line-height: 1.85; max-width: 520px; margin: 0 auto 52px;
    }

    /* ── QA (챗봇) ─────────────────────────── */
    .qa-sec {
      background: radial-gradient(ellipse 70% 80% at 50% 50%, #142238 0%, #080D1A 70%);
      text-align: center; position: relative; overflow: hidden;
    }
    .qa-rings {
      position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%);
      pointer-events: none;
    }
    .qa-rings span {
      display: block; position: absolute; border-radius: 50%;
      border: 1px solid rgba(201,168,76,.07);
      transform: translate(-50%,-50%);
    }
    .qa-inner { position: relative; z-index: 2; }
    .qa-badge {
      display: inline-block; padding: 6px 16px;
      border: 1px solid rgba(201,168,76,.3); border-radius: 20px;
      font-size: 11px; letter-spacing: 0.28em; color: var(--gold-dk);
      text-transform: uppercase; margin-bottom: 28px;
    }
    .qa-title {
      font-family: var(--serif);
      font-size: clamp(24px, 3.6vw, 46px); font-weight: 500;
      color: var(--cream); line-height: 1.35; margin-bottom: 20px;
    }
    .qa-body {
      font-family: var(--serif); font-size: 17px; font-weight: 300;
      color: var(--cream-2); line-height: 1.85; max-width: 480px; margin: 0 auto 48px;
    }
    .qa-input-wrap {
      display: flex; max-width: 560px; margin: 0 auto;
      border: 1px solid rgba(201,168,76,.35); border-radius: 2px;
      overflow: hidden;
    }
    .qa-input {
      flex: 1; padding: 16px 20px;
      background: rgba(201,168,76,.04); border: none; outline: none;
      font-family: var(--serif); font-size: 15px; color: var(--cream);
    }
    .qa-input::placeholder { color: var(--gray); }
    .qa-btn {
      padding: 16px 28px;
      background: var(--gold); color: var(--navy);
      font-family: var(--sans); font-size: 13px; font-weight: 700; letter-spacing: 0.06em;
      border: none; cursor: pointer; transition: background .2s;
    }
    .qa-btn:hover { background: var(--gold-lt); }
    .qa-coming { font-size: 12px; color: var(--gray); margin-top: 16px; }

    /* ── FOOTER ─────────────────────────────── */
    footer {
      background: #030810; padding: 64px;
      border-top: 1px solid var(--border);
    }
    .ft-inner {
      max-width: 1120px; margin: 0 auto;
      display: flex; gap: 48px; justify-content: space-between; flex-wrap: wrap;
    }
    .ft-brand .logo { font-family: var(--serif); font-size: 20px; color: var(--gold); font-weight: 600; margin-bottom: 14px; }
    .ft-brand p { font-size: 13px; color: var(--gray); line-height: 1.8; max-width: 260px; }
    .ft-col h4 { font-size: 10px; letter-spacing: 0.36em; color: var(--gold); text-transform: uppercase; margin-bottom: 18px; }
    .ft-col ul { list-style: none; }
    .ft-col li { margin-bottom: 10px; }
    .ft-col a { font-size: 14px; color: var(--gray); text-decoration: none; transition: color .2s; }
    .ft-col a:hover { color: var(--cream); }
    .ft-copy {
      max-width: 1120px; margin: 40px auto 0; padding-top: 24px;
      border-top: 1px solid rgba(255,255,255,.05);
      display: flex; justify-content: space-between; flex-wrap: wrap; gap: 8px;
      font-size: 12px; color: var(--gray);
    }

    /* ── RESPONSIVE ─────────────────────────── */
    @media (max-width: 960px) {
      nav { padding: 16px 24px; }
      .nav-menu { display: none; }
      section { padding: 80px 24px; }
      .about-cards, .teach-grid, .center-grid, .programs { grid-template-columns: 1fr; }
      .center-symbol { height: auto; position: static; padding: 40px 0; }
      footer { padding: 40px 24px; }
    }
  </style>
</head>
<body>

<!-- NAV -->
<nav id="nav">
  <a href="#" class="nav-logo">한울<span>사상</span></a>
  <ul class="nav-menu">
    <li><a href="#about">한울이란</a></li>
    <li><a href="#teachings">핵심 가르침</a></li>
    <li><a href="#center">여의명상센터</a></li>
    <li><a href="#archive">법문 아카이브</a></li>
  </ul>
  <a href="http://211.104.37.65:4200" class="nav-cta" target="_blank">법문 아카이브 →</a>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="stars"></div>
  <div class="mandala">
    <svg viewBox="0 0 900 900" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="450" cy="450" r="440" stroke="rgba(201,168,76,0.06)" stroke-width="1"/>
      <circle cx="450" cy="450" r="400" stroke="rgba(201,168,76,0.08)" stroke-width="0.5"/>
      <circle cx="450" cy="450" r="360" stroke="rgba(201,168,76,0.10)" stroke-width="0.5"/>
      <circle cx="450" cy="450" r="310" stroke="rgba(201,168,76,0.12)" stroke-width="1"/>
      <circle cx="450" cy="450" r="260" stroke="rgba(201,168,76,0.16)" stroke-width="0.5"/>
      <circle cx="450" cy="450" r="210" stroke="rgba(201,168,76,0.14)" stroke-width="1"/>
      <line x1="450" y1="10"  x2="450" y2="890"  stroke="rgba(201,168,76,0.05)" stroke-width="0.5"/>
      <line x1="10"  y1="450" x2="890" y2="450"  stroke="rgba(201,168,76,0.05)" stroke-width="0.5"/>
      <line x1="137" y1="137" x2="763" y2="763"  stroke="rgba(201,168,76,0.04)" stroke-width="0.5"/>
      <line x1="763" y1="137" x2="137" y2="763"  stroke="rgba(201,168,76,0.04)" stroke-width="0.5"/>
      <g stroke="rgba(201,168,76,0.3)" stroke-width="1">
        <line x1="450" y1="12" x2="450" y2="30"/>
        <line x1="450" y1="870" x2="450" y2="888"/>
        <line x1="12" y1="450" x2="30" y2="450"/>
        <line x1="870" y1="450" x2="888" y2="450"/>
      </g>
      <text x="450" y="48"  text-anchor="middle" font-family="serif" font-size="18" fill="rgba(201,168,76,0.45)">天</text>
      <text x="450" y="878" text-anchor="middle" font-family="serif" font-size="18" fill="rgba(201,168,76,0.45)">地</text>
      <text x="34"  y="455" text-anchor="middle" font-family="serif" font-size="18" fill="rgba(201,168,76,0.45)">人</text>
      <text x="867" y="455" text-anchor="middle" font-family="serif" font-size="18" fill="rgba(201,168,76,0.45)">氣</text>
    </svg>
  </div>

  <div class="hero-inner">
    <span class="eyebrow">한울영성계발원 · 여의명상센터</span>
    <h1 class="hero-title">한울사상<br><em>하늘의 뜻으로</em> 사는 삶</h1>
    <p class="hero-sub">
      수도자 1인은 세상자 만인이요<br>
      중생자 억이라
    </p>
    <div class="hero-btns">
      <a href="http://211.104.37.65:4200" class="btn-fill" target="_blank">법문 아카이브 보기</a>
      <a href="#about" class="btn-line">한울사상이란</a>
    </div>
  </div>

  <div class="scroll-hint">
    <span>scroll</span>
    <div class="scroll-bar"></div>
  </div>
</section>

<!-- ABOUT: 한울이란 -->
<section class="about" id="about">
  <div class="wrap">
    <div class="about-intro">
      <p class="s-label">한울이란</p>
      <h2 class="s-title">한울(韓蔚)은 하늘의 순우리말<br>만물의 근원</h2>
      <div class="s-bar"></div>
      <p class="s-body">
        한울은 동서고금의 어떤 종교나 사상과도 구별되는 독자적 사상 체계입니다.
        우주의 이치(道)가 인간의 삶 속에서 어떻게 펼쳐지는가를 밝히고,
        그 이치에 따라 사는 삶의 길을 제시합니다.
      </p>
    </div>
    <div class="about-cards">
      <div class="about-card">
        <p class="ac-num">01</p>
        <span class="ac-hanja">道</span>
        <h3 class="ac-name">우주도리</h3>
        <p class="ac-sub">우주의 이치를 깨닫다</p>
